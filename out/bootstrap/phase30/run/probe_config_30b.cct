INCIPIT grimoire "probe_config_30b"
ADVOCARE "cct/config.cct"
RITUALE main() REDDE REX
  OBSECRO write_all("out/bootstrap/phase30/run/probe_config_30b.ini", "[core]\nname = cct\n")
  EVOCA SPECULUM NIHIL cfg AD CONIURA config_load_ini("out/bootstrap/phase30/run/probe_config_30b.ini")
  SI CONIURA compare(CONIURA config_get_or(cfg, "core", "name", ""), "cct") == 0
    REDDE 0
  FIN SI
  REDDE 1
EXPLICIT RITUALE
EXPLICIT grimoire
