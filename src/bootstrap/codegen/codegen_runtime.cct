INCIPIT grimoire "codegen_runtime"

ADVOCARE "cct/fmt.cct"
ADVOCARE "cct/verbum.cct"
ADVOCARE "cct/verbum_builder.cct"
ADVOCARE "../parser/ast.cct"
ADVOCARE "codegen.cct"
ADVOCARE "codegen_context.cct"
ADVOCARE "codegen_decl.cct"
ADVOCARE "codegen_emitter.cct"

RITUALE codegen_runtime_escape_c_string(VERBUM raw) REDDE VERBUM
  EVOCA SPECULUM NIHIL b AD CONIURA builder_init()
  CONIURA builder_append_char(b, 34)

  EVOCA REX i AD 0
  EVOCA REX n AD CONIURA len(raw)
  DUM i < n
    EVOCA MILES ch AD CONIURA char_at(raw, i)
    SI ch == 34
      CONIURA builder_append(b, "\\\"")
    ALITER
      SI ch == 92
        CONIURA builder_append(b, "\\\\")
      ALITER
        SI ch == 10
          CONIURA builder_append(b, "\\n")
        ALITER
          SI ch == 13
            CONIURA builder_append(b, "\\r")
          ALITER
            SI ch == 9
              CONIURA builder_append(b, "\\t")
            ALITER
              CONIURA builder_append_char(b, ch)
            FIN SI
          FIN SI
        FIN SI
      FIN SI
    FIN SI
    VINCIRE i AD i + 1
  FIN DUM

  CONIURA builder_append_char(b, 34)
  EVOCA VERBUM out AD CONIURA builder_to_verbum(b)
  CONIURA builder_free(b)
  REDDE out
EXPLICIT RITUALE

RITUALE codegen_runtime_string_symbol(SPECULUM CodegenContext ctx, VERBUM raw_text) REDDE VERBUM
  EVOCA VERBUM existing AD CONIURA codegen_lookup_string_symbol(ctx, raw_text)
  SI CONIURA compare(existing, "") != 0
    REDDE existing
  FIN SI

  EVOCA VERBUM symbol AD CONIURA concat("cct_boot_str_", CONIURA stringify_int(CONIURA codegen_registered_string_count(ctx)))
  REDDE CONIURA codegen_register_string_symbol(ctx, raw_text, symbol)
EXPLICIT RITUALE

RITUALE codegen_runtime_emit_includes(SPECULUM CodegenContext ctx) REDDE NIHIL
  EVOCA VERUM emitted_any AD FALSUM
  SI (*ctx).needs_stdlib
    CONIURA codegen_emit_line(ctx, "#include <string.h>")
    CONIURA codegen_emit_line(ctx, "#include <stdlib.h>")
    CONIURA codegen_emit_line(ctx, "void *cct_rt_option_some(const void *value_ptr, size_t value_size);")
    CONIURA codegen_emit_line(ctx, "void *cct_rt_option_none(size_t value_size);")
    CONIURA codegen_emit_line(ctx, "long long cct_rt_option_is_some(const void *opt_ptr);")
    CONIURA codegen_emit_line(ctx, "long long cct_rt_option_is_none(const void *opt_ptr);")
    CONIURA codegen_emit_line(ctx, "void *cct_rt_option_unwrap_ptr(void *opt_ptr);")
    CONIURA codegen_emit_line(ctx, "void *cct_rt_option_expect_ptr(void *opt_ptr, const char *message);")
    CONIURA codegen_emit_line(ctx, "void cct_rt_option_free(void *opt_ptr);")
    CONIURA codegen_emit_line(ctx, "void *cct_rt_result_ok(const void *value_ptr, size_t ok_size, size_t err_size);")
    CONIURA codegen_emit_line(ctx, "void *cct_rt_result_err(const void *err_ptr, size_t ok_size, size_t err_size);")
    CONIURA codegen_emit_line(ctx, "long long cct_rt_result_is_ok(const void *res_ptr);")
    CONIURA codegen_emit_line(ctx, "long long cct_rt_result_is_err(const void *res_ptr);")
    CONIURA codegen_emit_line(ctx, "void *cct_rt_result_unwrap_ptr(void *res_ptr);")
    CONIURA codegen_emit_line(ctx, "void *cct_rt_result_unwrap_err_ptr(void *res_ptr);")
    CONIURA codegen_emit_line(ctx, "void *cct_rt_result_expect_ptr(void *res_ptr, const char *message);")
    CONIURA codegen_emit_line(ctx, "void cct_rt_result_free(void *res_ptr);")
    CONIURA codegen_emit_line(ctx, "void *cct_rt_map_init(long long key_size, long long value_size);")
    CONIURA codegen_emit_line(ctx, "void cct_rt_map_free(void *map_ptr);")
    CONIURA codegen_emit_line(ctx, "void cct_rt_map_insert(void *map_ptr, const void *key_ptr, const void *value_ptr);")
    CONIURA codegen_emit_line(ctx, "long long cct_rt_map_remove(void *map_ptr, const void *key_ptr);")
    CONIURA codegen_emit_line(ctx, "void *cct_rt_map_get_ptr(void *map_ptr, const void *key_ptr);")
    CONIURA codegen_emit_line(ctx, "long long cct_rt_map_contains(void *map_ptr, const void *key_ptr);")
    CONIURA codegen_emit_line(ctx, "long long cct_rt_map_len(void *map_ptr);")
    CONIURA codegen_emit_line(ctx, "long long cct_rt_map_is_empty(void *map_ptr);")
    CONIURA codegen_emit_line(ctx, "long long cct_rt_map_capacity(void *map_ptr);")
    CONIURA codegen_emit_line(ctx, "void cct_rt_map_clear(void *map_ptr);")
    CONIURA codegen_emit_line(ctx, "void cct_rt_map_reserve(void *map_ptr, long long additional);")
    CONIURA codegen_emit_line(ctx, "void *cct_rt_map_copy(void *map_ptr);")
    CONIURA codegen_emit_line(ctx, "void *cct_rt_map_keys(void *map_ptr, long long key_size);")
    CONIURA codegen_emit_line(ctx, "void *cct_rt_map_values(void *map_ptr, long long value_size);")
    CONIURA codegen_emit_line(ctx, "void cct_rt_map_merge(void *dest_ptr, void *src_ptr);")
    CONIURA codegen_emit_line(ctx, "void *cct_rt_map_iter_begin(void *map_ptr);")
    CONIURA codegen_emit_line(ctx, "long long cct_rt_map_iter_next(void *iter_ptr, void **key_out, void **value_out);")
    CONIURA codegen_emit_line(ctx, "void cct_rt_map_iter_end(void *iter_ptr);")
    CONIURA codegen_emit_line(ctx, "void *cct_rt_set_init(long long item_size);")
    CONIURA codegen_emit_line(ctx, "void cct_rt_set_free(void *set_ptr);")
    CONIURA codegen_emit_line(ctx, "long long cct_rt_set_insert(void *set_ptr, const void *item_ptr);")
    CONIURA codegen_emit_line(ctx, "long long cct_rt_set_remove(void *set_ptr, const void *item_ptr);")
    CONIURA codegen_emit_line(ctx, "long long cct_rt_set_contains(void *set_ptr, const void *item_ptr);")
    CONIURA codegen_emit_line(ctx, "long long cct_rt_set_len(void *set_ptr);")
    CONIURA codegen_emit_line(ctx, "long long cct_rt_set_is_empty(void *set_ptr);")
    CONIURA codegen_emit_line(ctx, "void cct_rt_set_clear(void *set_ptr);")
    CONIURA codegen_emit_line(ctx, "void *cct_rt_set_union(void *a_ptr, void *b_ptr, long long item_size);")
    CONIURA codegen_emit_line(ctx, "void *cct_rt_set_intersection(void *a_ptr, void *b_ptr, long long item_size);")
    CONIURA codegen_emit_line(ctx, "void *cct_rt_set_difference(void *a_ptr, void *b_ptr, long long item_size);")
    CONIURA codegen_emit_line(ctx, "void *cct_rt_set_symmetric_difference(void *a_ptr, void *b_ptr, long long item_size);")
    CONIURA codegen_emit_line(ctx, "long long cct_rt_set_is_subset(void *a_ptr, void *b_ptr, long long item_size);")
    CONIURA codegen_emit_line(ctx, "long long cct_rt_set_equals(void *a_ptr, void *b_ptr, long long item_size);")
    CONIURA codegen_emit_line(ctx, "void *cct_rt_set_copy(void *set_ptr, long long item_size);")
    CONIURA codegen_emit_line(ctx, "void *cct_rt_set_to_fluxus(void *set_ptr, long long item_size);")
    CONIURA codegen_emit_line(ctx, "void cct_rt_set_reserve(void *set_ptr, long long additional);")
    CONIURA codegen_emit_line(ctx, "long long cct_rt_set_capacity(void *set_ptr);")
    CONIURA codegen_emit_line(ctx, "void *cct_rt_set_iter_begin(void *set_ptr);")
    CONIURA codegen_emit_line(ctx, "long long cct_rt_set_iter_next(void *iter_ptr, void **item_out);")
    CONIURA codegen_emit_line(ctx, "void cct_rt_set_iter_end(void *iter_ptr);")
    CONIURA codegen_emit_line(ctx, "static long long cct_rt_bytes_get(void *ptr, long long i) __attribute__((unused));")
    VINCIRE emitted_any AD VERUM
  FIN SI
  SI (*ctx).needs_args_runtime
    CONIURA codegen_emit_line(ctx, "void cct_rt_args_init(int argc, char **argv);")
    VINCIRE emitted_any AD VERUM
  FIN SI
  SI (*ctx).needs_failure_runtime
    CONIURA codegen_emit_line(ctx, "#include <setjmp.h>")
    VINCIRE emitted_any AD VERUM
  FIN SI
  SI (*ctx).needs_stdio
    CONIURA codegen_emit_line(ctx, "#include <stdio.h>")
    VINCIRE emitted_any AD VERUM
  FIN SI
  SI (*ctx).needs_math_runtime
    CONIURA codegen_emit_line(ctx, "#include <math.h>")
    VINCIRE emitted_any AD VERUM
  FIN SI
  SI (*ctx).needs_time_runtime
    CONIURA codegen_emit_line(ctx, "#include <time.h>")
    CONIURA codegen_emit_line(ctx, "long long cct_rt_time_now_ms(void);")
    VINCIRE emitted_any AD VERUM
  FIN SI
  SI (*ctx).needs_fs_runtime
    CONIURA codegen_emit_line(ctx, "char* cct_rt_fs_read_all(const char *path);")
    CONIURA codegen_emit_line(ctx, "void cct_rt_fs_write_all(const char *path, const char *content);")
    CONIURA codegen_emit_line(ctx, "long long cct_rt_fs_exists(const char *path);")
    CONIURA codegen_emit_line(ctx, "void cct_rt_fs_mkdir_all(const char *path);")
    VINCIRE emitted_any AD VERUM
  FIN SI
  SI emitted_any
    CONIURA codegen_emit_blank_line(ctx)
  FIN SI
  REDDE
EXPLICIT RITUALE

RITUALE codegen_runtime_emit_failure_runtime(SPECULUM CodegenContext ctx) REDDE NIHIL
  SI NON (*ctx).needs_failure_runtime
    REDDE
  FIN SI

  CONIURA codegen_emit_line(ctx, "static jmp_buf *cct_boot_try_top = NULL;")
  CONIURA codegen_emit_line(ctx, "static const char *cct_boot_error_value = NULL;")
  CONIURA codegen_emit_blank_line(ctx)
  CONIURA codegen_emit_line(ctx, "static void cct_boot_throw(const char* message) __attribute__((unused));")
  CONIURA codegen_emit_line(ctx, "static void cct_boot_throw(const char* message)")
  CONIURA codegen_emit_block_open(ctx)
  CONIURA codegen_emit_line(ctx, "cct_boot_error_value = message ? message : \"\";")
  CONIURA codegen_emit_line(ctx, "if (cct_boot_try_top) longjmp(*cct_boot_try_top, 1);")
  CONIURA codegen_emit_line(ctx, "cct_boot_fail(cct_boot_error_value);")
  CONIURA codegen_emit_block_close(ctx)
  CONIURA codegen_emit_blank_line(ctx)
  REDDE
EXPLICIT RITUALE

RITUALE codegen_runtime_emit_fmt_runtime(SPECULUM CodegenContext ctx) REDDE NIHIL
  SI NON (*ctx).needs_fmt_runtime
    REDDE
  FIN SI

  CONIURA codegen_emit_line(ctx, "static char *cct_rt_copy_string(const char *s) __attribute__((unused));")
  CONIURA codegen_emit_line(ctx, "static char *cct_rt_copy_string(const char *s)")
  CONIURA codegen_emit_block_open(ctx)
  CONIURA codegen_emit_line(ctx, "size_t n = strlen(s);")
  CONIURA codegen_emit_line(ctx, "char *out = (char*)malloc(n + 1);")
  CONIURA codegen_emit_line(ctx, "if (!out) cct_boot_fail(\"out of memory\");")
  CONIURA codegen_emit_line(ctx, "memcpy(out, s, n + 1);")
  CONIURA codegen_emit_line(ctx, "return out;")
  CONIURA codegen_emit_block_close(ctx)
  CONIURA codegen_emit_blank_line(ctx)

  CONIURA codegen_emit_line(ctx, "static char *cct_rt_fmt_stringify_int(long long x) __attribute__((unused));")
  CONIURA codegen_emit_line(ctx, "static char *cct_rt_fmt_stringify_int(long long x)")
  CONIURA codegen_emit_block_open(ctx)
  CONIURA codegen_emit_line(ctx, "char buf[64];")
  CONIURA codegen_emit_line(ctx, "snprintf(buf, sizeof(buf), \"%lld\", x);")
  CONIURA codegen_emit_line(ctx, "return cct_rt_copy_string(buf);")
  CONIURA codegen_emit_block_close(ctx)
  CONIURA codegen_emit_blank_line(ctx)

  CONIURA codegen_emit_line(ctx, "static char *cct_rt_fmt_stringify_real(double x) __attribute__((unused));")
  CONIURA codegen_emit_line(ctx, "static char *cct_rt_fmt_stringify_real(double x)")
  CONIURA codegen_emit_block_open(ctx)
  CONIURA codegen_emit_line(ctx, "char buf[128];")
  CONIURA codegen_emit_line(ctx, "snprintf(buf, sizeof(buf), \"%.15g\", x);")
  CONIURA codegen_emit_line(ctx, "return cct_rt_copy_string(buf);")
  CONIURA codegen_emit_block_close(ctx)
  CONIURA codegen_emit_blank_line(ctx)

  CONIURA codegen_emit_line(ctx, "typedef struct {")
  CONIURA codegen_emit_line(ctx, "char *buf;")
  CONIURA codegen_emit_line(ctx, "size_t len;")
  CONIURA codegen_emit_line(ctx, "size_t cap;")
  CONIURA codegen_emit_line(ctx, "} cct_rt_molde_ctx_t;")
  CONIURA codegen_emit_blank_line(ctx)

  CONIURA codegen_emit_line(ctx, "static cct_rt_molde_ctx_t *cct_rt_molde_begin(void) __attribute__((unused));")
  CONIURA codegen_emit_line(ctx, "static cct_rt_molde_ctx_t *cct_rt_molde_begin(void)")
  CONIURA codegen_emit_block_open(ctx)
  CONIURA codegen_emit_line(ctx, "cct_rt_molde_ctx_t *m = (cct_rt_molde_ctx_t*)malloc(sizeof(cct_rt_molde_ctx_t));")
  CONIURA codegen_emit_line(ctx, "if (!m) cct_boot_fail(\"MOLDE allocation failed\");")
  CONIURA codegen_emit_line(ctx, "m->cap = 128;")
  CONIURA codegen_emit_line(ctx, "m->len = 0;")
  CONIURA codegen_emit_line(ctx, "m->buf = (char*)malloc(m->cap);")
  CONIURA codegen_emit_line(ctx, "if (!m->buf) cct_boot_fail(\"MOLDE buffer allocation failed\");")
  CONIURA codegen_emit_line(ctx, "m->buf[0] = '\\0';")
  CONIURA codegen_emit_line(ctx, "return m;")
  CONIURA codegen_emit_block_close(ctx)
  CONIURA codegen_emit_blank_line(ctx)

  CONIURA codegen_emit_line(ctx, "static void cct_rt_molde_append(cct_rt_molde_ctx_t *m, const char *s, size_t slen) __attribute__((unused));")
  CONIURA codegen_emit_line(ctx, "static void cct_rt_molde_append(cct_rt_molde_ctx_t *m, const char *s, size_t slen)")
  CONIURA codegen_emit_block_open(ctx)
  CONIURA codegen_emit_line(ctx, "if (!m || !s || slen == 0) return;")
  CONIURA codegen_emit_line(ctx, "while (m->len + slen + 1 > m->cap) {")
  CONIURA codegen_emit_line(ctx, "size_t next = m->cap * 2;")
  CONIURA codegen_emit_line(ctx, "if (next <= m->cap) cct_boot_fail(\"MOLDE buffer overflow\");")
  CONIURA codegen_emit_line(ctx, "char *grown = (char*)realloc(m->buf, next);")
  CONIURA codegen_emit_line(ctx, "if (!grown) cct_boot_fail(\"MOLDE realloc failed\");")
  CONIURA codegen_emit_line(ctx, "m->buf = grown;")
  CONIURA codegen_emit_line(ctx, "m->cap = next;")
  CONIURA codegen_emit_line(ctx, "}")
  CONIURA codegen_emit_line(ctx, "memcpy(m->buf + m->len, s, slen);")
  CONIURA codegen_emit_line(ctx, "m->len += slen;")
  CONIURA codegen_emit_line(ctx, "m->buf[m->len] = '\\0';")
  CONIURA codegen_emit_block_close(ctx)
  CONIURA codegen_emit_blank_line(ctx)

  CONIURA codegen_emit_line(ctx, "static void cct_rt_molde_str(cct_rt_molde_ctx_t *m, const char *s) __attribute__((unused));")
  CONIURA codegen_emit_line(ctx, "static void cct_rt_molde_str(cct_rt_molde_ctx_t *m, const char *s)")
  CONIURA codegen_emit_block_open(ctx)
  CONIURA codegen_emit_line(ctx, "const char *src = s ? s : \"\";")
  CONIURA codegen_emit_line(ctx, "cct_rt_molde_append(m, src, strlen(src));")
  CONIURA codegen_emit_block_close(ctx)
  CONIURA codegen_emit_blank_line(ctx)

  CONIURA codegen_emit_line(ctx, "static void cct_rt_molde_rex(cct_rt_molde_ctx_t *m, long long v) __attribute__((unused));")
  CONIURA codegen_emit_line(ctx, "static void cct_rt_molde_rex(cct_rt_molde_ctx_t *m, long long v)")
  CONIURA codegen_emit_block_open(ctx)
  CONIURA codegen_emit_line(ctx, "char tmp[64];")
  CONIURA codegen_emit_line(ctx, "int n = snprintf(tmp, sizeof(tmp), \"%lld\", v);")
  CONIURA codegen_emit_line(ctx, "if (n < 0) cct_boot_fail(\"MOLDE rex formatting failed\");")
  CONIURA codegen_emit_line(ctx, "cct_rt_molde_append(m, tmp, (size_t)n);")
  CONIURA codegen_emit_block_close(ctx)
  CONIURA codegen_emit_blank_line(ctx)

  CONIURA codegen_emit_line(ctx, "static void cct_rt_molde_dux(cct_rt_molde_ctx_t *m, unsigned long long v) __attribute__((unused));")
  CONIURA codegen_emit_line(ctx, "static void cct_rt_molde_dux(cct_rt_molde_ctx_t *m, unsigned long long v)")
  CONIURA codegen_emit_block_open(ctx)
  CONIURA codegen_emit_line(ctx, "char tmp[64];")
  CONIURA codegen_emit_line(ctx, "int n = snprintf(tmp, sizeof(tmp), \"%llu\", v);")
  CONIURA codegen_emit_line(ctx, "if (n < 0) cct_boot_fail(\"MOLDE dux formatting failed\");")
  CONIURA codegen_emit_line(ctx, "cct_rt_molde_append(m, tmp, (size_t)n);")
  CONIURA codegen_emit_block_close(ctx)
  CONIURA codegen_emit_blank_line(ctx)

  CONIURA codegen_emit_line(ctx, "static void cct_rt_molde_umbra(cct_rt_molde_ctx_t *m, double v) __attribute__((unused));")
  CONIURA codegen_emit_line(ctx, "static void cct_rt_molde_umbra(cct_rt_molde_ctx_t *m, double v)")
  CONIURA codegen_emit_block_open(ctx)
  CONIURA codegen_emit_line(ctx, "char tmp[128];")
  CONIURA codegen_emit_line(ctx, "int n = snprintf(tmp, sizeof(tmp), \"%g\", v);")
  CONIURA codegen_emit_line(ctx, "if (n < 0) cct_boot_fail(\"MOLDE umbra formatting failed\");")
  CONIURA codegen_emit_line(ctx, "cct_rt_molde_append(m, tmp, (size_t)n);")
  CONIURA codegen_emit_block_close(ctx)
  CONIURA codegen_emit_blank_line(ctx)

  CONIURA codegen_emit_line(ctx, "static void cct_rt_molde_verum(cct_rt_molde_ctx_t *m, long long v) __attribute__((unused));")
  CONIURA codegen_emit_line(ctx, "static void cct_rt_molde_verum(cct_rt_molde_ctx_t *m, long long v)")
  CONIURA codegen_emit_block_open(ctx)
  CONIURA codegen_emit_line(ctx, "const char *txt = v ? \"VERUM\" : \"FALSUM\";")
  CONIURA codegen_emit_line(ctx, "cct_rt_molde_append(m, txt, strlen(txt));")
  CONIURA codegen_emit_block_close(ctx)
  CONIURA codegen_emit_blank_line(ctx)

  CONIURA codegen_emit_line(ctx, "static void cct_rt_molde_fmt_build(char *fmt, size_t fmt_cap, const char *spec, const char *length_mod) __attribute__((unused));")
  CONIURA codegen_emit_line(ctx, "static void cct_rt_molde_fmt_build(char *fmt, size_t fmt_cap, const char *spec, const char *length_mod)")
  CONIURA codegen_emit_block_open(ctx)
  CONIURA codegen_emit_line(ctx, "if (!fmt || fmt_cap == 0) cct_boot_fail(\"MOLDE format buffer invalid\");")
  CONIURA codegen_emit_line(ctx, "if (!spec || !spec[0]) cct_boot_fail(\"MOLDE format spec vazio\");")
  CONIURA codegen_emit_line(ctx, "size_t spec_len = strlen(spec);")
  CONIURA codegen_emit_line(ctx, "char conv = spec[spec_len - 1];")
  CONIURA codegen_emit_line(ctx, "size_t prefix_len = spec_len - 1;")
  CONIURA codegen_emit_line(ctx, "int n;")
  CONIURA codegen_emit_line(ctx, "if (length_mod && length_mod[0]) n = snprintf(fmt, fmt_cap, \"%%%.*s%s%c\", (int)prefix_len, spec, length_mod, conv);")
  CONIURA codegen_emit_line(ctx, "else n = snprintf(fmt, fmt_cap, \"%%%s\", spec);")
  CONIURA codegen_emit_line(ctx, "if (n < 0 || (size_t)n >= fmt_cap) cct_boot_fail(\"MOLDE format spec overflow\");")
  CONIURA codegen_emit_block_close(ctx)
  CONIURA codegen_emit_blank_line(ctx)

  CONIURA codegen_emit_line(ctx, "static void cct_rt_molde_rex_fmt(cct_rt_molde_ctx_t *m, long long v, const char *spec) __attribute__((unused));")
  CONIURA codegen_emit_line(ctx, "static void cct_rt_molde_rex_fmt(cct_rt_molde_ctx_t *m, long long v, const char *spec)")
  CONIURA codegen_emit_block_open(ctx)
  CONIURA codegen_emit_line(ctx, "char fmt[64];")
  CONIURA codegen_emit_line(ctx, "cct_rt_molde_fmt_build(fmt, sizeof(fmt), spec, \"ll\");")
  CONIURA codegen_emit_line(ctx, "int need = snprintf(NULL, 0, fmt, v);")
  CONIURA codegen_emit_line(ctx, "if (need < 0) cct_boot_fail(\"MOLDE rex fmt sizing failed\");")
  CONIURA codegen_emit_line(ctx, "char *tmp = (char*)malloc((size_t)need + 1);")
  CONIURA codegen_emit_line(ctx, "if (!tmp) cct_boot_fail(\"MOLDE rex fmt allocation failed\");")
