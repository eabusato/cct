RITUALE codegen_runtime_emit_string_pool(SPECULUM CodegenContext ctx) REDDE NIHIL
  EVOCA REX n AD CONIURA codegen_registered_string_count(ctx)
  SI n == 0
    REDDE
  FIN SI

  EVOCA REX i AD 0
  DUM i < n
    EVOCA SPECULUM CodegenStringLiteral item AD CONIURA codegen_context_string_at(ctx, i)
    EVOCA VERBUM quoted AD CONIURA codegen_runtime_escape_c_string((*item).raw_text)
    CONIURA codegen_emit(ctx, "static char ")
    CONIURA codegen_emit(ctx, (*item).symbol_name)
    CONIURA codegen_emit(ctx, "[] = ")
    CONIURA codegen_emit(ctx, quoted)
    CONIURA codegen_emit_line(ctx, ";")
    DIMITTE quoted
    VINCIRE i AD i + 1
  FIN DUM
  CONIURA codegen_emit_blank_line(ctx)
  REDDE
EXPLICIT RITUALE

RITUALE codegen_runtime_find_entry_main_index(SPECULUM AstProgram program) REDDE REX
  EVOCA REX i AD 0
  EVOCA REX n AD CONIURA ast_node_list_len((*program).declarations)
  DUM i < n
    EVOCA SPECULUM AstNode decl AD CONIURA ast_node_list_get((*program).declarations, i)
    SI (*decl).kind == AST_RITUALE ET CONIURA compare((*decl).name, "main") == 0
      REDDE i
    FIN SI
    VINCIRE i AD i + 1
  FIN DUM
  REDDE -1
EXPLICIT RITUALE

RITUALE codegen_runtime_program_needs_args_init(SPECULUM AstProgram program) REDDE VERUM
  EVOCA REX i AD 0
  EVOCA REX n AD CONIURA ast_node_list_len((*program).declarations)
  DUM i < n
    EVOCA SPECULUM AstNode decl AD CONIURA ast_node_list_get((*program).declarations, i)
    SI (*decl).kind == AST_RITUALE
      SI CONIURA compare((*decl).name, "argc") == 0 VEL CONIURA compare((*decl).name, "arg") == 0
        REDDE VERUM
      FIN SI
    FIN SI
    VINCIRE i AD i + 1
  FIN DUM
  REDDE FALSUM
EXPLICIT RITUALE

RITUALE codegen_runtime_detect_body_dependencies(SPECULUM CodegenContext ctx, VERBUM body) REDDE NIHIL
  SI CONIURA contains(body, "free(")
    CONIURA codegen_require_stdlib(ctx)
  FIN SI
  SI CONIURA contains(body, "malloc(")
    CONIURA codegen_require_stdlib(ctx)
  FIN SI
  SI CONIURA contains(body, "strcmp(")
    CONIURA codegen_require_stdlib(ctx)
  FIN SI
  SI CONIURA contains(body, "strlen(")
    CONIURA codegen_require_stdlib(ctx)
  FIN SI
  SI CONIURA contains(body, "memcpy(")
    CONIURA codegen_require_stdlib(ctx)
  FIN SI
  SI CONIURA contains(body, "memset(")
    CONIURA codegen_require_stdlib(ctx)
  FIN SI
  REDDE
EXPLICIT RITUALE

RITUALE codegen_runtime_emit_host_main(SPECULUM CodegenContext ctx, SPECULUM AstProgram program) REDDE NIHIL
  EVOCA REX entry_idx AD CONIURA codegen_runtime_find_entry_main_index(program)

  SI (*ctx).needs_args_runtime
    CONIURA codegen_emit_line(ctx, "int main(int argc, char **argv)")
  ALITER
    CONIURA codegen_emit_line(ctx, "int main(void)")
  FIN SI
  CONIURA codegen_emit_block_open(ctx)
  SI (*ctx).needs_args_runtime
    CONIURA codegen_emit_line(ctx, "cct_rt_args_init(argc, argv);")
  FIN SI
  SI entry_idx < 0
    CONIURA codegen_emit_line(ctx, "return 0;")
    CONIURA codegen_emit_block_close(ctx)
    REDDE
  FIN SI
  EVOCA SPECULUM AstNode entry AD CONIURA ast_node_list_get((*program).declarations, entry_idx)
  SI (*entry).has_return_type ET CONIURA compare((*(*entry).return_type).type_name, "NIHIL") == 0
    CONIURA codegen_emit(ctx, CONIURA codegen_rituale_c_name(ctx, "main"))
    CONIURA codegen_emit_line(ctx, "();")
    CONIURA codegen_emit_line(ctx, "return 0;")
  ALITER
    CONIURA codegen_emit(ctx, "return (int)")
    CONIURA codegen_emit(ctx, CONIURA codegen_rituale_c_name(ctx, "main"))
    CONIURA codegen_emit_line(ctx, "();")
  FIN SI
  CONIURA codegen_emit_block_close(ctx)
  REDDE
EXPLICIT RITUALE

RITUALE codegen_generate_translation_unit_with_context(SPECULUM CodegenContext ctx, SPECULUM AstProgram program) REDDE VERBUM
  CONIURA codegen_emit_program_body(ctx, program)
  SI CONIURA codegen_runtime_program_needs_args_init(program)
    CONIURA codegen_require_args_runtime(ctx)
  FIN SI
  EVOCA VERBUM body AD CONIURA codegen_output(ctx)
  CONIURA codegen_runtime_detect_body_dependencies(ctx, body)

  CONIURA codegen_context_reset_output(ctx)
  CONIURA codegen_emit_line(ctx, "/* generated by cct bootstrap codegen */")
  CONIURA codegen_emit_blank_line(ctx)
  CONIURA codegen_emit_line(ctx, "#if defined(__GNUC__) && !defined(__clang__)")
  CONIURA codegen_emit_line(ctx, "#pragma GCC diagnostic push")
  CONIURA codegen_emit_line(ctx, "#pragma GCC diagnostic ignored \"-Wclobbered\"")
  CONIURA codegen_emit_line(ctx, "#endif")
  CONIURA codegen_emit_blank_line(ctx)
  CONIURA codegen_runtime_emit_includes(ctx)
  CONIURA codegen_runtime_emit_fail_helper(ctx)
  CONIURA codegen_runtime_emit_scribe_runtime(ctx)
  CONIURA codegen_runtime_emit_verbum_runtime(ctx)
  CONIURA codegen_runtime_emit_bytes_runtime(ctx)
  CONIURA codegen_runtime_emit_gettext_runtime(ctx)
  CONIURA codegen_runtime_emit_failure_runtime(ctx)
  CONIURA codegen_runtime_emit_fmt_runtime(ctx)
  CONIURA codegen_runtime_emit_time_runtime(ctx)
  CONIURA codegen_runtime_emit_string_pool(ctx)
  CONIURA codegen_emit(ctx, body)
  DIMITTE body
  CONIURA codegen_emit_blank_line(ctx)
  CONIURA codegen_runtime_emit_host_main(ctx, program)
  CONIURA codegen_emit_blank_line(ctx)
  CONIURA codegen_emit_line(ctx, "#if defined(__GNUC__) && !defined(__clang__)")
  CONIURA codegen_emit_line(ctx, "#pragma GCC diagnostic pop")
  CONIURA codegen_emit_line(ctx, "#endif")
  REDDE CONIURA codegen_output(ctx)
EXPLICIT RITUALE

RITUALE codegen_generate_translation_unit(SPECULUM AstProgram program, VERBUM filename) REDDE VERBUM
  EVOCA SPECULUM CodegenContext ctx AD CONIURA codegen_context_new(filename)
  CONIURA codegen_context_reset(ctx)
  EVOCA VERBUM out AD CONIURA codegen_generate_translation_unit_with_context(ctx, program)
  CONIURA codegen_context_free(ctx)
  REDDE out
EXPLICIT RITUALE

EXPLICIT grimoire
