RITUALE codegen_registered_generic_sigillum_template_count(SPECULUM CodegenContext ctx) REDDE REX
  REDDE CONIURA fluxus_len((*ctx).generic_sigillum_templates)
EXPLICIT RITUALE

RITUALE codegen_find_generic_sigillum_template_index(SPECULUM CodegenContext ctx, VERBUM source_name) REDDE REX
  EVOCA REX i AD 0
  EVOCA REX n AD CONIURA fluxus_len((*ctx).generic_sigillum_templates)
  DUM i < n
    EVOCA SPECULUM CodegenGenericSigillumTemplate item AD CONIURA codegen_context_generic_sigillum_template_at(ctx, i)
    SI CONIURA compare((*item).source_name, source_name) == 0
      REDDE i
    FIN SI
    VINCIRE i AD i + 1
  FIN DUM
  REDDE -1
EXPLICIT RITUALE

RITUALE codegen_register_generic_sigillum_template(SPECULUM CodegenContext ctx, VERBUM source_name, SPECULUM AstNode decl_node, REX arity) REDDE NIHIL
  SI CONIURA codegen_find_generic_sigillum_template_index(ctx, source_name) >= 0
    REDDE
  FIN SI
  EVOCA CodegenGenericSigillumTemplate item
  VINCIRE item.source_name AD CONIURA verbum_dup(source_name)
  VINCIRE item.owns_source_name AD VERUM
  VINCIRE item.decl_node AD decl_node
  VINCIRE item.arity AD arity
  CONIURA fluxus_push((*ctx).generic_sigillum_templates, SPECULUM item)
  REDDE
EXPLICIT RITUALE

RITUALE codegen_lookup_generic_sigillum_template(SPECULUM CodegenContext ctx, VERBUM source_name) REDDE SPECULUM AstNode
  EVOCA REX idx AD CONIURA codegen_find_generic_sigillum_template_index(ctx, source_name)
  EVOCA SPECULUM CodegenGenericSigillumTemplate item AD CONIURA codegen_context_generic_sigillum_template_at(ctx, idx)
  REDDE (*item).decl_node
EXPLICIT RITUALE

RITUALE codegen_registered_generic_sigillum_instance_count(SPECULUM CodegenContext ctx) REDDE REX
  REDDE CONIURA fluxus_len((*ctx).generic_sigillum_instances)
EXPLICIT RITUALE

RITUALE codegen_find_generic_sigillum_instance_index(SPECULUM CodegenContext ctx, VERBUM instance_key) REDDE REX
  EVOCA REX i AD 0
  EVOCA REX n AD CONIURA fluxus_len((*ctx).generic_sigillum_instances)
  DUM i < n
    EVOCA SPECULUM CodegenGenericSigillumInstance item AD CONIURA codegen_context_generic_sigillum_instance_at(ctx, i)
    SI CONIURA compare((*item).instance_key, instance_key) == 0
      REDDE i
    FIN SI
    VINCIRE i AD i + 1
  FIN DUM
  REDDE -1
EXPLICIT RITUALE

RITUALE codegen_register_generic_sigillum_instance(SPECULUM CodegenContext ctx, VERBUM instance_key, VERBUM c_name, SPECULUM AstNode template_decl, SPECULUM NIHIL type_args) REDDE VERBUM
  EVOCA REX idx AD CONIURA codegen_find_generic_sigillum_instance_index(ctx, instance_key)
  SI idx >= 0
    EVOCA SPECULUM CodegenGenericSigillumInstance existing AD CONIURA codegen_context_generic_sigillum_instance_at(ctx, idx)
    REDDE (*existing).c_name
  FIN SI
  EVOCA CodegenGenericSigillumInstance item
  VINCIRE item.instance_key AD CONIURA verbum_dup(instance_key)
  VINCIRE item.owns_instance_key AD VERUM
  VINCIRE item.c_name AD CONIURA verbum_dup(c_name)
  VINCIRE item.owns_c_name AD VERUM
  VINCIRE item.template_decl AD template_decl
  VINCIRE item.type_args AD type_args
  CONIURA fluxus_push((*ctx).generic_sigillum_instances, SPECULUM item)
  REDDE c_name
EXPLICIT RITUALE

RITUALE codegen_registered_generic_rituale_template_count(SPECULUM CodegenContext ctx) REDDE REX
  REDDE CONIURA fluxus_len((*ctx).generic_rituale_templates)
EXPLICIT RITUALE

RITUALE codegen_find_generic_rituale_template_index(SPECULUM CodegenContext ctx, VERBUM source_name) REDDE REX
  EVOCA REX i AD 0
  EVOCA REX n AD CONIURA fluxus_len((*ctx).generic_rituale_templates)
  DUM i < n
    EVOCA SPECULUM CodegenGenericRitualeTemplate item AD CONIURA codegen_context_generic_rituale_template_at(ctx, i)
    SI CONIURA compare((*item).source_name, source_name) == 0
      REDDE i
    FIN SI
    VINCIRE i AD i + 1
  FIN DUM
  REDDE -1
EXPLICIT RITUALE

RITUALE codegen_register_generic_rituale_template(SPECULUM CodegenContext ctx, VERBUM source_name, SPECULUM AstNode decl_node, REX arity) REDDE NIHIL
  SI CONIURA codegen_find_generic_rituale_template_index(ctx, source_name) >= 0
    REDDE
  FIN SI
  EVOCA CodegenGenericRitualeTemplate item
  VINCIRE item.source_name AD CONIURA verbum_dup(source_name)
  VINCIRE item.owns_source_name AD VERUM
  VINCIRE item.decl_node AD decl_node
  VINCIRE item.arity AD arity
  CONIURA fluxus_push((*ctx).generic_rituale_templates, SPECULUM item)
  REDDE
EXPLICIT RITUALE

RITUALE codegen_lookup_generic_rituale_template(SPECULUM CodegenContext ctx, VERBUM source_name) REDDE SPECULUM AstNode
  EVOCA REX idx AD CONIURA codegen_find_generic_rituale_template_index(ctx, source_name)
  EVOCA SPECULUM CodegenGenericRitualeTemplate item AD CONIURA codegen_context_generic_rituale_template_at(ctx, idx)
  REDDE (*item).decl_node
EXPLICIT RITUALE

RITUALE codegen_registered_generic_rituale_instance_count(SPECULUM CodegenContext ctx) REDDE REX
  REDDE CONIURA fluxus_len((*ctx).generic_rituale_instances)
EXPLICIT RITUALE

RITUALE codegen_find_generic_rituale_instance_index(SPECULUM CodegenContext ctx, VERBUM instance_key) REDDE REX
  EVOCA REX i AD 0
  EVOCA REX n AD CONIURA fluxus_len((*ctx).generic_rituale_instances)
  DUM i < n
    EVOCA SPECULUM CodegenGenericRitualeInstance item AD CONIURA codegen_context_generic_rituale_instance_at(ctx, i)
    SI CONIURA compare((*item).instance_key, instance_key) == 0
      REDDE i
    FIN SI
    VINCIRE i AD i + 1
  FIN DUM
  REDDE -1
EXPLICIT RITUALE

RITUALE codegen_register_generic_rituale_instance(SPECULUM CodegenContext ctx, VERBUM instance_key, VERBUM c_name, VERBUM return_type_name, SPECULUM AstNode template_decl, SPECULUM NIHIL type_args) REDDE VERBUM
  EVOCA REX idx AD CONIURA codegen_find_generic_rituale_instance_index(ctx, instance_key)
  SI idx >= 0
    EVOCA SPECULUM CodegenGenericRitualeInstance existing AD CONIURA codegen_context_generic_rituale_instance_at(ctx, idx)
    REDDE (*existing).c_name
  FIN SI
  EVOCA CodegenGenericRitualeInstance item
  VINCIRE item.instance_key AD CONIURA verbum_dup(instance_key)
  VINCIRE item.owns_instance_key AD VERUM
  VINCIRE item.c_name AD CONIURA verbum_dup(c_name)
  VINCIRE item.owns_c_name AD VERUM
  VINCIRE item.return_type_name AD CONIURA verbum_dup(return_type_name)
  VINCIRE item.owns_return_type_name AD VERUM
  VINCIRE item.template_decl AD template_decl
  VINCIRE item.type_args AD type_args
  CONIURA fluxus_push((*ctx).generic_rituale_instances, SPECULUM item)
  REDDE c_name
EXPLICIT RITUALE

RITUALE codegen_push_generic_binding_scope(SPECULUM CodegenContext ctx) REDDE NIHIL
  EVOCA REX mark AD CONIURA fluxus_len((*ctx).generic_bindings)
  CONIURA fluxus_push((*ctx).generic_binding_marks, SPECULUM mark)
  REDDE
EXPLICIT RITUALE

RITUALE codegen_pop_generic_binding_scope(SPECULUM CodegenContext ctx) REDDE NIHIL
  SI CONIURA fluxus_len((*ctx).generic_binding_marks) == 0
    REDDE
  FIN SI
  EVOCA REX mark AD 0
  CONIURA fluxus_pop((*ctx).generic_binding_marks, SPECULUM mark)
  DUM CONIURA fluxus_len((*ctx).generic_bindings) > mark
    EVOCA REX idx AD CONIURA fluxus_len((*ctx).generic_bindings) - 1
    EVOCA SPECULUM CodegenGenericBinding item AD CONIURA codegen_context_generic_binding_at(ctx, idx)
    SI (*item).owns_param_name
      DIMITTE (*item).param_name
    FIN SI
    CONIURA fluxus_remove((*ctx).generic_bindings, idx)
  FIN DUM
  REDDE
EXPLICIT RITUALE

RITUALE codegen_define_generic_binding(SPECULUM CodegenContext ctx, VERBUM param_name, SPECULUM AstNode type_expr) REDDE NIHIL
  EVOCA CodegenGenericBinding item
  VINCIRE item.param_name AD CONIURA verbum_dup(param_name)
  VINCIRE item.owns_param_name AD VERUM
  VINCIRE item.type_expr AD type_expr
  CONIURA fluxus_push((*ctx).generic_bindings, SPECULUM item)
  REDDE
EXPLICIT RITUALE

RITUALE codegen_find_generic_binding_index(SPECULUM CodegenContext ctx, VERBUM param_name) REDDE REX
  EVOCA REX i AD CONIURA fluxus_len((*ctx).generic_bindings) - 1
  DUM i >= 0
    EVOCA SPECULUM CodegenGenericBinding item AD CONIURA codegen_context_generic_binding_at(ctx, i)
    SI CONIURA compare((*item).param_name, param_name) == 0
      REDDE i
    FIN SI
    VINCIRE i AD i - 1
  FIN DUM
  REDDE -1
EXPLICIT RITUALE

RITUALE codegen_lookup_generic_binding(SPECULUM CodegenContext ctx, VERBUM param_name) REDDE SPECULUM AstNode
  EVOCA REX idx AD CONIURA codegen_find_generic_binding_index(ctx, param_name)
  EVOCA SPECULUM CodegenGenericBinding item AD CONIURA codegen_context_generic_binding_at(ctx, idx)
  REDDE (*item).type_expr
EXPLICIT RITUALE

EXPLICIT grimoire
