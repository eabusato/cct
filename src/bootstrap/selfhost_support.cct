EXPLICIT RITUALE

RITUALE run_capture_err(VERBUM cmd) REDDE VERBUM
  EVOCA VERBUM wrapped AD CONIURA concat(CONIURA concat("{ ", cmd), " ; } 2>&1 >/dev/null")
  REDDE CONIURA run_capture(wrapped)
EXPLICIT RITUALE

