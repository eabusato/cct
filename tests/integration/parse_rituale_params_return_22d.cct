INCIPIT grimoire "parse_rituale_params_return_22d"
ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/parser/parser.cct"
RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"x\" RITUALE sum(REX a, REX b) REDDE REX REDDE a EXPLICIT RITUALE EXPLICIT grimoire"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(src, "m.cct")
  EVOCA SPECULUM AstNode decl AD CONIURA ast_node_list_get((*program).declarations, 0)
  SI CONIURA ast_node_list_len((*decl).params) != 2
    REDDE 41
  FIN SI
  EVOCA SPECULUM AstNode param1 AD CONIURA ast_node_list_get((*decl).params, 0)
  SI CONIURA compare((*param1).name, "a") != 0
    REDDE 42
  FIN SI
  SI CONIURA compare((*(*decl).return_type).type_name, "REX") != 0
    REDDE 43
  FIN SI
  CONIURA ast_program_free(program)
  REDDE 0
EXPLICIT RITUALE
EXPLICIT grimoire
