INCIPIT grimoire "http_client_post_local_20c3"

ADVOCARE "cct/fs.cct"
ADVOCARE "cct/http.cct"
ADVOCARE "cct/process.cct"
ADVOCARE "cct/time.cct"
ADVOCARE "cct/verbum.cct"

RITUALE cleanup_file(VERBUM path) REDDE NIHIL
  SI CONIURA exists(path)
    CONIURA delete_file(path)
  FIN SI
  REDDE
EXPLICIT RITUALE

RITUALE wait_for_file(VERBUM path, REX timeout_ms) REDDE VERUM
  EVOCA REX elapsed AD 0
  DUM elapsed < timeout_ms
    SI CONIURA exists(path)
      REDDE VERUM
    FIN SI
    CONIURA sleep_ms(20)
    VINCIRE elapsed AD elapsed + 20
  FIN DUM
  REDDE CONIURA exists(path)
EXPLICIT RITUALE

RITUALE main() REDDE REX
  EVOCA VERBUM ready AD "tests/.tmp/http_client_post_local_20c3.ready"
  EVOCA VERBUM done AD "tests/.tmp/http_client_post_local_20c3.done"
  EVOCA VERBUM log AD "tests/.tmp/http_client_post_local_20c3.server.log"

  CONIURA cleanup_file(ready)
  CONIURA cleanup_file(done)
  CONIURA cleanup_file(log)

  SI CONIURA run("tests/integration/http_client_post_local_20c3_server >tests/.tmp/http_client_post_local_20c3.server.log 2>&1 &") != 0
    REDDE 1
  FIN SI

  SI NON CONIURA wait_for_file(ready, 2000)
    REDDE 2
  FIN SI

  SI CONIURA compare(CONIURA read_all(ready), "skip") == 0
    REDDE 0
  FIN SI
  CONIURA sleep_ms(50)

  EVOCA HttpRequest req AD CONIURA http_request_with_body("POST", "http://127.0.0.1:22332/submit", "corpo-post")
  CONIURA http_headers_set_or_push(CONIURA http_request_headers_handle(req), "X-Trace", "abc123")

  EVOCA HttpResponse res AD CONIURA http_request(req)
  SI CONIURA http_response_status(res) != 201
    REDDE 3
  FIN SI
  SI CONIURA compare(CONIURA http_response_body(res), "gravado") != 0
    REDDE 4
  FIN SI
  SI CONIURA compare(CONIURA http_response_header(res, "X-Reply", ""), "post-ok") != 0
    REDDE 5
  FIN SI

  SI NON CONIURA wait_for_file(done, 2000)
    REDDE 6
  FIN SI
  SI CONIURA compare(CONIURA read_all(done), "ok") != 0
    REDDE 7
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
