INCIPIT grimoire "parse_vincire_simple_22c"
ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/parser/parse_stmt.cct"
RITUALE main() REDDE REX
  EVOCA SPECULUM AstNode stmt AD CONIURA parser_parse_statement_source("VINCIRE x AD 7", "stmt.cct")
  SI (*stmt).kind != AST_VINCIRE
    REDDE 41
  FIN SI
  SI CONIURA compare((*(*stmt).left).name, "x") != 0 VEL CONIURA compare((*(*stmt).right).value_text, "7") != 0
    REDDE 42
  FIN SI
  CONIURA ast_node_free(stmt)
  REDDE 0
EXPLICIT RITUALE
EXPLICIT grimoire
