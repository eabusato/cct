INCIPIT grimoire "parser_dump_sigillum_22e"
ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/parser.cct"
RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"probe\"\nSIGILLUM Pair\n  left: REX\n  right: SPECULUM REX\nFIN SIGILLUM\nEXPLICIT grimoire\n"
  EVOCA VERBUM expected AD "PROGRAM: probe\nDeclarations: (1)\n  SIGILLUM (line 2, col 1)\n    Name: Pair\n    Fields: (2)\n      - left: REX\n      - right: SPECULUM REX\n"
  SI CONIURA compare(CONIURA parser_dump_program_source(src, "m.cct"), expected) != 0
    REDDE 41
  FIN SI
  REDDE 0
EXPLICIT RITUALE
EXPLICIT grimoire
