INCIPIT grimoire "semantic_stmt_elige_basic_24e"

ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_context.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_kind.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_stmt.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM SemanticContext ctx AD CONIURA semantic_context_new("elige_basic.cct")
  CONIURA semantic_define(ctx, SEM_SYMBOL_VARIABLE, "x", (*ctx).type_rex, 1, 1)

  EVOCA SPECULUM AstNode elige_stmt AD CONIURA ast_make_quando(CONIURA ast_make_identifier("x", 1, 8), 1, 1)
  EVOCA SPECULUM AstNode case_node AD CONIURA ast_make_case(1, 10)
  CONIURA ast_append_child(case_node, CONIURA ast_make_literal_int("1", 1, 15))
  VINCIRE (*case_node).body AD CONIURA ast_make_block(1, 18)
  VINCIRE (*case_node).has_body AD VERUM
  CONIURA ast_append_case(elige_stmt, case_node)
  VINCIRE (*elige_stmt).else_branch AD CONIURA ast_make_block(1, 20)
  VINCIRE (*elige_stmt).has_else_branch AD VERUM

  CONIURA semantic_analyze_stmt(ctx, elige_stmt)
  SI CONIURA semantic_had_error(ctx)
    REDDE 41
  FIN SI

  CONIURA semantic_context_free(ctx)
  CONIURA ast_node_free(elige_stmt)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
