INCIPIT grimoire "codegen_expr_literal_bool_26b"

ADVOCARE "../../src/bootstrap/codegen/codegen_context.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen_expr.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen_emitter.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM CodegenContext ctx AD CONIURA codegen_context_new("bool.cct")
  EVOCA SPECULUM AstNode yes AD CONIURA ast_make_literal_bool(VERUM, 1, 1)
  EVOCA SPECULUM AstNode no AD CONIURA ast_make_literal_bool(FALSUM, 1, 2)
  CONIURA codegen_emit_expr(ctx, yes)
  CONIURA codegen_emit(ctx, ",")
  CONIURA codegen_emit_expr(ctx, no)
  EVOCA VERBUM out AD CONIURA codegen_output(ctx)
  EVOCA REX rc AD 0
  SI CONIURA compare(out, "1,0") != 0
    VINCIRE rc AD 1
  FIN SI
  DIMITTE out
  CONIURA ast_node_free(yes)
  CONIURA ast_node_free(no)
  CONIURA codegen_context_free(ctx)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
