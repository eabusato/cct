INCIPIT grimoire "quando_ordo_exaustivo_19a3"

ORDO Cor
  Vermelho = 0
  Verde = 1
  Azul = 2
FIN ORDO

RITUALE main() REDDE REX
  EVOCA Cor c
  VINCIRE c AD Verde

  QUANDO c
    CASO Vermelho:
      REDDE 1
    CASO Verde:
      REDDE 2
    CASO Azul:
      REDDE 3
  FIN QUANDO

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
