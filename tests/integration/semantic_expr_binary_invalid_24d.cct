INCIPIT grimoire "semantic_expr_binary_invalid_24d"

ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/lexer/token_type.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_context.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_expr.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM SemanticContext ctx AD CONIURA semantic_context_new("binary_invalid.cct")
  EVOCA SPECULUM AstNode left AD CONIURA ast_make_literal_bool(VERUM, 1, 1)
  EVOCA SPECULUM AstNode right AD CONIURA ast_make_literal_int("1", 1, 8)
  EVOCA SPECULUM AstNode expr AD CONIURA ast_make_binary(TK_PLUS, left, right, 1, 5)
  EVOCA REX type_id AD CONIURA semantic_analyze_expr(ctx, expr)

  SI type_id != (*ctx).type_error
    REDDE 41
  FIN SI
  SI NON CONIURA semantic_had_error(ctx)
    REDDE 42
  FIN SI
  SI CONIURA compare((*ctx).last_error_message, "binary operator requires numeric operands") != 0
    REDDE 43
  FIN SI

  CONIURA semantic_context_free(ctx)
  CONIURA ast_node_free(expr)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
