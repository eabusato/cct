INCIPIT grimoire "log_rate_limit_34a"

ADVOCARE "cct/fs.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/log.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM path AD "tests/.tmp/log_rate_limit_34a.log"
  SI CONIURA exists(path)
    CONIURA delete_file(path)
  FIN SI

  EVOCA Logger logger AD CONIURA log_new("worker", INFO)
  EVOCA SPECULUM NIHIL res AD CONIURA log_set_sink_file(SPECULUM logger, path)
  SI CONIURA result_is_err GENUS(REX, LogError)(res)
    REDDE 1
  FIN SI

  CONIURA log_set_rate_limit(SPECULUM logger, 1, 1)
  CONIURA log_info(SPECULUM logger, "a", "{}")
  CONIURA log_info(SPECULUM logger, "b", "{}")
  CONIURA log_info(SPECULUM logger, "c", "{}")

  EVOCA VERBUM txt AD CONIURA read_all(path)
  SI NON CONIURA contains(txt, "a")
    REDDE 2
  FIN SI
  SI NON CONIURA contains(txt, "b")
    REDDE 3
  FIN SI
  SI CONIURA contains(txt, "c")
    REDDE 4
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
