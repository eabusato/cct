INCIPIT grimoire "semantic_pactum_duplicate_signature_24f"

ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/parser.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_context.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_decl.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"p\" PACTUM Forma RITUALE render(REX value) REDDE REX RITUALE render(REX value) REDDE REX FIN PACTUM EXPLICIT grimoire"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(src, "pactum_duplicate.cct")
  EVOCA SPECULUM SemanticContext ctx AD CONIURA semantic_context_new("pactum_duplicate.cct")
  CONIURA semantic_validate_program(ctx, program)

  SI NON CONIURA semantic_had_error(ctx)
    REDDE 41
  FIN SI
  SI CONIURA compare((*ctx).last_error_message, "duplicate PACTUM signature 'render' in contract 'Forma'") != 0
    REDDE 42
  FIN SI

  CONIURA semantic_context_free(ctx)
  CONIURA ast_program_free(program)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
