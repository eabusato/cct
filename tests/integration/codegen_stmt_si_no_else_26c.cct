INCIPIT grimoire "codegen_stmt_si_no_else_26c"

ADVOCARE "../../src/bootstrap/codegen/codegen_context.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen_stmt.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM AstNode cond AD CONIURA ast_make_identifier("ok", 1, 1)
  EVOCA SPECULUM AstNode body AD CONIURA ast_make_block(1, 4)
  CONIURA ast_append_statement(body, CONIURA ast_make_expr_stmt(CONIURA ast_make_literal_int("1", 1, 6), 1, 6))
  EVOCA SPECULUM AstNode stmt AD CONIURA ast_make_si_no_else(cond, body, 1, 1)
  EVOCA SPECULUM CodegenContext ctx AD CONIURA codegen_context_new("if.cct")
  CONIURA codegen_emit_stmt(ctx, stmt)
  EVOCA VERBUM out AD CONIURA codegen_output(ctx)
  EVOCA VERBUM expected AD "if (ok)\n{\n  1;\n}\n"
  EVOCA REX rc AD 0
  SI CONIURA compare(out, expected) != 0
    VINCIRE rc AD 1
  FIN SI
  DIMITTE out
  CONIURA ast_node_free(stmt)
  CONIURA codegen_context_free(ctx)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
