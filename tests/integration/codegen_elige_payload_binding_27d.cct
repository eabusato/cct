INCIPIT grimoire "codegen_elige_payload_binding_27d"

ADVOCARE "../../src/bootstrap/parser/parser.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen_decl.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM source AD "INCIPIT grimoire \"g\"\nORDO Option\n  None\n  Some(value: REX)\nFIN ORDO\nRITUALE main() REDDE REX\n  EVOCA Option o AD Some(7)\n  ELIGE o\n  CASUS Some(value):\n    REDDE value\n  ALIOQUIN:\n    REDDE 0\n  FIN ELIGE\nEXPLICIT RITUALE\nEXPLICIT grimoire\n"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(source, "elige_payload_bind.cct")
  EVOCA VERBUM out AD CONIURA codegen_generate_program(program, "elige_payload_bind.cct")
  EVOCA REX rc AD 0
  SI NON CONIURA contains(out, "switch (__cct_tmp_")
    VINCIRE rc AD 1
  FIN SI
  SI NON CONIURA contains(out, ".__tag)")
    VINCIRE rc AD 2
  FIN SI
  SI NON CONIURA contains(out, "long long value = __cct_tmp_")
    VINCIRE rc AD 3
  FIN SI
  SI NON CONIURA contains(out, ".__payload.Some.value;")
    VINCIRE rc AD 4
  FIN SI
  DIMITTE out
  CONIURA ast_program_free(program)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
