INCIPIT grimoire "codegen_rituale_registry_26a"

ADVOCARE "../../src/bootstrap/codegen/codegen.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen_context.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM CodegenContext ctx AD CONIURA codegen_context_new("rituale.cct")
  EVOCA VERBUM a0 AD CONIURA codegen_rituale_c_name(ctx, "main")
  EVOCA VERBUM a1 AD CONIURA codegen_rituale_c_name(ctx, "main")
  EVOCA VERBUM b0 AD CONIURA codegen_rituale_c_name(ctx, "helper")
  EVOCA REX rc AD 0

  SI CONIURA compare(a0, "cct_boot_rit_main_0") != 0
    VINCIRE rc AD 1
  FIN SI
  SI CONIURA compare(a1, a0) != 0
    VINCIRE rc AD 2
  FIN SI
  SI CONIURA compare(b0, "cct_boot_rit_helper_1") != 0
    VINCIRE rc AD 3
  FIN SI
  SI CONIURA codegen_registered_rituale_count(ctx) != 2
    VINCIRE rc AD 4
  FIN SI

  CONIURA codegen_context_free(ctx)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
