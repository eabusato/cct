INCIPIT grimoire "json_stringify_basic_20a3"

ADVOCARE "cct/json.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA Json root AD CONIURA json_obj()
  EVOCA Json nums AD CONIURA json_arr()

  CONIURA json_arr_push(nums, CONIURA json_num(1))
  CONIURA json_arr_push(nums, CONIURA json_bool(FALSUM))
  CONIURA json_arr_push(nums, CONIURA json_str("x/y"))

  CONIURA json_obj_push(root, "nome", CONIURA json_str("cct"))
  CONIURA json_obj_push(root, "ok", CONIURA json_bool(VERUM))
  CONIURA json_obj_push(root, "nums", nums)

  EVOCA VERBUM out AD CONIURA json_stringify(root)
  SI CONIURA compare(out, "{\"nome\":\"cct\",\"ok\":true,\"nums\":[1,false,\"x/y\"]}") != 0
    REDDE 1
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
