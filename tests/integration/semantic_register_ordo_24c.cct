INCIPIT grimoire "semantic_register_ordo_24c"

ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/parser.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_context.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_register.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_symbol.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_type.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_type_kind.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"p\" ORDO Cor RUBER, VIRIDIS FIN ORDO EXPLICIT grimoire"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(src, "ordo.cct")
  EVOCA SPECULUM SemanticContext ctx AD CONIURA semantic_context_new("ordo.cct")
  CONIURA semantic_register_program(ctx, program)

  EVOCA REX sym_id AD CONIURA semantic_lookup_global(ctx, "Cor")
  SI sym_id == CONIURA semantic_invalid_id()
    REDDE 41
  FIN SI
  EVOCA SPECULUM SemanticSymbol sym AD CONIURA semantic_symbol_at(ctx, sym_id)
  EVOCA SPECULUM SemanticType type_ref AD CONIURA semantic_type_at(ctx, (*sym).type_id)
  SI (*sym).kind != SEM_SYMBOL_TYPE
    REDDE 42
  FIN SI
  SI (*type_ref).kind != SEM_TYPE_NAMED
    REDDE 43
  FIN SI
  SI CONIURA compare((*type_ref).name, "Cor") != 0
    REDDE 44
  FIN SI

  CONIURA semantic_context_free(ctx)
  CONIURA ast_program_free(program)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
