INCIPIT grimoire "cmp_verbum_basic_11f2"

ADVOCARE "cct/cmp.cct"

RITUALE main() REDDE REX
  SI CONIURA cmp_verbum("a", "b") < 0
    SI CONIURA cmp_verbum("x", "x") == 0
      SI CONIURA cmp_verbum("z", "x") > 0
        REDDE 0
      FIN SI
    FIN SI
  FIN SI
  REDDE 1
EXPLICIT RITUALE

EXPLICIT grimoire
