INCIPIT grimoire "code_writer_append_bool_17b3"

ADVOCARE "cct/code_writer.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL w AD CONIURA writer_init()
  CONIURA writer_write(w, "ok=")
  CONIURA writer_write_bool(w, VERUM)
  CONIURA writer_writeln(w, "")
  CONIURA writer_write(w, "fail=")
  CONIURA writer_write_bool(w, FALSUM)
  CONIURA writer_writeln(w, "")

  EVOCA VERBUM out AD CONIURA writer_to_verbum(w)
  SI CONIURA compare(out, "ok=true\nfail=false\n") == 0
    CONIURA writer_free(w)
    REDDE 0
  FIN SI

  CONIURA writer_free(w)
  REDDE 1
EXPLICIT RITUALE

EXPLICIT grimoire
