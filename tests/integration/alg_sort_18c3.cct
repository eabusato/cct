INCIPIT grimoire "alg_sort_18c3"

ADVOCARE "cct/alg.cct"
ADVOCARE "cct/verbum.cct"
ADVOCARE "cct/fluxus.cct"

RITUALE main() REDDE REX
  EVOCA SERIES REX[5] a
  VINCIRE a[0] AD 5
  VINCIRE a[1] AD 1
  VINCIRE a[2] AD 4
  VINCIRE a[3] AD 2
  VINCIRE a[4] AD 3

  CONIURA alg_quicksort(SPECULUM a[0], 5)
  SI NON CONIURA alg_is_sorted(SPECULUM a[0], 5)
    REDDE 1
  FIN SI
  SI a[0] != 1
    REDDE 2
  FIN SI
  SI a[4] != 5
    REDDE 3
  FIN SI

  EVOCA SERIES REX[5] b
  VINCIRE b[0] AD 3
  VINCIRE b[1] AD 1
  VINCIRE b[2] AD 2
  VINCIRE b[3] AD 1
  VINCIRE b[4] AD 3

  CONIURA alg_mergesort(SPECULUM b[0], 5)
  SI NON CONIURA alg_is_sorted(SPECULUM b[0], 5)
    REDDE 4
  FIN SI
  SI b[0] != 1
    REDDE 5
  FIN SI
  SI b[1] != 1
    REDDE 6
  FIN SI
  SI b[2] != 2
    REDDE 7
  FIN SI
  SI b[3] != 3
    REDDE 8
  FIN SI
  SI b[4] != 3
    REDDE 9
  FIN SI

  EVOCA SPECULUM NIHIL fv AD CONIURA fluxus_init(MENSURA(VERBUM))
  EVOCA VERBUM s0 AD "beta"
  EVOCA VERBUM s1 AD "alpha"
  EVOCA VERBUM s2 AD "delta"
  CONIURA fluxus_push(fv, SPECULUM s0)
  CONIURA fluxus_push(fv, SPECULUM s1)
  CONIURA fluxus_push(fv, SPECULUM s2)

  EVOCA SPECULUM NIHIL raw AD CONIURA fluxus_to_ptr(fv)
  CONIURA alg_sort_verbum(raw, CONIURA fluxus_len(fv))

  EVOCA VERBUM o0 AD ""
  EVOCA VERBUM o1 AD ""
  EVOCA VERBUM o2 AD ""
  CONIURA fluxus_pop(fv, SPECULUM o2)
  CONIURA fluxus_pop(fv, SPECULUM o1)
  CONIURA fluxus_pop(fv, SPECULUM o0)

  SI CONIURA compare(o0, "alpha") != 0
    CONIURA fluxus_free(fv)
    REDDE 10
  FIN SI
  SI CONIURA compare(o1, "beta") != 0
    CONIURA fluxus_free(fv)
    REDDE 11
  FIN SI
  SI CONIURA compare(o2, "delta") != 0
    CONIURA fluxus_free(fv)
    REDDE 12
  FIN SI

  CONIURA fluxus_free(fv)

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
