INCIPIT grimoire "semantic_generic_rituale_arity_invalid_25b"

ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/parser.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_context.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_decl.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"p\" RITUALE identitas GENUS(T)(T valor) REDDE T REDDE valor EXPLICIT RITUALE RITUALE main() REDDE REX REDDE identitas GENUS(REX, DUX)(1) EXPLICIT RITUALE EXPLICIT grimoire"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(src, "rituale_arity_invalid.cct")
  EVOCA SPECULUM SemanticContext ctx AD CONIURA semantic_context_new("rituale_arity_invalid.cct")
  CONIURA semantic_validate_program(ctx, program)
  SI (*ctx).had_error != VERUM
    REDDE 41
  FIN SI
  SI CONIURA compare((*ctx).last_error_message, "generic rituale arity mismatch") != 0
    REDDE 42
  FIN SI
  CONIURA semantic_context_free(ctx)
  CONIURA ast_program_free(program)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
