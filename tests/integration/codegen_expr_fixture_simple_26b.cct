INCIPIT grimoire "codegen_expr_fixture_simple_26b"

ADVOCARE "../../src/bootstrap/codegen/codegen_context.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen_expr.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/lexer/token_type.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM AstNode callee AD CONIURA ast_make_identifier("sum", 1, 1)
  EVOCA SPECULUM AstNode call AD CONIURA ast_make_call(callee, 1, 1)
  CONIURA ast_append_argument(call, CONIURA ast_make_identifier("x", 1, 5))
  CONIURA ast_append_argument(call, CONIURA ast_make_literal_int("2", 1, 8))
  EVOCA SPECULUM AstNode expr AD CONIURA ast_make_binary(TK_STAR, call, CONIURA ast_make_unary(TK_MINUS, CONIURA ast_make_literal_int("3", 1, 13), 1, 12), 1, 10)

  EVOCA SPECULUM CodegenContext ctx AD CONIURA codegen_context_new("fixture.cct")
  CONIURA codegen_emit_expr(ctx, expr)
  EVOCA VERBUM out AD CONIURA codegen_output(ctx)
  EVOCA VERBUM expected AD "(cct_boot_rit_sum_0(x, 2) * (-3))"
  EVOCA REX rc AD 0
  SI CONIURA compare(out, expected) != 0
    VINCIRE rc AD 1
  FIN SI
  DIMITTE out
  CONIURA ast_node_free(expr)
  CONIURA codegen_context_free(ctx)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
