INCIPIT grimoire "verbum_builder_append_int_17b3"

ADVOCARE "cct/verbum_builder.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL b AD CONIURA builder_init()
  CONIURA builder_append(b, "value=")
  CONIURA builder_append_int(b, 42)
  CONIURA builder_append(b, ",neg=")
  CONIURA builder_append_int(b, -7)

  EVOCA VERBUM out AD CONIURA builder_to_verbum(b)
  SI CONIURA compare(out, "value=42,neg=-7") == 0
    CONIURA builder_free(b)
    REDDE 0
  FIN SI

  CONIURA builder_free(b)
  REDDE 1
EXPLICIT RITUALE

EXPLICIT grimoire
