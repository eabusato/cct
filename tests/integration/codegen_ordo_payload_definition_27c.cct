INCIPIT grimoire "codegen_ordo_payload_definition_27c"

ADVOCARE "../../src/bootstrap/codegen/codegen_decl.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM AstProgram program AD CONIURA ast_program_new()
  EVOCA SPECULUM AstNode ord AD CONIURA ast_make_ordo("Option", 1, 1)
  EVOCA SPECULUM AstNode none_item AD CONIURA ast_make_enum_item_no_value("None", 1, 1)
  EVOCA SPECULUM AstNode some_item AD CONIURA ast_make_enum_item_no_value("Some", 2, 1)
  CONIURA ast_append_field(some_item, CONIURA ast_make_field("value", CONIURA ast_make_type("REX", 2, 1), 2, 1))
  CONIURA ast_append_item(ord, none_item)
  CONIURA ast_append_item(ord, some_item)
  CONIURA ast_program_append_decl(program, ord)
  CONIURA ast_program_append_decl(program, CONIURA ast_make_rituale("main", CONIURA ast_make_type("REX", 3, 1), CONIURA ast_make_block(3, 1), 3, 1))
  EVOCA VERBUM out AD CONIURA codegen_generate_program(program, "ordo_payload_def.cct")
  EVOCA REX rc AD 0
  SI NON CONIURA contains(out, "int __tag;")
    VINCIRE rc AD 1
  FIN SI
  SI NON CONIURA contains(out, "union")
    VINCIRE rc AD 2
  FIN SI
  SI NON CONIURA contains(out, "} Some;")
    VINCIRE rc AD 3
  FIN SI
  DIMITTE out
  CONIURA ast_program_free(program)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
