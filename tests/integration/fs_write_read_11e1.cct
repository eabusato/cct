INCIPIT grimoire "fs_write_read_11e1"

ADVOCARE "cct/fs.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM caminho AD "tests/fixtures/io_fs/output_test.txt"
  EVOCA VERBUM conteudo AD "Conteudo de teste\n"

  CONIURA write_all(caminho, conteudo)
  EVOCA VERBUM lido AD CONIURA read_all(caminho)

  SI CONIURA compare(lido, conteudo) == 0
    REDDE 0
  FIN SI
  REDDE 1
EXPLICIT RITUALE

EXPLICIT grimoire
