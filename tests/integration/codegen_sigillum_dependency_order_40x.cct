INCIPIT grimoire "codegen_sigillum_dependency_order_40x"

ADVOCARE "cct/verbum.cct"

SIGILLUM Outer
  inner: Inner
  label: VERBUM
FIN SIGILLUM

SIGILLUM Inner
  total: REX
FIN SIGILLUM

RITUALE make_outer() REDDE Outer
  EVOCA Inner inner
  VINCIRE inner.total AD 9
  EVOCA Outer out
  VINCIRE out.inner AD inner
  VINCIRE out.label AD "ok"
  REDDE out
EXPLICIT RITUALE

RITUALE main() REDDE REX
  EVOCA Outer out AD CONIURA make_outer()
  SI out.inner.total != 9
    REDDE 1
  FIN SI
  SI CONIURA compare(out.label, "ok") != 0
    REDDE 2
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
