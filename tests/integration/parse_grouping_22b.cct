INCIPIT grimoire "parse_grouping_22b"

ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/lexer/token_type.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/parser/parse_expr.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM AstNode expr AD CONIURA parser_parse_expression_source("(1 + 2) * 3", "expr.cct")

  SI (*expr).kind != AST_BINARY_OP VEL (*expr).operator_kind != TK_STAR
    REDDE 41
  FIN SI
  SI (*(*expr).left).kind != AST_BINARY_OP VEL (*(*expr).left).operator_kind != TK_PLUS
    REDDE 42
  FIN SI
  SI CONIURA compare((*(*(*expr).left).left).value_text, "1") != 0 VEL CONIURA compare((*(*(*expr).left).right).value_text, "2") != 0
    REDDE 43
  FIN SI

  CONIURA ast_node_free(expr)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
