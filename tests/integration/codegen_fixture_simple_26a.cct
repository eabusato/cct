INCIPIT grimoire "codegen_fixture_simple_26a"

ADVOCARE "../../src/bootstrap/codegen/codegen.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen_context.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen_emitter.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM CodegenContext ctx AD CONIURA codegen_context_new("fixture.cct")
  EVOCA VERBUM cname AD CONIURA codegen_rituale_c_name(ctx, "main")

  CONIURA codegen_emit_line(ctx, "#include <stdio.h>")
  CONIURA codegen_emit_blank_line(ctx)
  CONIURA codegen_emit(ctx, "int ")
  CONIURA codegen_emit_line(ctx, CONIURA concat(cname, "(void)"))
  CONIURA codegen_emit_block_open(ctx)
  CONIURA codegen_emit_line(ctx, "return 0;")
  CONIURA codegen_emit_block_close(ctx)

  EVOCA VERBUM out AD CONIURA codegen_output(ctx)
  EVOCA VERBUM expected AD "#include <stdio.h>\n\nint cct_boot_rit_main_0(void)\n{\n  return 0;\n}\n"
  EVOCA REX rc AD 0
  SI CONIURA compare(out, expected) != 0
    VINCIRE rc AD 1
  FIN SI

  DIMITTE out
  CONIURA codegen_context_free(ctx)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
