INCIPIT grimoire "diagnostic_warn_21a3"

ADVOCARE "cct/diagnostic.cct"

RITUALE main() REDDE REX
  EVOCA SourceLocation loc
  VINCIRE loc.filename AD "example.cct"
  VINCIRE loc.line AD 15
  VINCIRE loc.column AD 5

  CONIURA diag_warn(SPECULUM loc, "Unused variable")
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
