INCIPIT grimoire "codegen_sigillum_definition_27a"

ADVOCARE "../../src/bootstrap/codegen/codegen_decl.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM AstProgram program AD CONIURA ast_program_new()
  EVOCA SPECULUM AstNode sig AD CONIURA ast_make_sigillum("Point", 1, 1)
  CONIURA ast_append_field(sig, CONIURA ast_make_field("x", CONIURA ast_make_type("REX", 1, 1), 1, 1))
  CONIURA ast_append_field(sig, CONIURA ast_make_field("y", CONIURA ast_make_type("REX", 1, 1), 1, 1))
  CONIURA ast_program_append_decl(program, sig)

  EVOCA SPECULUM AstNode body AD CONIURA ast_make_block(2, 1)
  CONIURA ast_append_statement(body, CONIURA ast_make_redde(CONIURA ast_make_literal_int("0", 2, 1), 2, 1))
  CONIURA ast_program_append_decl(program, CONIURA ast_make_rituale("main", CONIURA ast_make_type("REX", 2, 1), body, 2, 1))

  EVOCA VERBUM out AD CONIURA codegen_generate_program(program, "sigdef.cct")
  EVOCA VERBUM expected AD "/* generated by cct bootstrap codegen */\n\ntypedef struct cct_boot_sig_Point cct_boot_sig_Point;\n\nstruct cct_boot_sig_Point\n{\n  long long x;\n  long long y;\n};\n\nlong long cct_boot_rit_main_0(void);\n\nlong long cct_boot_rit_main_0(void)\n{\n  return 0;\n}\n"
  EVOCA REX rc AD 0
  SI CONIURA compare(out, expected) != 0
    VINCIRE rc AD 1
  FIN SI

  DIMITTE out
  CONIURA ast_program_free(program)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
