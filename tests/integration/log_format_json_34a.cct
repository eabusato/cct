INCIPIT grimoire "log_format_json_34a"

ADVOCARE "cct/log.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM line AD CONIURA log_format_json_line(
    "2026-03-25T12:00:00+0000",
    ERROR,
    "db",
    "query failed",
    "{\"sql\":\"select 1\"}"
  )

  SI NON CONIURA contains(line, "\"timestamp\":\"2026-03-25T12:00:00+0000\"")
    REDDE 1
  FIN SI
  SI NON CONIURA contains(line, "\"level\":\"ERROR\"")
    REDDE 2
  FIN SI
  SI NON CONIURA contains(line, "\"module\":\"db\"")
    REDDE 3
  FIN SI
  SI NON CONIURA contains(line, "\"message\":\"query failed\"")
    REDDE 4
  FIN SI
  SI NON CONIURA contains(line, "\"fields\":{\"sql\":\"select 1\"}")
    REDDE 5
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
