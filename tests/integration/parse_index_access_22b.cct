INCIPIT grimoire "parse_index_access_22b"

ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/parser/parse_expr.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM AstNode expr AD CONIURA parser_parse_expression_source("arr[1][2]", "expr.cct")

  SI (*expr).kind != AST_INDEX_ACCESS
    REDDE 41
  FIN SI
  SI CONIURA compare((*(*expr).right).value_text, "2") != 0
    REDDE 42
  FIN SI
  SI (*(*expr).left).kind != AST_INDEX_ACCESS
    REDDE 43
  FIN SI
  SI CONIURA compare((*(*(*expr).left).right).value_text, "1") != 0
    REDDE 44
  FIN SI

  CONIURA ast_node_free(expr)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
