INCIPIT grimoire "semantic_unknown_type_24c"

ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_context.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_resolver.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM SemanticContext ctx AD CONIURA semantic_context_new("unknown_type.cct")
  EVOCA SPECULUM AstNode type_node AD CONIURA ast_make_type("Ghost", 7, 9)
  SI CONIURA semantic_resolve_type_node(ctx, type_node) != (*ctx).type_error
    REDDE 41
  FIN SI
  SI (*ctx).had_error != VERUM
    REDDE 42
  FIN SI
  SI (*ctx).last_error_line != 7 VEL (*ctx).last_error_column != 9
    REDDE 43
  FIN SI
  SI CONIURA compare((*ctx).last_error_message, "unknown type 'Ghost'") != 0
    REDDE 44
  FIN SI

  CONIURA ast_node_free(type_node)
  CONIURA semantic_context_free(ctx)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
