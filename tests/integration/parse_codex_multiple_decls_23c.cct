INCIPIT grimoire "parse_codex_multiple_decls_23c"
ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/parser/parser.cct"
RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"p\" CODEX Math SIGILLUM Box value: REX FIN SIGILLUM RITUALE sum(REX a, REX b) REDDE REX REDDE a EXPLICIT RITUALE FIN CODEX EXPLICIT grimoire"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(src, "m.cct")
  EVOCA SPECULUM AstNode codex AD CONIURA ast_node_list_get((*program).declarations, 0)
  SI CONIURA ast_node_list_len((*codex).declarations) != 2
    REDDE 41
  FIN SI
  EVOCA SPECULUM AstNode first AD CONIURA ast_node_list_get((*codex).declarations, 0)
  EVOCA SPECULUM AstNode second AD CONIURA ast_node_list_get((*codex).declarations, 1)
  SI (*first).kind != AST_SIGILLUM VEL (*second).kind != AST_RITUALE
    REDDE 42
  FIN SI
  CONIURA ast_program_free(program)
  REDDE 0
EXPLICIT RITUALE
EXPLICIT grimoire
