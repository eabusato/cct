INCIPIT grimoire "db_stmt_select_single_40x"

ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL db AD CONIURA db_open(":memory:")
  CONIURA db_exec(db, "CREATE TABLE items(id INTEGER, nome TEXT, preco REAL);")
  CONIURA db_exec(db, "INSERT INTO items(id, nome, preco) VALUES(1, 'alpha', 1.5);")
  CONIURA db_exec(db, "INSERT INTO items(id, nome, preco) VALUES(2, 'beta', 2.25);")

  EVOCA SPECULUM NIHIL stmt AD CONIURA db_prepare(db, "SELECT id, nome, preco FROM items WHERE id = ?1;")
  CONIURA stmt_bind_int(stmt, 1, 2)
  SI NON CONIURA stmt_step(stmt)
    REDDE 1
  FIN SI
  SI NON CONIURA stmt_has_row(stmt)
    REDDE 2
  FIN SI
  SI CONIURA stmt_get_int(stmt, 0) != 2
    REDDE 3
  FIN SI
  SI CONIURA compare(CONIURA stmt_get_text(stmt, 1), "beta") != 0
    REDDE 4
  FIN SI
  SI CONIURA stmt_get_real(stmt, 2) != 2.25
    REDDE 5
  FIN SI
  SI NON CONIURA stmt_step(stmt)
    REDDE 6
  FIN SI
  SI CONIURA stmt_has_row(stmt)
    REDDE 7
  FIN SI

  CONIURA stmt_finalize(stmt)
  CONIURA db_close(db)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
