INCIPIT grimoire "db_stmt_select_reuse_40x"

ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL db AD CONIURA db_open(":memory:")
  CONIURA db_exec(db, "CREATE TABLE items(id INTEGER, nome TEXT);")
  CONIURA db_exec(db, "INSERT INTO items(id, nome) VALUES(1, 'alpha');")
  CONIURA db_exec(db, "INSERT INTO items(id, nome) VALUES(2, 'beta');")

  EVOCA SPECULUM NIHIL stmt AD CONIURA db_prepare(db, "SELECT id FROM items WHERE nome = ?1;")
  CONIURA stmt_bind_text(stmt, 1, "alpha")
  SI NON CONIURA stmt_step(stmt)
    REDDE 1
  FIN SI
  SI NON CONIURA stmt_has_row(stmt) VEL CONIURA stmt_get_int(stmt, 0) != 1
    REDDE 2
  FIN SI

  CONIURA stmt_reset(stmt)
  CONIURA stmt_bind_text(stmt, 1, "beta")
  SI NON CONIURA stmt_step(stmt)
    REDDE 3
  FIN SI
  SI NON CONIURA stmt_has_row(stmt) VEL CONIURA stmt_get_int(stmt, 0) != 2
    REDDE 4
  FIN SI

  CONIURA stmt_finalize(stmt)
  CONIURA db_close(db)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
