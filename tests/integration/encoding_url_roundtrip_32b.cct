INCIPIT grimoire "encoding_url_roundtrip_32b"

ADVOCARE "cct/encoding.cct"
ADVOCARE "cct/option.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM original AD "hello world & friends/?"
  EVOCA VERBUM encoded AD CONIURA url_encode(original)
  EVOCA SPECULUM NIHIL decoded_opt AD CONIURA url_decode(encoded)
  SI CONIURA compare(encoded, "hello%20world%20%26%20friends%2F%3F") != 0
    REDDE 1
  FIN SI
  SI NON CONIURA option_is_some GENUS(VERBUM)(decoded_opt)
    REDDE 1
  FIN SI
  SI CONIURA compare(CONIURA option_unwrap GENUS(VERBUM)(decoded_opt), original) != 0
    REDDE 1
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
