INCIPIT grimoire "semantic_generic_field_substitution_25b"

ADVOCARE "../../src/bootstrap/parser/parser.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_context.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_decl.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"p\" SIGILLUM Caixa GENUS(T) valor: T FIN SIGILLUM RITUALE valor(Caixa GENUS(REX) c) REDDE REX REDDE c.valor EXPLICIT RITUALE EXPLICIT grimoire"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(src, "field_substitution.cct")
  EVOCA SPECULUM SemanticContext ctx AD CONIURA semantic_context_new("field_substitution.cct")
  CONIURA semantic_validate_program(ctx, program)
  SI (*ctx).had_error != FALSUM
    REDDE 41
  FIN SI
  CONIURA semantic_context_free(ctx)
  CONIURA ast_program_free(program)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
