INCIPIT grimoire "parser_negative_fixture_22e"
ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/parser.cct"
RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"negfixture\"\nEVOCA REX x AD 1\nRITUALE ok(REX a) REDDE REX\n  REDDE a\nEXPLICIT RITUALE\nSIGILLUM Pair\n  left: REX\nFIN SIGILLUM\nEXPLICIT grimoire\n"
  EVOCA VERBUM dump AD CONIURA parser_dump_program_source(src, "negfixture.cct")
  SI NON CONIURA contains(dump, "PROGRAM: negfixture")
    REDDE 41
  FIN SI
  SI NON CONIURA contains(dump, "RITUALE (line 3, col 1)")
    REDDE 42
  FIN SI
  SI NON CONIURA contains(dump, "Name: ok")
    REDDE 43
  FIN SI
  SI NON CONIURA contains(dump, "SIGILLUM (line 6, col 1)")
    REDDE 44
  FIN SI
  REDDE 0
EXPLICIT RITUALE
EXPLICIT grimoire
