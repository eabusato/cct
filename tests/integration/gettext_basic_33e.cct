INCIPIT grimoire "gettext_basic_33e"

ADVOCARE "cct/gettext.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA Catalog cat AD CONIURA gettext_catalog_new("pt_BR")
  CONIURA gettext_add_message(SPECULUM cat, "welcome", "bem-vindo")
  CONIURA gettext_add_message(SPECULUM cat, "logout", "sair")

  SI CONIURA compare(CONIURA gettext_translate(cat, "welcome"), "bem-vindo") != 0
    REDDE 1
  FIN SI
  SI CONIURA compare(CONIURA gettext_translate(cat, "logout"), "sair") != 0
    REDDE 1
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
