INCIPIT grimoire "codegen_ordo_type_27b"

ADVOCARE "../../src/bootstrap/codegen/codegen_context.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen_type.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM CodegenContext ctx AD CONIURA codegen_context_new("ordo_type.cct")
  CONIURA codegen_register_ordo(ctx, "Cor", "cct_boot_ord_Cor")
  EVOCA SPECULUM AstNode type_expr AD CONIURA ast_make_type("Cor", 1, 1)
  EVOCA VERBUM out AD CONIURA codegen_type_text(ctx, type_expr)
  EVOCA REX rc AD 0
  SI CONIURA compare(out, "cct_boot_ord_Cor") != 0
    VINCIRE rc AD 1
  FIN SI
  CONIURA ast_node_free(type_expr)
  CONIURA codegen_context_free(ctx)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
