INCIPIT grimoire "gettext_po_plural_default_33e"

ADVOCARE "cct/fs.cct"
ADVOCARE "cct/gettext.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM dir AD "tests/.tmp/gettext_33e"
  EVOCA VERBUM path AD "tests/.tmp/gettext_33e/plural.po"
  EVOCA VERBUM content AD "msgid \"item\"\n"
  VINCIRE content AD CONIURA concat(content, "msgid_plural \"items\"\n")
  VINCIRE content AD CONIURA concat(content, "msgstr[0] \"item\"\n")
  VINCIRE content AD CONIURA concat(content, "msgstr[1] \"itens\"\n")
  VINCIRE content AD CONIURA concat(content, "\n")
  VINCIRE content AD CONIURA concat(content, "msgid \"logout\"\n")
  VINCIRE content AD CONIURA concat(content, "msgstr \"sair\"\n")
  VINCIRE content AD CONIURA concat(content, "\n")
  CONIURA mkdir_all(dir)
  CONIURA write_all(path, content)

  EVOCA SPECULUM NIHIL loaded AD CONIURA gettext_load_catalog(path, "pt_BR")
  SI CONIURA result_is_err GENUS(Catalog, VERBUM)(loaded)
    REDDE 1
  FIN SI

  EVOCA Catalog cat AD CONIURA result_unwrap GENUS(Catalog, VERBUM)(loaded)
  CONIURA gettext_set_default_catalog(cat)

  SI CONIURA compare(CONIURA gettext_translate_plural(cat, "item", "items", 2), "itens") != 0
    REDDE 1
  FIN SI
  SI CONIURA compare(CONIURA t("logout"), "sair") != 0
    REDDE 1
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
