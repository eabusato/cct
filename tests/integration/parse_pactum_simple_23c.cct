INCIPIT grimoire "parse_pactum_simple_23c"
ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/parser/parser.cct"
RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"p\" PACTUM Forma RITUALE apply(REX value) REDDE REX FIN PACTUM EXPLICIT grimoire"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(src, "m.cct")
  EVOCA SPECULUM AstNode pact AD CONIURA ast_node_list_get((*program).declarations, 0)
  SI (*pact).kind != AST_PACTUM
    REDDE 41
  FIN SI
  SI CONIURA ast_node_list_len((*pact).signatures) != 1
    REDDE 42
  FIN SI
  EVOCA SPECULUM AstNode sig AD CONIURA ast_node_list_get((*pact).signatures, 0)
  SI CONIURA compare((*sig).name, "apply") != 0
    REDDE 43
  FIN SI
  CONIURA ast_program_free(program)
  REDDE 0
EXPLICIT RITUALE
EXPLICIT grimoire
