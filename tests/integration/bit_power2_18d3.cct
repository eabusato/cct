INCIPIT grimoire "bit_power2_18d3"

ADVOCARE "cct/bit.cct"

RITUALE main() REDDE REX
  SI NON CONIURA is_power_of_2(1)
    REDDE 1
  FIN SI

  SI NON CONIURA is_power_of_2(2)
    REDDE 2
  FIN SI

  SI CONIURA is_power_of_2(3)
    REDDE 3
  FIN SI

  SI CONIURA is_power_of_2(0)
    REDDE 4
  FIN SI

  SI CONIURA next_power_of_2(1) != 1
    REDDE 5
  FIN SI

  SI CONIURA next_power_of_2(2) != 2
    REDDE 6
  FIN SI

  SI CONIURA next_power_of_2(3) != 4
    REDDE 7
  FIN SI

  SI CONIURA next_power_of_2(17) != 32
    REDDE 8
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
