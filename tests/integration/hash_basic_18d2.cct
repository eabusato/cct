INCIPIT grimoire "hash_basic_18d2"

ADVOCARE "cct/hash.cct"

RITUALE main() REDDE REX
  SI CONIURA djb2("") != 5381
    REDDE 1
  FIN SI

  SI CONIURA djb2("abc") != 193409669
    REDDE 2
  FIN SI

  SI CONIURA fnv1a("") != -3750763034362895579
    REDDE 3
  FIN SI

  SI CONIURA fnv1a("abc") != -1792535898324117685
    REDDE 4
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
