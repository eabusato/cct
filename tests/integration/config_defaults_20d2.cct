INCIPIT grimoire "config_defaults_20d2"

ADVOCARE "cct/config.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM src AD "[db]"
  VINCIRE src AD CONIURA concat(src, "\n")
  VINCIRE src AD CONIURA concat(src, "host=localhost")

  EVOCA SPECULUM NIHIL cfg AD CONIURA config_parse_ini(src)
  SI CONIURA config_has(cfg, "db", "port")
    REDDE 1
  FIN SI
  SI CONIURA compare(CONIURA config_get_or(cfg, "db", "port", "5432"), "5432") != 0
    REDDE 2
  FIN SI
  SI CONIURA compare(CONIURA config_get_or(cfg, "db", "host", "127.0.0.1"), "localhost") != 0
    REDDE 3
  FIN SI
  SI CONIURA compare(CONIURA config_get_or(cfg, "missing", "key", "fallback"), "fallback") != 0
    REDDE 4
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
