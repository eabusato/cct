INCIPIT grimoire "mail_mime_text_only_37a"

ADVOCARE "cct/mail.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA MailMessage msg AD CONIURA mail_message_new()
  CONIURA mail_message_set_from(SPECULUM msg, CONIURA mail_address("a@b.com", "Sender"))
  CONIURA mail_message_add_to(SPECULUM msg, CONIURA mail_address("c@d.com", "Dest"))
  CONIURA mail_message_set_subject(SPECULUM msg, "Text only")
  CONIURA mail_message_set_text(SPECULUM msg, "Plain body")
  CONIURA mail_message_ensure_message_id(SPECULUM msg)

  EVOCA VERBUM mime AD CONIURA mail_message_render_mime(msg)
  SI CONIURA contains(mime, "Content-Type: text/plain; charset=UTF-8") == FALSUM
    REDDE 1
  FIN SI
  SI CONIURA contains(mime, "MIME-Version: 1.0") == FALSUM
    REDDE 2
  FIN SI
  SI CONIURA contains(mime, "Message-ID: <") == FALSUM
    REDDE 3
  FIN SI
  SI CONIURA contains(mime, "@b.com>") == FALSUM
    REDDE 6
  FIN SI
  SI CONIURA contains(mime, "Date: 20") == VERUM
    REDDE 7
  FIN SI
  SI CONIURA contains(mime, "Plain body") == FALSUM
    REDDE 4
  FIN SI
  SI CONIURA contains(mime, "multipart/alternative") == VERUM
    REDDE 5
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
