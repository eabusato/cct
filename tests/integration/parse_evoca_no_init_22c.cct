INCIPIT grimoire "parse_evoca_no_init_22c"
ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/parser/parse_stmt.cct"
RITUALE main() REDDE REX
  EVOCA SPECULUM AstNode stmt AD CONIURA parser_parse_statement_source("EVOCA REX x", "stmt.cct")
  SI (*stmt).kind != AST_EVOCA VEL CONIURA compare((*stmt).name, "x") != 0
    REDDE 41
  FIN SI
  SI (*stmt).has_type_expr != VERUM VEL (*stmt).has_right != FALSUM
    REDDE 42
  FIN SI
  SI CONIURA compare((*(*stmt).type_expr).type_name, "REX") != 0
    REDDE 43
  FIN SI
  CONIURA ast_node_free(stmt)
  REDDE 0
EXPLICIT RITUALE
EXPLICIT grimoire
