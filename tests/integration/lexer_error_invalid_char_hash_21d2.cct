INCIPIT grimoire "lexer_error_invalid_char_hash_21d2"

ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/lexer/lexer.cct"
ADVOCARE "../../src/bootstrap/lexer/lexer_state.cct"
ADVOCARE "../../src/bootstrap/lexer/token.cct"
ADVOCARE "../../src/bootstrap/lexer/token_type.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM source AD "# 42"
  EVOCA LexerState lex AD CONIURA lexer_init(source, "test.cct")

  EVOCA Token t1 AD CONIURA lexer_next_token(SPECULUM lex)
  SI t1.kind != TK_INVALID
    REDDE 41
  FIN SI
  CONIURA token_free(SPECULUM t1)

  EVOCA Token t2 AD CONIURA lexer_next_token(SPECULUM lex)
  SI t2.kind != TK_INTEGER VEL CONIURA compare(t2.lexeme, "42") != 0
    REDDE 42
  FIN SI
  CONIURA token_free(SPECULUM t2)

  EVOCA Token t3 AD CONIURA lexer_next_token(SPECULUM lex)
  SI t3.kind != TK_EOF
    REDDE 43
  FIN SI
  CONIURA token_free(SPECULUM t3)

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
