INCIPIT grimoire "codegen_sigillum_nested_forward_27a"

ADVOCARE "../../src/bootstrap/codegen/codegen_decl.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM AstProgram program AD CONIURA ast_program_new()

  EVOCA SPECULUM AstNode point AD CONIURA ast_make_sigillum("Point", 1, 1)
  CONIURA ast_append_field(point, CONIURA ast_make_field("x", CONIURA ast_make_type("REX", 1, 1), 1, 1))
  CONIURA ast_program_append_decl(program, point)

  EVOCA SPECULUM AstNode box AD CONIURA ast_make_sigillum("Box", 2, 1)
  CONIURA ast_append_field(box, CONIURA ast_make_field("p", CONIURA ast_make_type("Point", 2, 1), 2, 1))
  CONIURA ast_program_append_decl(program, box)

  EVOCA SPECULUM AstNode body AD CONIURA ast_make_block(3, 1)
  CONIURA ast_append_statement(body, CONIURA ast_make_redde(CONIURA ast_make_literal_int("0", 3, 1), 3, 1))
  CONIURA ast_program_append_decl(program, CONIURA ast_make_rituale("main", CONIURA ast_make_type("REX", 3, 1), body, 3, 1))

  EVOCA VERBUM out AD CONIURA codegen_generate_program(program, "nested.cct")
  EVOCA REX rc AD 0
  SI NON CONIURA contains(out, "typedef struct cct_boot_sig_Point cct_boot_sig_Point;")
    VINCIRE rc AD 1
  FIN SI
  SI NON CONIURA contains(out, "typedef struct cct_boot_sig_Box cct_boot_sig_Box;")
    VINCIRE rc AD 2
  FIN SI
  SI NON CONIURA contains(out, "cct_boot_sig_Point p;")
    VINCIRE rc AD 3
  FIN SI

  DIMITTE out
  CONIURA ast_program_free(program)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
