INCIPIT grimoire "semantic_decl_duplicate_param_24f"

ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/parser.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_context.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_decl.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"p\" RITUALE main(REX x, REX x) REDDE REX REDDE x EXPLICIT RITUALE EXPLICIT grimoire"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(src, "duplicate_param.cct")
  EVOCA SPECULUM SemanticContext ctx AD CONIURA semantic_context_new("duplicate_param.cct")
  CONIURA semantic_validate_program(ctx, program)

  SI NON CONIURA semantic_had_error(ctx)
    REDDE 41
  FIN SI
  SI CONIURA compare((*ctx).last_error_message, "duplicate symbol 'x' in same scope") != 0
    REDDE 42
  FIN SI

  CONIURA semantic_context_free(ctx)
  CONIURA ast_program_free(program)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
