INCIPIT grimoire "db_stmt_select_loop_40x"

ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL db AD CONIURA db_open(":memory:")
  CONIURA db_exec(db, "CREATE TABLE items(id INTEGER, nome TEXT);")
  CONIURA db_exec(db, "INSERT INTO items(id, nome) VALUES(1, 'alpha');")
  CONIURA db_exec(db, "INSERT INTO items(id, nome) VALUES(2, 'beta');")
  CONIURA db_exec(db, "INSERT INTO items(id, nome) VALUES(3, 'gamma');")

  EVOCA SPECULUM NIHIL stmt AD CONIURA db_prepare(db, "SELECT id, nome FROM items WHERE id >= ?1 ORDER BY id;")
  CONIURA stmt_bind_int(stmt, 1, 2)

  EVOCA REX total AD 0
  EVOCA VERBUM names AD ""
  DUM CONIURA stmt_step(stmt)
    SI NON CONIURA stmt_has_row(stmt)
      FRANGE
    FIN SI
    VINCIRE total AD total + CONIURA stmt_get_int(stmt, 0)
    SI CONIURA len(names) != 0
      VINCIRE names AD CONIURA concat(names, ",")
    FIN SI
    VINCIRE names AD CONIURA concat(names, CONIURA stmt_get_text(stmt, 1))
  FIN DUM

  SI total != 5
    REDDE 1
  FIN SI
  SI CONIURA compare(names, "beta,gamma") != 0
    REDDE 2
  FIN SI

  CONIURA stmt_finalize(stmt)
  CONIURA db_close(db)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
