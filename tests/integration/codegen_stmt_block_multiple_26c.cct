INCIPIT grimoire "codegen_stmt_block_multiple_26c"

ADVOCARE "../../src/bootstrap/codegen/codegen_context.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen_stmt.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM CodegenContext ctx AD CONIURA codegen_context_new("block_multi.cct")
  EVOCA SPECULUM AstNode block AD CONIURA ast_make_block(1, 1)
  CONIURA ast_append_statement(block, CONIURA ast_make_expr_stmt(CONIURA ast_make_literal_int("1", 1, 1), 1, 1))
  CONIURA ast_append_statement(block, CONIURA ast_make_expr_stmt(CONIURA ast_make_literal_int("2", 1, 3), 1, 3))
  CONIURA codegen_emit_stmt(ctx, block)
  EVOCA VERBUM out AD CONIURA codegen_output(ctx)
  EVOCA REX rc AD 0
  SI CONIURA compare(out, "{\n  1;\n  2;\n}\n") != 0
    VINCIRE rc AD 1
  FIN SI
  DIMITTE out
  CONIURA ast_node_free(block)
  CONIURA codegen_context_free(ctx)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
