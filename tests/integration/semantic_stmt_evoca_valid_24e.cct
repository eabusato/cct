INCIPIT grimoire "semantic_stmt_evoca_valid_24e"

ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_context.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_stmt.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_symbol.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM SemanticContext ctx AD CONIURA semantic_context_new("evoca_valid.cct")
  EVOCA SPECULUM AstNode type_expr AD CONIURA ast_make_type("REX", 1, 7)
  EVOCA SPECULUM AstNode init_expr AD CONIURA ast_make_literal_int("1", 1, 16)
  EVOCA SPECULUM AstNode stmt AD CONIURA ast_make_evoca("x", type_expr, init_expr, 1, 1)
  CONIURA semantic_analyze_stmt(ctx, stmt)

  SI CONIURA semantic_had_error(ctx)
    REDDE 41
  FIN SI

  EVOCA REX sym_id AD CONIURA semantic_lookup_local(ctx, "x")
  SI sym_id == CONIURA semantic_invalid_id()
    REDDE 42
  FIN SI

  EVOCA SPECULUM SemanticSymbol sym AD CONIURA semantic_symbol_at(ctx, sym_id)
  SI (*sym).type_id != (*ctx).type_rex
    REDDE 43
  FIN SI

  CONIURA semantic_context_free(ctx)
  CONIURA ast_node_free(stmt)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
