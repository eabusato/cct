INCIPIT grimoire "map_basic_12d1"

ADVOCARE "cct/map.cct"
ADVOCARE "cct/option.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL m AD CONIURA map_init GENUS(REX, REX)()

  CONIURA map_insert GENUS(REX, REX)(m, 1, 10)
  CONIURA map_insert GENUS(REX, REX)(m, 2, 20)

  EVOCA SPECULUM NIHIL opt AD CONIURA map_get GENUS(REX, REX)(m, 1)
  SI NON CONIURA option_is_some GENUS(REX)(opt)
    CONIURA option_free GENUS(REX)(opt)
    CONIURA map_free GENUS(REX, REX)(m)
    REDDE 11
  FIN SI

  EVOCA REX v AD CONIURA option_unwrap GENUS(REX)(opt)
  CONIURA option_free GENUS(REX)(opt)

  SI v != 10
    CONIURA map_free GENUS(REX, REX)(m)
    REDDE 12
  FIN SI

  SI CONIURA map_len GENUS(REX, REX)(m) != 2
    CONIURA map_free GENUS(REX, REX)(m)
    REDDE 13
  FIN SI

  CONIURA map_free GENUS(REX, REX)(m)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
