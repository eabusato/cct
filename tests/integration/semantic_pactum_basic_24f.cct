INCIPIT grimoire "semantic_pactum_basic_24f"

ADVOCARE "../../src/bootstrap/parser/parser.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_context.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_decl.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"p\" PACTUM Forma RITUALE render(REX value) REDDE REX FIN PACTUM EXPLICIT grimoire"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(src, "pactum_basic.cct")
  EVOCA SPECULUM SemanticContext ctx AD CONIURA semantic_context_new("pactum_basic.cct")
  CONIURA semantic_validate_program(ctx, program)

  SI CONIURA semantic_had_error(ctx)
    REDDE 41
  FIN SI

  CONIURA semantic_context_free(ctx)
  CONIURA ast_program_free(program)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
