INCIPIT grimoire "codegen_sigillum_field_access_27a"

ADVOCARE "../../src/bootstrap/codegen/codegen_context.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen_struct.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen_expr.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM CodegenContext ctx AD CONIURA codegen_context_new("field.cct")
  EVOCA SPECULUM AstNode sig AD CONIURA ast_make_sigillum("Point", 1, 1)
  CONIURA ast_append_field(sig, CONIURA ast_make_field("x", CONIURA ast_make_type("REX", 1, 1), 1, 1))
  CONIURA codegen_register_sigillum_decl(ctx, sig)
  CONIURA codegen_define_local(ctx, "p", "p", "Point")

  EVOCA SPECULUM AstNode expr AD CONIURA ast_make_field_access(CONIURA ast_make_identifier("p", 1, 1), "x", 1, 3)
  CONIURA codegen_emit_expr(ctx, expr)
  EVOCA VERBUM out AD CONIURA codegen_output(ctx)
  EVOCA REX rc AD 0
  SI CONIURA compare(out, "p.x") != 0
    VINCIRE rc AD 1
  FIN SI
  SI CONIURA codegen_had_error(ctx)
    VINCIRE rc AD 2
  FIN SI

  DIMITTE out
  CONIURA ast_node_free(sig)
  CONIURA ast_node_free(expr)
  CONIURA codegen_context_free(ctx)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
