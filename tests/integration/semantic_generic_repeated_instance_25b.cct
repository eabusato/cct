INCIPIT grimoire "semantic_generic_repeated_instance_25b"

ADVOCARE "../../src/bootstrap/parser/parser.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_context.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_register.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_resolver.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"p\" SIGILLUM Caixa GENUS(T) valor: T FIN SIGILLUM EXPLICIT grimoire"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(src, "repeat_instance.cct")
  EVOCA SPECULUM SemanticContext ctx AD CONIURA semantic_context_new("repeat_instance.cct")
  CONIURA semantic_register_program(ctx, program)

  EVOCA SPECULUM AstNode t1 AD CONIURA ast_make_type("Caixa", 1, 1)
  CONIURA ast_append_generic_arg(t1, CONIURA ast_make_type("REX", 1, 10))
  EVOCA SPECULUM AstNode t2 AD CONIURA ast_make_type("Caixa", 2, 1)
  CONIURA ast_append_generic_arg(t2, CONIURA ast_make_type("REX", 2, 10))

  EVOCA REX id1 AD CONIURA semantic_resolve_type_node(ctx, t1)
  EVOCA REX id2 AD CONIURA semantic_resolve_type_node(ctx, t2)
  SI id1 != id2
    REDDE 41
  FIN SI

  CONIURA ast_node_free(t1)
  CONIURA ast_node_free(t2)
  CONIURA semantic_context_free(ctx)
  CONIURA ast_program_free(program)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
