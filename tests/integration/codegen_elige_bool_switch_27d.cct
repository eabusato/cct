INCIPIT grimoire "codegen_elige_bool_switch_27d"

ADVOCARE "../../src/bootstrap/parser/parser.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen_decl.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM source AD "INCIPIT grimoire \"g\"\nRITUALE main() REDDE REX\n  EVOCA VERUM x AD VERUM\n  ELIGE x\n  CASUS VERUM:\n    REDDE 1\n  CASUS FALSUM:\n    REDDE 2\n  FIN ELIGE\nEXPLICIT RITUALE\nEXPLICIT grimoire\n"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(source, "elige_bool.cct")
  EVOCA VERBUM out AD CONIURA codegen_generate_program(program, "elige_bool.cct")
  EVOCA REX rc AD 0
  SI NON CONIURA contains(out, "case 1:")
    VINCIRE rc AD 1
  FIN SI
  SI NON CONIURA contains(out, "case 0:")
    VINCIRE rc AD 2
  FIN SI
  DIMITTE out
  CONIURA ast_program_free(program)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
