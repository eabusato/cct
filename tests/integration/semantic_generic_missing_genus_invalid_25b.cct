INCIPIT grimoire "semantic_generic_missing_genus_invalid_25b"

ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/parser.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_context.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_decl.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"p\" SIGILLUM Caixa GENUS(T) valor: T FIN SIGILLUM RITUALE usa(Caixa c) REDDE NIHIL REDDE EXPLICIT RITUALE EXPLICIT grimoire"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(src, "missing_genus_invalid.cct")
  EVOCA SPECULUM SemanticContext ctx AD CONIURA semantic_context_new("missing_genus_invalid.cct")
  CONIURA semantic_validate_program(ctx, program)
  SI (*ctx).had_error != VERUM
    REDDE 41
  FIN SI
  SI CONIURA compare((*ctx).last_error_message, "generic type 'Caixa' requires explicit GENUS(...)") != 0
    REDDE 42
  FIN SI
  CONIURA semantic_context_free(ctx)
  CONIURA ast_program_free(program)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
