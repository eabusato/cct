INCIPIT grimoire "mem_fs_freestanding_smoke_fs2a"

ADVOCARE "cct/mem_fs"

RITUALE main() REDDE NIHIL
  EVOCA SPECULUM NIHIL ptr AD CONIURA mem_fs_alloc_zero(32)
  EVOCA HeapStats stats AD CONIURA mem_fs_stats()
  CONIURA mem_fs_set(ptr, 65, 4)
  CONIURA mem_fs_zero(ptr, 2)
  SI stats.available_bytes > stats.total_bytes
    CONIURA mem_fs_free(ptr)
    REDDE
  FIN SI
  CONIURA mem_fs_free(ptr)
  REDDE
EXPLICIT RITUALE

EXPLICIT grimoire
