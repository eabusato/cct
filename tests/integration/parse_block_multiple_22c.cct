INCIPIT grimoire "parse_block_multiple_22c"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/parser/parse_stmt.cct"
RITUALE main() REDDE REX
  EVOCA SPECULUM AstNode stmt AD CONIURA parser_parse_statement_source("{ REDDE 1 REDDE 2 }", "stmt.cct")
  SI (*stmt).kind != AST_BLOCK VEL CONIURA ast_node_list_len((*stmt).statements) != 2
    REDDE 41
  FIN SI
  CONIURA ast_node_free(stmt)
  REDDE 0
EXPLICIT RITUALE
EXPLICIT grimoire
