INCIPIT grimoire "semantic_constraint_ecosystem_simple_25c"

ADVOCARE "../../src/bootstrap/parser/parser.cct"
ADVOCARE "../../src/bootstrap/parser/parse_expr.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_context.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_expr.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_register.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_symbol.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"p\" PACTUM Numerabilis RITUALE valor() REDDE REX FIN PACTUM SIGILLUM Contador atual: REX FIN SIGILLUM RITUALE valor(SPECULUM Contador self) REDDE REX REDDE 1 EXPLICIT RITUALE RITUALE coleta GENUS(T PACTUM Numerabilis)(T item) REDDE NIHIL REDDE EXPLICIT RITUALE EXPLICIT grimoire"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(src, "ecosystem_25c.cct")
  EVOCA SPECULUM SemanticContext ctx AD CONIURA semantic_context_new("ecosystem_25c.cct")
  CONIURA semantic_register_program(ctx, program)

  EVOCA REX cont_id AD CONIURA semantic_lookup_global(ctx, "Contador")
  EVOCA SPECULUM SemanticSymbol cont_sym AD CONIURA semantic_symbol_at(ctx, cont_id)
  CONIURA semantic_define(ctx, SEM_SYMBOL_VARIABLE, "c", (*cont_sym).type_id, 1, 1)

  EVOCA SPECULUM AstNode expr AD CONIURA parser_parse_expression_source("coleta GENUS(Contador)(c)", "expr.cct")
  SI CONIURA semantic_analyze_expr(ctx, expr) != (*ctx).type_nihil VEL (*ctx).had_error != FALSUM
    REDDE 41
  FIN SI

  CONIURA ast_node_free(expr)
  CONIURA semantic_context_free(ctx)
  CONIURA ast_program_free(program)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
