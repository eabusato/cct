INCIPIT grimoire "codegen_type_unsupported_26e"

ADVOCARE "../../src/bootstrap/codegen/codegen_context.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen_type.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM CodegenContext ctx AD CONIURA codegen_context_new("unsupported.cct")
  EVOCA SPECULUM AstNode ty AD CONIURA ast_make_type("Persona", 3, 9)
  EVOCA VERBUM out AD CONIURA codegen_type_text(ctx, ty)
  EVOCA REX rc AD 0
  SI CONIURA codegen_had_error(ctx) != VERUM
    VINCIRE rc AD 1
  FIN SI
  SI CONIURA compare(out, "") != 0
    VINCIRE rc AD 2
  FIN SI
  CONIURA ast_node_free(ty)
  CONIURA codegen_context_free(ctx)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
