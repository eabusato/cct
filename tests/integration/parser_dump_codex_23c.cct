INCIPIT grimoire "parser_dump_codex_23c"
ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/parser.cct"
RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"p\"\nCODEX Math\n  SIGILLUM Box\n    value: REX\n  FIN SIGILLUM\n  RITUALE sum(REX a, REX b) REDDE REX\n    REDDE a\n  EXPLICIT RITUALE\nFIN CODEX\nEXPLICIT grimoire\n"
  EVOCA VERBUM dump AD CONIURA parser_dump_program_source(src, "m.cct")
  SI NON CONIURA contains(dump, "CODEX (line 2, col 1)")
    REDDE 41
  FIN SI
  SI NON CONIURA contains(dump, "Declarations:")
    REDDE 42
  FIN SI
  SI NON CONIURA contains(dump, "SIGILLUM (line 3, col 3)")
    REDDE 43
  FIN SI
  SI NON CONIURA contains(dump, "RITUALE (line 6, col 3)")
    REDDE 44
  FIN SI
  REDDE 0
EXPLICIT RITUALE
EXPLICIT grimoire
