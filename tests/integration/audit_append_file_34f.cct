INCIPIT grimoire "audit_append_file_34f"

ADVOCARE "cct/audit.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM path AD "tests/.tmp/audit_append_file_34f.jsonl"
  SI CONIURA exists(path)
    CONIURA delete_file(path)
  FIN SI
  EVOCA AuditOptions options AD CONIURA audit_options_default()
  EVOCA AuditLogger logger AD CONIURA audit_logger_open(path, options)
  EVOCA AuditActor actor AD CONIURA audit_actor_make("admin", "1", "root")
  EVOCA AuditTarget target AD CONIURA audit_target_make("page", "2", "home")
  EVOCA AuditEvent event AD CONIURA audit_event_new(actor, "update", target, AUDIT_SUCCESS, "", "req-2", "{\"changed\":1}")
  EVOCA SPECULUM NIHIL res AD CONIURA audit_append_event(SPECULUM logger, event)
  SI CONIURA result_is_err GENUS(REX, AuditError)(res)
    REDDE 1
  FIN SI
  EVOCA VERBUM out AD CONIURA read_all(path)
  CONIURA delete_file(path)
  SI NON CONIURA contains(out, "\"action\":\"update\"")
    REDDE 2
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
