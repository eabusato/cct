INCIPIT grimoire "codegen_program_fixture_simple_26d"

ADVOCARE "../../src/bootstrap/codegen/codegen_decl.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM AstProgram program AD CONIURA ast_program_new()
  EVOCA SPECULUM AstNode body AD CONIURA ast_make_block(1, 1)
  CONIURA ast_append_statement(body, CONIURA ast_make_redde(CONIURA ast_make_literal_int("0", 1, 1), 1, 1))
  CONIURA ast_program_append_decl(program, CONIURA ast_make_rituale("main", CONIURA ast_make_type("REX", 1, 1), body, 1, 1))
  EVOCA VERBUM out AD CONIURA codegen_generate_program(program, "fixture.cct")
  EVOCA REX rc AD 0
  SI NON CONIURA contains(out, "/* generated by cct bootstrap codegen */")
    VINCIRE rc AD 1
  FIN SI
  SI NON CONIURA contains(out, "long long cct_boot_rit_main_0(void);")
    VINCIRE rc AD 1
  FIN SI
  SI NON CONIURA contains(out, "long long cct_boot_rit_main_0(void)\n")
    VINCIRE rc AD 1
  FIN SI
  SI NON CONIURA contains(out, "return 0;")
    VINCIRE rc AD 1
  FIN SI
  DIMITTE out
  CONIURA ast_program_free(program)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
