INCIPIT grimoire "lexer_identifier_21c5"

ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/lexer/lexer_state.cct"
ADVOCARE "../../src/bootstrap/lexer/lexer_helpers.cct"
ADVOCARE "../../src/bootstrap/lexer/token.cct"
ADVOCARE "../../src/bootstrap/lexer/token_type.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM source1 AD "foo"
  EVOCA LexerState lex1 AD CONIURA lexer_init(source1, "test.cct")
  EVOCA Token tok1 AD CONIURA lexer_identifier(SPECULUM lex1)
  SI tok1.kind != TK_IDENTIFIER
    REDDE 41
  FIN SI
  SI CONIURA compare(tok1.lexeme, "foo") != 0
    REDDE 42
  FIN SI
  SI tok1.line != 1
    REDDE 43
  FIN SI
  SI tok1.column != 1
    REDDE 44
  FIN SI
  CONIURA token_free(SPECULUM tok1)

  EVOCA VERBUM source2 AD "my_variable"
  EVOCA LexerState lex2 AD CONIURA lexer_init(source2, "test.cct")
  EVOCA Token tok2 AD CONIURA lexer_identifier(SPECULUM lex2)
  SI tok2.kind != TK_IDENTIFIER
    REDDE 45
  FIN SI
  SI CONIURA compare(tok2.lexeme, "my_variable") != 0
    REDDE 46
  FIN SI
  CONIURA token_free(SPECULUM tok2)

  EVOCA VERBUM source3 AD "var123"
  EVOCA LexerState lex3 AD CONIURA lexer_init(source3, "test.cct")
  EVOCA Token tok3 AD CONIURA lexer_identifier(SPECULUM lex3)
  SI tok3.kind != TK_IDENTIFIER
    REDDE 47
  FIN SI
  SI CONIURA compare(tok3.lexeme, "var123") != 0
    REDDE 48
  FIN SI
  CONIURA token_free(SPECULUM tok3)

  EVOCA VERBUM source4 AD "INCIPIT"
  EVOCA LexerState lex4 AD CONIURA lexer_init(source4, "test.cct")
  EVOCA Token tok4 AD CONIURA lexer_identifier(SPECULUM lex4)
  SI tok4.kind != TK_INCIPIT
    REDDE 49
  FIN SI
  SI CONIURA compare(tok4.lexeme, "INCIPIT") != 0
    REDDE 50
  FIN SI
  CONIURA token_free(SPECULUM tok4)

  EVOCA VERBUM source5 AD "RITUALE"
  EVOCA LexerState lex5 AD CONIURA lexer_init(source5, "test.cct")
  EVOCA Token tok5 AD CONIURA lexer_identifier(SPECULUM lex5)
  SI tok5.kind != TK_RITUALE
    REDDE 51
  FIN SI
  CONIURA token_free(SPECULUM tok5)

  EVOCA VERBUM source6 AD "SI"
  EVOCA LexerState lex6 AD CONIURA lexer_init(source6, "test.cct")
  EVOCA Token tok6 AD CONIURA lexer_identifier(SPECULUM lex6)
  SI tok6.kind != TK_SI
    REDDE 52
  FIN SI
  CONIURA token_free(SPECULUM tok6)

  EVOCA VERBUM source7 AD "incipit"
  EVOCA LexerState lex7 AD CONIURA lexer_init(source7, "test.cct")
  EVOCA Token tok7 AD CONIURA lexer_identifier(SPECULUM lex7)
  SI tok7.kind != TK_IDENTIFIER
    REDDE 53
  FIN SI
  CONIURA token_free(SPECULUM tok7)

  EVOCA VERBUM source8 AD "_private"
  EVOCA LexerState lex8 AD CONIURA lexer_init(source8, "test.cct")
  EVOCA Token tok8 AD CONIURA lexer_identifier(SPECULUM lex8)
  SI tok8.kind != TK_IDENTIFIER
    REDDE 54
  FIN SI
  SI CONIURA compare(tok8.lexeme, "_private") != 0
    REDDE 55
  FIN SI
  CONIURA token_free(SPECULUM tok8)

  EVOCA VERBUM source9 AD "very_long_identifier_name_with_many_chars_123"
  EVOCA LexerState lex9 AD CONIURA lexer_init(source9, "test.cct")
  EVOCA Token tok9 AD CONIURA lexer_identifier(SPECULUM lex9)
  SI tok9.kind != TK_IDENTIFIER
    REDDE 56
  FIN SI
  SI CONIURA compare(tok9.lexeme, "very_long_identifier_name_with_many_chars_123") != 0
    REDDE 57
  FIN SI
  CONIURA token_free(SPECULUM tok9)

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
