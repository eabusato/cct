INCIPIT grimoire "lexer_string_21c7"

ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/lexer/lexer_state.cct"
ADVOCARE "../../src/bootstrap/lexer/lexer_helpers.cct"
ADVOCARE "../../src/bootstrap/lexer/token.cct"
ADVOCARE "../../src/bootstrap/lexer/token_type.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM source1 AD "\"hello\""
  EVOCA LexerState lex1 AD CONIURA lexer_init(source1, "test.cct")
  CONIURA lexer_advance(SPECULUM lex1)
  EVOCA Token tok1 AD CONIURA lexer_string(SPECULUM lex1)
  SI tok1.kind != TK_STRING
    REDDE 41
  FIN SI
  SI CONIURA compare(tok1.lexeme, "\"hello\"") != 0
    REDDE 42
  FIN SI
  CONIURA token_free(SPECULUM tok1)

  EVOCA VERBUM source2 AD "\"\""
  EVOCA LexerState lex2 AD CONIURA lexer_init(source2, "test.cct")
  CONIURA lexer_advance(SPECULUM lex2)
  EVOCA Token tok2 AD CONIURA lexer_string(SPECULUM lex2)
  SI tok2.kind != TK_STRING
    REDDE 43
  FIN SI
  SI CONIURA compare(tok2.lexeme, "\"\"") != 0
    REDDE 44
  FIN SI
  CONIURA token_free(SPECULUM tok2)

  EVOCA VERBUM source3 AD "\"hello world\""
  EVOCA LexerState lex3 AD CONIURA lexer_init(source3, "test.cct")
  CONIURA lexer_advance(SPECULUM lex3)
  EVOCA Token tok3 AD CONIURA lexer_string(SPECULUM lex3)
  SI tok3.kind != TK_STRING
    REDDE 45
  FIN SI
  SI CONIURA compare(tok3.lexeme, "\"hello world\"") != 0
    REDDE 46
  FIN SI
  CONIURA token_free(SPECULUM tok3)

  EVOCA VERBUM source4 AD "\"line1\\nline2\""
  EVOCA LexerState lex4 AD CONIURA lexer_init(source4, "test.cct")
  CONIURA lexer_advance(SPECULUM lex4)
  EVOCA Token tok4 AD CONIURA lexer_string(SPECULUM lex4)
  SI tok4.kind != TK_STRING
    REDDE 47
  FIN SI
  SI CONIURA compare(tok4.lexeme, "\"line1\\nline2\"") != 0
    REDDE 48
  FIN SI
  CONIURA token_free(SPECULUM tok4)

  EVOCA VERBUM source5 AD "\"say \\\"hello\\\"\""
  EVOCA LexerState lex5 AD CONIURA lexer_init(source5, "test.cct")
  CONIURA lexer_advance(SPECULUM lex5)
  EVOCA Token tok5 AD CONIURA lexer_string(SPECULUM lex5)
  SI tok5.kind != TK_STRING
    REDDE 49
  FIN SI
  SI CONIURA compare(tok5.lexeme, "\"say \\\"hello\\\"\"") != 0
    REDDE 50
  FIN SI
  CONIURA token_free(SPECULUM tok5)

  EVOCA VERBUM source6 AD "\"path\\\\file\""
  EVOCA LexerState lex6 AD CONIURA lexer_init(source6, "test.cct")
  CONIURA lexer_advance(SPECULUM lex6)
  EVOCA Token tok6 AD CONIURA lexer_string(SPECULUM lex6)
  SI tok6.kind != TK_STRING
    REDDE 51
  FIN SI
  SI CONIURA compare(tok6.lexeme, "\"path\\\\file\"") != 0
    REDDE 52
  FIN SI
  CONIURA token_free(SPECULUM tok6)

  EVOCA VERBUM source7 AD "\"col1\\tcol2\""
  EVOCA LexerState lex7 AD CONIURA lexer_init(source7, "test.cct")
  CONIURA lexer_advance(SPECULUM lex7)
  EVOCA Token tok7 AD CONIURA lexer_string(SPECULUM lex7)
  SI tok7.kind != TK_STRING
    REDDE 53
  FIN SI
  SI CONIURA compare(tok7.lexeme, "\"col1\\tcol2\"") != 0
    REDDE 54
  FIN SI
  CONIURA token_free(SPECULUM tok7)

  EVOCA VERBUM source8 AD "\"unterminated"
  EVOCA LexerState lex8 AD CONIURA lexer_init(source8, "test.cct")
  CONIURA lexer_advance(SPECULUM lex8)
  EVOCA Token tok8 AD CONIURA lexer_string(SPECULUM lex8)
  SI tok8.kind != TK_INVALID
    REDDE 55
  FIN SI
  SI NON lex8.had_error
    REDDE 56
  FIN SI
  SI CONIURA compare(tok8.lexeme, "Unterminated string") != 0
    REDDE 57
  FIN SI
  CONIURA token_free(SPECULUM tok8)

  EVOCA VERBUM source9 AD "\"\\n\\t\\\\\\\"all\""
  EVOCA LexerState lex9 AD CONIURA lexer_init(source9, "test.cct")
  CONIURA lexer_advance(SPECULUM lex9)
  EVOCA Token tok9 AD CONIURA lexer_string(SPECULUM lex9)
  SI tok9.kind != TK_STRING
    REDDE 58
  FIN SI
  SI CONIURA compare(tok9.lexeme, "\"\\n\\t\\\\\\\"all\"") != 0
    REDDE 59
  FIN SI
  CONIURA token_free(SPECULUM tok9)

  EVOCA VERBUM source10 AD "\"bad\\q\""
  EVOCA LexerState lex10 AD CONIURA lexer_init(source10, "test.cct")
  CONIURA lexer_advance(SPECULUM lex10)
  EVOCA Token tok10 AD CONIURA lexer_string(SPECULUM lex10)
  SI tok10.kind != TK_INVALID
    REDDE 60
  FIN SI
  SI NON lex10.had_error
    REDDE 61
  FIN SI
  SI CONIURA compare(tok10.lexeme, "Invalid escape sequence") != 0
    REDDE 62
  FIN SI
  CONIURA token_free(SPECULUM tok10)

  EVOCA VERBUM source11 AD CONIURA concat("\"unter", CONIURA concat(CONIURA from_char(10), "minated"))
  EVOCA LexerState lex11 AD CONIURA lexer_init(source11, "test.cct")
  CONIURA lexer_advance(SPECULUM lex11)
  EVOCA Token tok11 AD CONIURA lexer_string(SPECULUM lex11)
  SI tok11.kind != TK_INVALID
    REDDE 63
  FIN SI
  SI NON lex11.had_error
    REDDE 64
  FIN SI
  SI CONIURA compare(tok11.lexeme, "Unterminated string") != 0
    REDDE 65
  FIN SI
  CONIURA token_free(SPECULUM tok11)

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
