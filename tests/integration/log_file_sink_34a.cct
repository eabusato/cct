INCIPIT grimoire "log_file_sink_34a"

ADVOCARE "cct/fs.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/log.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM path AD "tests/.tmp/log_file_sink_34a.log"
  SI CONIURA exists(path)
    CONIURA delete_file(path)
  FIN SI

  EVOCA Logger logger AD CONIURA log_new("jobs", INFO)
  EVOCA SPECULUM NIHIL res AD CONIURA log_set_sink_file(SPECULUM logger, path)
  SI CONIURA result_is_err GENUS(REX, LogError)(res)
    REDDE 1
  FIN SI

  CONIURA log_info(SPECULUM logger, "job started", "{\"job\":\"nightly\"}")
  CONIURA log_error(SPECULUM logger, "job failed", "{\"reason\":\"boom\"}")

  EVOCA VERBUM txt AD CONIURA read_all(path)
  SI NON CONIURA contains(txt, "job started")
    REDDE 2
  FIN SI
  SI NON CONIURA contains(txt, "job failed")
    REDDE 3
  FIN SI

  EVOCA SPECULUM NIHIL ls AD CONIURA lines(txt)
  SI CONIURA fluxus_len(ls) < 2
    REDDE 4
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
