INCIPIT grimoire "http_client_post_local_20c3_server"

ADVOCARE "cct/fs.cct"
ADVOCARE "cct/http.cct"
ADVOCARE "cct/net.cct"
ADVOCARE "cct/socket.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM ready AD "tests/.tmp/http_client_post_local_20c3.ready"
  EVOCA VERBUM done AD "tests/.tmp/http_client_post_local_20c3.done"
  TEMPTA
    EVOCA SPECULUM NIHIL listener AD CONIURA tcp_listen("", 22332)
    CONIURA write_all(ready, "ready")

    EVOCA SPECULUM NIHIL client AD CONIURA tcp_accept(listener)
    CONIURA sock_set_timeout_ms(client, 1000)

    EVOCA VERBUM raw_req AD CONIURA http_read_request_raw(client)
    EVOCA HttpRequest req AD CONIURA http_parse_request(raw_req)
    SI CONIURA compare(CONIURA http_request_method(req), "POST") != 0
      REDDE 10
    FIN SI
    SI CONIURA compare(CONIURA http_request_path(req), "/submit") != 0
      REDDE 11
    FIN SI
    SI CONIURA compare(CONIURA http_request_body(req), "corpo-post") != 0
      REDDE 12
    FIN SI
    SI CONIURA compare(CONIURA http_request_header(req, "X-Trace", ""), "abc123") != 0
      REDDE 13
    FIN SI
    SI CONIURA compare(CONIURA http_request_header(req, "Content-Length", ""), "10") != 0
      REDDE 14
    FIN SI

    EVOCA HttpResponse res AD CONIURA http_response_new(201, "gravado")
    EVOCA REX headers AD CONIURA http_response_headers_handle(res)
    CONIURA http_headers_set_or_push(headers, "Content-Type", "text/plain")
    CONIURA http_headers_set_or_push(headers, "X-Reply", "post-ok")
    CONIURA http_headers_set_or_push(headers, "Content-Length", "7")

    EVOCA VERBUM raw_res AD CONIURA http_stringify_response(res)
    SI CONIURA sock_send(client, raw_res) != CONIURA len(raw_res)
      REDDE 15
    FIN SI

    CONIURA net_close(client)
    CONIURA net_close(listener)
    CONIURA write_all(done, "ok")
    REDDE 0
  CAPE FRACTUM erro
    EVOCA VERBUM msg AD OBSECRO fractum_to_verbum(erro)
    SI CONIURA compare(msg, "sock_bind falhou") == 0 VEL CONIURA compare(msg, "socket tcp create falhou") == 0
      CONIURA write_all(ready, "skip")
      CONIURA write_all(done, "skip")
      REDDE 0
    FIN SI
    REDDE 90
  FIN TEMPTA
  REDDE 91
EXPLICIT RITUALE

EXPLICIT grimoire
