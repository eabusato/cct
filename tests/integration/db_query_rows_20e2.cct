INCIPIT grimoire "db_query_rows_20e2"

ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL db AD CONIURA db_open(":memory:")
  CONIURA db_exec(db, "CREATE TABLE items(id INTEGER, nome TEXT, preco REAL);")
  CONIURA db_exec(db, "INSERT INTO items(id, nome, preco) VALUES(1, 'alpha', 1.5);")
  CONIURA db_exec(db, "INSERT INTO items(id, nome, preco) VALUES(2, 'beta', 2.25);")

  EVOCA SPECULUM NIHIL rows AD CONIURA db_query(db, "SELECT id, nome, preco FROM items ORDER BY id;")

  SI NON CONIURA rows_next(rows)
    REDDE 1
  FIN SI
  SI CONIURA rows_get_int(rows, 0) != 1
    REDDE 2
  FIN SI
  SI CONIURA compare(CONIURA rows_get_text(rows, 1), "alpha") != 0
    REDDE 3
  FIN SI
  SI CONIURA rows_get_real(rows, 2) != 1.5
    REDDE 4
  FIN SI

  SI NON CONIURA rows_next(rows)
    REDDE 5
  FIN SI
  SI CONIURA rows_get_int(rows, 0) != 2
    REDDE 6
  FIN SI
  SI CONIURA compare(CONIURA rows_get_text(rows, 1), "beta") != 0
    REDDE 7
  FIN SI
  SI CONIURA rows_get_real(rows, 2) != 2.25
    REDDE 8
  FIN SI

  SI CONIURA rows_next(rows)
    REDDE 9
  FIN SI

  CONIURA rows_close(rows)
  CONIURA db_close(db)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
