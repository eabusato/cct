INCIPIT grimoire "signal_kind_map_34d"

ADVOCARE "cct/signal.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  SI CONIURA compare(CONIURA signal_kind_to_string(SIGNAL_SIGTERM), "SIGTERM") != 0
    REDDE 1
  FIN SI
  SI CONIURA signal_kind_from_code(2) != SIGNAL_SIGINT
    REDDE 2
  FIN SI
  SI CONIURA signal_kind_from_code(9) != SIGNAL_UNKNOWN
    REDDE 3
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
