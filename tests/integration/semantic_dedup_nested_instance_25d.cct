INCIPIT grimoire "semantic_dedup_nested_instance_25d"

ADVOCARE "../../src/bootstrap/parser/parser.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_context.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_generic.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_register.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_resolver.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"p\" SIGILLUM Caixa GENUS(T) valor: T FIN SIGILLUM SIGILLUM Porta GENUS(U) interno: U FIN SIGILLUM EXPLICIT grimoire"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(src, "nested_instance_25d.cct")
  EVOCA SPECULUM SemanticContext ctx AD CONIURA semantic_context_new("nested_instance_25d.cct")
  CONIURA semantic_register_program(ctx, program)

  EVOCA SPECULUM AstNode inner1 AD CONIURA ast_make_type("Caixa", 1, 1)
  CONIURA ast_append_generic_arg(inner1, CONIURA ast_make_type("REX", 1, 10))
  EVOCA SPECULUM AstNode outer1 AD CONIURA ast_make_type("Porta", 1, 20)
  CONIURA ast_append_generic_arg(outer1, inner1)

  EVOCA SPECULUM AstNode inner2 AD CONIURA ast_make_type("Caixa", 2, 1)
  CONIURA ast_append_generic_arg(inner2, CONIURA ast_make_type("REX", 2, 10))
  EVOCA SPECULUM AstNode outer2 AD CONIURA ast_make_type("Porta", 2, 20)
  CONIURA ast_append_generic_arg(outer2, inner2)

  EVOCA REX id1 AD CONIURA semantic_resolve_type_node(ctx, outer1)
  EVOCA REX id2 AD CONIURA semantic_resolve_type_node(ctx, outer2)
  SI id1 != id2
    REDDE 41
  FIN SI
  SI CONIURA semantic_instance_cache_len(ctx) != 2
    REDDE 42
  FIN SI

  CONIURA ast_node_free(outer1)
  CONIURA ast_node_free(outer2)
  CONIURA semantic_context_free(ctx)
  CONIURA ast_program_free(program)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
