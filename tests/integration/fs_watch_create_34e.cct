INCIPIT grimoire "fs_watch_create_34e"

ADVOCARE "cct/fs.cct"
ADVOCARE "cct/fs_watch.cct"
ADVOCARE "cct/time.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM path AD "tests/.tmp/fs_watch_create_34e.txt"
  EVOCA FsWatchEvent event
  EVOCA REX attempts AD 0
  SI CONIURA exists(path)
    CONIURA delete_file(path)
  FIN SI
  EVOCA FsWatch watch AD CONIURA fs_watch_open(path)
  CONIURA write_all(path, "created")
  VINCIRE event AD CONIURA fs_watch_poll(SPECULUM watch)
  DUM event.kind == WATCH_NONE ET attempts < 50
    CONIURA sleep_ms(20)
    VINCIRE event AD CONIURA fs_watch_poll(SPECULUM watch)
    VINCIRE attempts AD attempts + 1
  FIN DUM
  CONIURA delete_file(path)
  SI event.kind != WATCH_CREATE
    REDDE 1
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
