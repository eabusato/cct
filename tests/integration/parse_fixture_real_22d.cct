INCIPIT grimoire "parse_fixture_real_22d"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/parser/parser.cct"
RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"fixture22d\"\nADVOCARE \"cct/io.cct\"\nSIGILLUM Pair\n  left: REX\n  right: REX\nFIN SIGILLUM\nRITUALE main() REDDE REX\n  EVOCA REX x AD 1\n  REDDE x\nEXPLICIT RITUALE\nEXPLICIT grimoire\n"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(src, "real.cct")
  SI CONIURA ast_node_list_len((*program).declarations) != 3
    REDDE 41
  FIN SI
  CONIURA ast_program_free(program)
  REDDE 0
EXPLICIT RITUALE
EXPLICIT grimoire
