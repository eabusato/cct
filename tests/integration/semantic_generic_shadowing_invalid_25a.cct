INCIPIT grimoire "semantic_generic_shadowing_invalid_25a"

ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/parser.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_context.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_register.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_symbol.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"p\" SIGILLUM Caixa valor: REX FIN SIGILLUM RITUALE usar GENUS(Caixa)(Caixa valor) REDDE NIHIL REDDE EXPLICIT RITUALE EXPLICIT grimoire"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(src, "shadow_invalid.cct")
  EVOCA SPECULUM SemanticContext ctx AD CONIURA semantic_context_new("shadow_invalid.cct")
  CONIURA semantic_register_program(ctx, program)

  SI (*ctx).had_error != VERUM
    REDDE 41
  FIN SI
  SI CONIURA compare((*ctx).last_error_message, "GENUS parameter 'Caixa' shadows existing type namespace symbol") != 0
    REDDE 42
  FIN SI

  EVOCA REX rituale_id AD CONIURA semantic_lookup_global(ctx, "usar")
  EVOCA SPECULUM SemanticSymbol rituale_sym AD CONIURA semantic_symbol_at(ctx, rituale_id)
  SI CONIURA fluxus_len((*rituale_sym).type_param_ids) != 0
    REDDE 43
  FIN SI

  CONIURA semantic_context_free(ctx)
  CONIURA ast_program_free(program)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
