INCIPIT grimoire "collection_series_ops_12d2"

ADVOCARE "cct/collection_ops.cct"
ADVOCARE "cct/fluxus.cct"

RITUALE inc(REX x) REDDE REX
  REDDE x + 1
EXPLICIT RITUALE

RITUALE somar(REX acc, REX x) REDDE REX
  REDDE acc + x
EXPLICIT RITUALE

RITUALE main() REDDE REX
  EVOCA SERIES REX[3] nums
  VINCIRE nums[0] AD 10
  VINCIRE nums[1] AD 20
  VINCIRE nums[2] AD 30

  EVOCA SPECULUM NIHIL mapped AD CONIURA series_map GENUS(REX, REX)(SPECULUM nums, 3, inc)
  EVOCA REX len AD CONIURA fluxus_len(mapped)
  CONIURA fluxus_free(mapped)

  EVOCA REX soma AD CONIURA series_reduce GENUS(REX, REX)(SPECULUM nums, 3, 0, somar)

  REDDE len + soma
EXPLICIT RITUALE

EXPLICIT grimoire
