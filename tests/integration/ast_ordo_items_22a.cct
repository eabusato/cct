INCIPIT grimoire "ast_ordo_items_22a"

ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM AstNode ord AD CONIURA ast_make_ordo("Cor", 1, 1)
  EVOCA SPECULUM AstNode i1 AD CONIURA ast_make_enum_item("RUBER", CONIURA ast_make_literal_int("1", 2, 3), 2, 3)
  EVOCA SPECULUM AstNode i2 AD CONIURA ast_make_enum_item("VIRIDIS", CONIURA ast_make_literal_int("2", 3, 3), 3, 3)

  CONIURA ast_append_item(ord, i1)
  CONIURA ast_append_item(ord, i2)

  SI (*ord).kind != AST_ORDO
    REDDE 41
  FIN SI
  SI CONIURA ast_node_list_len((*ord).items) != 2
    REDDE 42
  FIN SI
  EVOCA SPECULUM AstNode item1 AD CONIURA ast_node_list_get((*ord).items, 0)
  EVOCA SPECULUM AstNode item2 AD CONIURA ast_node_list_get((*ord).items, 1)
  SI CONIURA compare((*item1).name, "RUBER") != 0
    REDDE 43
  FIN SI
  SI CONIURA compare((*(*item2).right).value_text, "2") != 0
    REDDE 44
  FIN SI

  CONIURA ast_node_free(ord)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
