INCIPIT grimoire "semantic_lookup_parent_24a"

ADVOCARE "../../src/bootstrap/semantic/semantic_context.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM SemanticContext ctx AD CONIURA semantic_context_new("parent.cct")
  CONIURA semantic_push_scope(ctx, SEM_SCOPE_RITUALE)
  EVOCA REX outer AD CONIURA semantic_define(ctx, SEM_SYMBOL_PARAMETER, "arg", (*ctx).type_rex, 3, 4)
  CONIURA semantic_push_scope(ctx, SEM_SCOPE_BLOCK)

  SI CONIURA semantic_lookup(ctx, "arg") != outer
    REDDE 41
  FIN SI
  SI CONIURA semantic_lookup_local(ctx, "arg") != CONIURA semantic_invalid_id()
    REDDE 42
  FIN SI
  SI CONIURA semantic_lookup_global(ctx, "arg") != CONIURA semantic_invalid_id()
    REDDE 43
  FIN SI

  CONIURA semantic_context_free(ctx)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
