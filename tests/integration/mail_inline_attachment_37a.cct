INCIPIT grimoire "mail_inline_attachment_37a"

ADVOCARE "cct/bytes.cct"
ADVOCARE "cct/mail.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA MailMessage msg AD CONIURA mail_message_new()
  EVOCA SPECULUM NIHIL data AD CONIURA bytes_new(60)
  EVOCA REX i AD 0
  DUM i < 60
    CONIURA bytes_set(data, i, 65)
    VINCIRE i AD i + 1
  FIN DUM

  CONIURA mail_message_set_from(SPECULUM msg, CONIURA mail_address("noreply@example.com", ""))
  CONIURA mail_message_add_to(SPECULUM msg, CONIURA mail_address("dest@example.com", ""))
  CONIURA mail_message_set_subject(SPECULUM msg, "Inline attachment")
  CONIURA mail_message_set_html(SPECULUM msg, "<img src=\"cid:cid-logo\">")
  CONIURA mail_message_add_inline_attachment(SPECULUM msg, "logo.bin", "image/png", data, "cid-logo")

  EVOCA VERBUM mime AD CONIURA mail_message_render_mime(msg)
  SI CONIURA contains(mime, "Content-Disposition: inline; filename=\"logo.bin\"") == FALSUM
    REDDE 1
  FIN SI
  SI CONIURA contains(mime, "Content-ID: <cid-logo>") == FALSUM
    REDDE 2
  FIN SI
  SI CONIURA contains(mime, CONIURA concat(CONIURA repeat("QUFB", 19), CONIURA concat("\n", "QUFB"))) == FALSUM
    REDDE 3
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
