INCIPIT grimoire "codegen_decl_prototype_26d"

ADVOCARE "../../src/bootstrap/codegen/codegen_context.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen_decl.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM CodegenContext ctx AD CONIURA codegen_context_new("proto.cct")
  EVOCA SPECULUM AstNode fn AD CONIURA ast_make_rituale("noop", CONIURA ast_make_type("NIHIL", 1, 1), CONIURA ast_make_block(1, 1), 1, 1)
  CONIURA codegen_emit_rituale_prototype(ctx, fn)
  EVOCA VERBUM out AD CONIURA codegen_output(ctx)
  EVOCA REX rc AD 0
  SI CONIURA compare(out, "void cct_boot_rit_noop_0(void);\n") != 0
    VINCIRE rc AD 1
  FIN SI
  DIMITTE out
  CONIURA ast_node_free(fn)
  CONIURA codegen_context_free(ctx)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
