INCIPIT grimoire "verbum_ascii_helpers_33a"

ADVOCARE "cct/io.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM noisy AD CONIURA concat("abc", CONIURA from_char(1))
  VINCIRE noisy AD CONIURA concat(noisy, CONIURA from_char(2))
  VINCIRE noisy AD CONIURA concat(noisy, "-123")

  SI CONIURA compare(CONIURA to_upper("Abc-123"), "ABC-123") != 0
    CONIURA eprint("to_upper falhou\n")
    REDDE 1
  FIN SI

  SI CONIURA compare(CONIURA to_lower("AbC-123"), "abc-123") != 0
    CONIURA eprint("to_lower falhou\n")
    REDDE 1
  FIN SI

  SI CONIURA compare(CONIURA verbum_ascii_only(noisy), "abc-123") != 0
    CONIURA eprint("ascii_only falhou\n")
    REDDE 1
  FIN SI

  SI CONIURA verbum_length("abc-123") != 7
    CONIURA eprint("verbum_length falhou\n")
    REDDE 1
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
