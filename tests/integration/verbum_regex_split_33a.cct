INCIPIT grimoire "verbum_regex_split_33a"

ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/io.cct"
ADVOCARE "cct/regex.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL compiled AD CONIURA regex_compile("[,; ]+")
  SI CONIURA result_is_err GENUS(Regex, VERBUM)(compiled)
    CONIURA eprint("regex_compile falhou\n")
    REDDE 1
  FIN SI

  EVOCA Regex rx AD CONIURA result_unwrap GENUS(Regex, VERBUM)(compiled)
  EVOCA SPECULUM NIHIL parts AD CONIURA verbum_split_regex("um,dois; tres", rx.handle)
  SI CONIURA fluxus_len(parts) != 3
    CONIURA eprint("split_regex len invalido\n")
    REDDE 1
  FIN SI

  EVOCA VERBUM joined AD CONIURA join(parts, "|")
  SI CONIURA compare(joined, "um|dois|tres") != 0
    CONIURA eprint("split_regex conteudo invalido\n")
    REDDE 1
  FIN SI

  CONIURA fluxus_free(parts)
  CONIURA regex_free(rx)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
