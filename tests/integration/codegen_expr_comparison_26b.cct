INCIPIT grimoire "codegen_expr_comparison_26b"

ADVOCARE "../../src/bootstrap/codegen/codegen_context.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen_expr.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/lexer/token_type.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM AstNode left AD CONIURA ast_make_identifier("x", 1, 1)
  EVOCA SPECULUM AstNode right AD CONIURA ast_make_literal_int("10", 1, 5)
  EVOCA SPECULUM AstNode expr AD CONIURA ast_make_binary(TK_GREATER_EQ, left, right, 1, 3)
  EVOCA SPECULUM CodegenContext ctx AD CONIURA codegen_context_new("cmp.cct")
  CONIURA codegen_emit_expr(ctx, expr)
  EVOCA VERBUM out AD CONIURA codegen_output(ctx)
  EVOCA REX rc AD 0
  SI CONIURA compare(out, "(x >= 10)") != 0
    VINCIRE rc AD 1
  FIN SI
  DIMITTE out
  CONIURA ast_node_free(expr)
  CONIURA codegen_context_free(ctx)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
