INCIPIT grimoire "http_server_basic_20c4"

ADVOCARE "cct/fs.cct"
ADVOCARE "cct/http.cct"
ADVOCARE "cct/process.cct"
ADVOCARE "cct/time.cct"
ADVOCARE "cct/verbum.cct"

RITUALE cleanup_file(VERBUM path) REDDE NIHIL
  SI CONIURA exists(path)
    CONIURA delete_file(path)
  FIN SI
  REDDE
EXPLICIT RITUALE

RITUALE wait_for_file(VERBUM path, REX timeout_ms) REDDE VERUM
  EVOCA REX elapsed AD 0
  DUM elapsed < timeout_ms
    SI CONIURA exists(path)
      REDDE VERUM
    FIN SI
    CONIURA sleep_ms(20)
    VINCIRE elapsed AD elapsed + 20
  FIN DUM
  REDDE CONIURA exists(path)
EXPLICIT RITUALE

RITUALE main() REDDE REX
  EVOCA VERBUM ready AD "tests/.tmp/http_server_basic_20c4.ready"
  EVOCA VERBUM done AD "tests/.tmp/http_server_basic_20c4.done"
  EVOCA VERBUM log AD "tests/.tmp/http_server_basic_20c4.server.log"

  CONIURA cleanup_file(ready)
  CONIURA cleanup_file(done)
  CONIURA cleanup_file(log)

  SI CONIURA run("tests/integration/http_server_basic_20c4_server >tests/.tmp/http_server_basic_20c4.server.log 2>&1 &") != 0
    REDDE 1
  FIN SI

  SI NON CONIURA wait_for_file(ready, 2000)
    REDDE 2
  FIN SI

  SI CONIURA compare(CONIURA read_all(ready), "skip") == 0
    REDDE 0
  FIN SI
  CONIURA sleep_ms(50)

  EVOCA HttpResponse res AD CONIURA http_get("http://127.0.0.1:22334/server-basic")
  SI CONIURA http_response_status(res) != 200
    REDDE 3
  FIN SI
  SI CONIURA compare(CONIURA http_response_body(res), "server-ok") != 0
    REDDE 4
  FIN SI
  SI CONIURA compare(CONIURA http_response_header(res, "X-Server", ""), "cct") != 0
    REDDE 5
  FIN SI

  SI NON CONIURA wait_for_file(done, 2000)
    REDDE 6
  FIN SI
  SI CONIURA compare(CONIURA read_all(done), "ok") != 0
    REDDE 7
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
