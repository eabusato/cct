INCIPIT grimoire "verbum_words_18a2"

ADVOCARE "cct/verbum.cct"
ADVOCARE "cct/fluxus.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM crs AD OBSECRO verbum_from_char(13)
  EVOCA VERBUM s1 AD "  alpha\tbeta\n"
  VINCIRE s1 AD CONIURA concat(s1, crs)
  VINCIRE s1 AD CONIURA concat(s1, "gamma  ")
  EVOCA SPECULUM NIHIL w AD CONIURA words(s1)

  EVOCA VERBUM s2 AD " \t\n"
  VINCIRE s2 AD CONIURA concat(s2, crs)
  VINCIRE s2 AD CONIURA concat(s2, " ")
  EVOCA SPECULUM NIHIL z AD CONIURA words(s2)
  EVOCA VERBUM wj AD CONIURA join(w, "|")
  EVOCA VERBUM zj AD CONIURA join(z, "|")

  SI CONIURA fluxus_len(w) == 3 ET CONIURA fluxus_len(z) == 0
    SI CONIURA compare(wj, "alpha|beta|gamma") == 0 ET CONIURA compare(zj, "") == 0
      CONIURA fluxus_free(w)
      CONIURA fluxus_free(z)
      REDDE 0
    FIN SI
  FIN SI

  CONIURA fluxus_free(w)
  CONIURA fluxus_free(z)
  REDDE 1
EXPLICIT RITUALE

EXPLICIT grimoire
