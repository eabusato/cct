INCIPIT grimoire "db_postgres_stmt_closed_36a"

ADVOCARE "cct/db_postgres.cct"
ADVOCARE "cct/result.cct"

RITUALE main() REDDE REX
  EVOCA Stmt stmt
  VINCIRE stmt.name AD "noop"
  VINCIRE stmt.sql AD "SELECT 1"
  VINCIRE stmt.bindings AD CONIURA db_empty_params()
  VINCIRE stmt.closed AD VERUM
  EVOCA SPECULUM NIHIL exec_res AD CONIURA stmt_exec(stmt)
  SI NON CONIURA result_is_err GENUS(REX, VERBUM)(exec_res)
    REDDE 1
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
