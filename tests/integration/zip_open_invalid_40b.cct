INCIPIT grimoire "zip_open_invalid_40b"

ADVOCARE "cct/archive_zip.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/result.cct"

RITUALE main() REDDE REX
  SI OBSECRO args_argc() < 2
    REDDE 130
  FIN SI

  EVOCA VERBUM zip_path AD OBSECRO args_arg(1)
  CONIURA write_all(zip_path, "not-a-zip")
  EVOCA SPECULUM NIHIL opened AD CONIURA zip_open(zip_path)
  SI CONIURA result_is_ok GENUS(ZipArchive, VERBUM)(opened)
    REDDE 131
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
