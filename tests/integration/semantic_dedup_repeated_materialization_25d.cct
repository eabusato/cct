INCIPIT grimoire "semantic_dedup_repeated_materialization_25d"

ADVOCARE "../../src/bootstrap/parser/parser.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_context.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_generic.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_register.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_resolver.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"p\" SIGILLUM Caixa GENUS(T) valor: T FIN SIGILLUM EXPLICIT grimoire"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(src, "repeated_materialization_25d.cct")
  EVOCA SPECULUM SemanticContext ctx AD CONIURA semantic_context_new("repeated_materialization_25d.cct")
  CONIURA semantic_register_program(ctx, program)

  EVOCA REX first_id AD CONIURA semantic_invalid_id()
  EVOCA REX i AD 0
  DUM i < 20
    EVOCA SPECULUM AstNode t AD CONIURA ast_make_type("Caixa", i + 1, 1)
    CONIURA ast_append_generic_arg(t, CONIURA ast_make_type("REX", i + 1, 10))
    EVOCA REX type_id AD CONIURA semantic_resolve_type_node(ctx, t)
    SI i == 0
      VINCIRE first_id AD type_id
    ALITER
      SI type_id != first_id
        REDDE 41
      FIN SI
    FIN SI
    CONIURA ast_node_free(t)
    VINCIRE i AD i + 1
  FIN DUM

  SI CONIURA semantic_instance_cache_len(ctx) != 1
    REDDE 42
  FIN SI

  CONIURA semantic_context_free(ctx)
  CONIURA ast_program_free(program)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
