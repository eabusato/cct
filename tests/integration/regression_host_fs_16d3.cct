INCIPIT grimoire "regression_host_fs_16d3"

ADVOCARE "cct/fs.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM caminho AD "tests/.tmp/regression_host_fs_16d3.txt"
  EVOCA VERBUM conteudo AD "host-fs-16d3"

  CONIURA write_all(caminho, conteudo)
  EVOCA VERBUM lido AD CONIURA read_all(caminho)

  SI CONIURA compare(lido, conteudo) == 0
    REDDE 0
  FIN SI
  REDDE 1
EXPLICIT RITUALE

EXPLICIT grimoire
