INCIPIT grimoire "codegen_sigillum_type_27a"

ADVOCARE "../../src/bootstrap/codegen/codegen_context.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen_struct.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen_type.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM AstProgram program AD CONIURA ast_program_new()
  EVOCA SPECULUM AstNode sig AD CONIURA ast_make_sigillum("Point", 1, 1)
  CONIURA ast_append_field(sig, CONIURA ast_make_field("x", CONIURA ast_make_type("REX", 1, 1), 1, 1))
  CONIURA ast_program_append_decl(program, sig)

  EVOCA SPECULUM CodegenContext ctx AD CONIURA codegen_context_new("sigtype.cct")
  CONIURA codegen_register_program_shapes(ctx, program)

  EVOCA SPECULUM AstNode ty AD CONIURA ast_make_type("Point", 2, 1)
  EVOCA VERBUM out AD CONIURA codegen_type_text(ctx, ty)
  EVOCA REX rc AD 0
  SI CONIURA compare(out, "cct_boot_sig_Point") != 0
    VINCIRE rc AD 1
  FIN SI

  CONIURA ast_node_free(ty)
  CONIURA codegen_context_free(ctx)
  CONIURA ast_program_free(program)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
