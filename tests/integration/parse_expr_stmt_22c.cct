INCIPIT grimoire "parse_expr_stmt_22c"
ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/lexer/token_type.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/parser/parse_stmt.cct"
RITUALE main() REDDE REX
  EVOCA SPECULUM AstNode stmt AD CONIURA parser_parse_statement_source("1 + 2", "stmt.cct")
  SI (*stmt).kind != AST_EXPR_STMT
    REDDE 41
  FIN SI
  SI (*(*stmt).left).kind != AST_BINARY_OP VEL (*(*stmt).left).operator_kind != TK_PLUS
    REDDE 42
  FIN SI
  CONIURA ast_node_free(stmt)
  REDDE 0
EXPLICIT RITUALE
EXPLICIT grimoire
