INCIPIT grimoire "args_arg_basic_17a2"

ADVOCARE "cct/args.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  SI CONIURA argc() >= 3
    EVOCA VERBUM a AD CONIURA arg(1)
    EVOCA VERBUM b AD CONIURA arg(2)
    SI CONIURA compare(a, "alpha") == 0
      SI CONIURA compare(b, "beta") == 0
        REDDE 0
      FIN SI
    FIN SI
  FIN SI
  REDDE 1
EXPLICIT RITUALE

EXPLICIT grimoire
