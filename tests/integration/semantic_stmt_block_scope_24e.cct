INCIPIT grimoire "semantic_stmt_block_scope_24e"

ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_context.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_stmt.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM SemanticContext ctx AD CONIURA semantic_context_new("block_scope.cct")
  EVOCA SPECULUM AstNode block AD CONIURA ast_make_block(1, 1)
  CONIURA ast_append_statement(block, CONIURA ast_make_evoca("x", CONIURA ast_make_type("REX", 1, 7), CONIURA ast_make_literal_int("1", 1, 15), 1, 3))
  CONIURA semantic_analyze_stmt(ctx, block)

  SI CONIURA semantic_had_error(ctx)
    REDDE 41
  FIN SI
  SI CONIURA semantic_lookup_local(ctx, "x") != CONIURA semantic_invalid_id()
    REDDE 42
  FIN SI

  CONIURA semantic_context_free(ctx)
  CONIURA ast_node_free(block)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
