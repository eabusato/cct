INCIPIT grimoire "set_basic_12d1"

ADVOCARE "cct/set.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL s AD CONIURA set_init GENUS(REX)()

  CONIURA set_insert GENUS(REX)(s, 10)
  CONIURA set_insert GENUS(REX)(s, 20)
  CONIURA set_insert GENUS(REX)(s, 30)
  CONIURA set_insert GENUS(REX)(s, 20)

  SI CONIURA set_len GENUS(REX)(s) != 3
    CONIURA set_free GENUS(REX)(s)
    REDDE 51
  FIN SI

  SI NON CONIURA set_contains GENUS(REX)(s, 20)
    CONIURA set_free GENUS(REX)(s)
    REDDE 52
  FIN SI

  SI CONIURA set_contains GENUS(REX)(s, 99)
    CONIURA set_free GENUS(REX)(s)
    REDDE 53
  FIN SI

  CONIURA set_free GENUS(REX)(s)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
