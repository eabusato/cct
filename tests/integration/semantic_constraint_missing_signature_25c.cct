INCIPIT grimoire "semantic_constraint_missing_signature_25c"

ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/parser.cct"
ADVOCARE "../../src/bootstrap/parser/parse_expr.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_context.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_expr.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_register.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_symbol.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"p\" PACTUM Forma RITUALE medir() REDDE REX FIN PACTUM SIGILLUM Pixel valor: REX FIN SIGILLUM RITUALE usar GENUS(T PACTUM Forma)(T valor) REDDE NIHIL REDDE EXPLICIT RITUALE EXPLICIT grimoire"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(src, "missing_sig_25c.cct")
  EVOCA SPECULUM SemanticContext ctx AD CONIURA semantic_context_new("missing_sig_25c.cct")
  CONIURA semantic_register_program(ctx, program)

  EVOCA REX pixel_id AD CONIURA semantic_lookup_global(ctx, "Pixel")
  EVOCA SPECULUM SemanticSymbol pixel_sym AD CONIURA semantic_symbol_at(ctx, pixel_id)
  CONIURA semantic_define(ctx, SEM_SYMBOL_VARIABLE, "p", (*pixel_sym).type_id, 1, 1)

  EVOCA SPECULUM AstNode expr AD CONIURA parser_parse_expression_source("usar GENUS(Pixel)(p)", "expr.cct")
  EVOCA REX type_id AD CONIURA semantic_analyze_expr(ctx, expr)
  SI type_id != (*ctx).type_error
    REDDE 41
  FIN SI
  SI CONIURA compare((*ctx).last_error_message, "type argument 'Pixel' does not satisfy constraint 'T PACTUM Forma'") != 0
    REDDE 42
  FIN SI

  CONIURA ast_node_free(expr)
  CONIURA semantic_context_free(ctx)
  CONIURA ast_program_free(program)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
