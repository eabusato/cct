INCIPIT grimoire "image_host_wrapper_32i"

ADVOCARE "cct/image_ops.cct"

RITUALE main() REDDE REX
  EVOCA Image img AD CONIURA image_load("tests/integration/phase32i_assets/sample_32i.gif")
  EVOCA ImageDimensions dims AD CONIURA image_get_dimensions(img)
  SI NON CONIURA image_is_valid(img)
    REDDE 1
  FIN SI
  SI dims.width != 48 VEL dims.height != 36
    CONIURA image_free(img)
    REDDE 2
  FIN SI
  CONIURA image_free(img)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
