INCIPIT grimoire "image_load_dimensions_32i"

ADVOCARE "cct/image_ops.cct"

RITUALE main() REDDE REX
  EVOCA Image img AD CONIURA image_load("tests/integration/phase32i_assets/sample_32i.png")
  SI NON CONIURA image_is_valid(img)
    REDDE 1
  FIN SI
  SI img.width != 48 VEL img.height != 36
    CONIURA image_free(img)
    REDDE 2
  FIN SI
  SI img.formato != ImgPNG
    CONIURA image_free(img)
    REDDE 3
  FIN SI
  SI img.channels < 3
    CONIURA image_free(img)
    REDDE 4
  FIN SI
  CONIURA image_free(img)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
