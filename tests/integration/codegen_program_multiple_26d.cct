INCIPIT grimoire "codegen_program_multiple_26d"

ADVOCARE "../../src/bootstrap/codegen/codegen_decl.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM AstProgram program AD CONIURA ast_program_new()
  EVOCA SPECULUM AstNode body_a AD CONIURA ast_make_block(1, 1)
  EVOCA SPECULUM AstNode body_b AD CONIURA ast_make_block(1, 1)
  CONIURA ast_append_statement(body_a, CONIURA ast_make_redde(CONIURA ast_make_literal_int("1", 1, 1), 1, 1))
  CONIURA ast_append_statement(body_b, CONIURA ast_make_redde(CONIURA ast_make_literal_int("2", 1, 1), 1, 1))
  CONIURA ast_program_append_decl(program, CONIURA ast_make_rituale("a", CONIURA ast_make_type("REX", 1, 1), body_a, 1, 1))
  CONIURA ast_program_append_decl(program, CONIURA ast_make_rituale("b", CONIURA ast_make_type("REX", 1, 1), body_b, 1, 1))
  EVOCA VERBUM out AD CONIURA codegen_generate_program(program, "prog.cct")
  EVOCA REX rc AD 0
  SI NON CONIURA contains(out, "long long cct_boot_rit_a_0(void);")
    VINCIRE rc AD 1
  FIN SI
  SI NON CONIURA contains(out, "long long cct_boot_rit_b_1(void);")
    VINCIRE rc AD 2
  FIN SI
  SI NON CONIURA contains(out, "return 1;")
    VINCIRE rc AD 3
  FIN SI
  SI NON CONIURA contains(out, "return 2;")
    VINCIRE rc AD 4
  FIN SI
  DIMITTE out
  CONIURA ast_program_free(program)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
