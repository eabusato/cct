INCIPIT grimoire "semantic_register_pactum_24c"

ADVOCARE "../../src/bootstrap/parser/parser.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_context.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_register.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_symbol.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"p\" PACTUM Printable RITUALE render() REDDE VERBUM; FIN PACTUM EXPLICIT grimoire"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(src, "pactum.cct")
  EVOCA SPECULUM SemanticContext ctx AD CONIURA semantic_context_new("pactum.cct")
  CONIURA semantic_register_program(ctx, program)

  EVOCA REX sym_id AD CONIURA semantic_lookup_global(ctx, "Printable")
  SI sym_id == CONIURA semantic_invalid_id()
    REDDE 41
  FIN SI
  EVOCA SPECULUM SemanticSymbol sym AD CONIURA semantic_symbol_at(ctx, sym_id)
  SI (*sym).kind != SEM_SYMBOL_PACTUM
    REDDE 42
  FIN SI
  SI (*(*sym).decl_node).kind != AST_PACTUM
    REDDE 43
  FIN SI

  CONIURA semantic_context_free(ctx)
  CONIURA ast_program_free(program)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
