INCIPIT grimoire "signal_sigterm_shutdown_34d"

ADVOCARE "cct/result.cct"
ADVOCARE "cct/signal.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL installed AD CONIURA signal_install_default_handlers()
  SI CONIURA result_is_err GENUS(REX, SignalError)(installed)
    REDDE 1
  FIN SI

  CONIURA signal_clear_last_event()
  CONIURA signal_raise_self(SIGNAL_SIGTERM)
  EVOCA SignalEvent event AD CONIURA signal_poll()
  SI event.kind != SIGNAL_SIGTERM
    REDDE 2
  FIN SI
  SI NON event.requests_shutdown
    REDDE 3
  FIN SI
  SI NON CONIURA signal_check_shutdown()
    REDDE 4
  FIN SI
  SI NON CONIURA signal_received_sigterm()
    REDDE 5
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
