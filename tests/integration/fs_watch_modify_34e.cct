INCIPIT grimoire "fs_watch_modify_34e"

ADVOCARE "cct/fs.cct"
ADVOCARE "cct/fs_watch.cct"
ADVOCARE "cct/time.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM path AD "tests/.tmp/fs_watch_modify_34e.txt"
  CONIURA write_all(path, "v1")
  EVOCA FsWatch watch AD CONIURA fs_watch_open(path)
  CONIURA sleep_ms(1100)
  CONIURA write_all(path, "v2")
  EVOCA FsWatchEvent event AD CONIURA fs_watch_poll(SPECULUM watch)
  CONIURA delete_file(path)
  SI event.kind != WATCH_MODIFY
    REDDE 1
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
