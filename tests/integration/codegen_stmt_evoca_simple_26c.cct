INCIPIT grimoire "codegen_stmt_evoca_simple_26c"

ADVOCARE "../../src/bootstrap/codegen/codegen_context.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen_stmt.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM CodegenContext ctx AD CONIURA codegen_context_new("evoca.cct")
  EVOCA SPECULUM AstNode stmt AD CONIURA ast_make_evoca_no_init("x", CONIURA ast_make_type("REX", 1, 1), 1, 1)
  CONIURA codegen_emit_stmt(ctx, stmt)
  EVOCA VERBUM out AD CONIURA codegen_output(ctx)
  EVOCA REX rc AD 0
  SI CONIURA compare(out, "long long x;\n") != 0
    VINCIRE rc AD 1
  FIN SI
  SI CONIURA compare(CONIURA codegen_lookup_local_c_name(ctx, "x"), "x") != 0
    VINCIRE rc AD 2
  FIN SI
  DIMITTE out
  CONIURA ast_node_free(stmt)
  CONIURA codegen_context_free(ctx)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
