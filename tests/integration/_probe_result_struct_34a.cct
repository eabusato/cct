INCIPIT grimoire "_probe_result_struct_34a"
ADVOCARE "cct/result.cct"
SIGILLUM ErrX
  mensagem: VERBUM
FIN SIGILLUM
RITUALE ok() REDDE SPECULUM NIHIL
  REDDE CONIURA Ok GENUS(REX, ErrX)(0)
EXPLICIT RITUALE
RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL r AD CONIURA ok()
  SI CONIURA result_is_ok GENUS(REX, ErrX)(r)
    REDDE 0
  FIN SI
  REDDE 1
EXPLICIT RITUALE
EXPLICIT grimoire
