INCIPIT grimoire "parse_rituale_genus_single_23b"
ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/parser/parser.cct"
RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"p\" RITUALE ident GENUS(T)(T value) REDDE T REDDE value EXPLICIT RITUALE EXPLICIT grimoire"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(src, "m.cct")
  EVOCA SPECULUM AstNode rit AD CONIURA ast_node_list_get((*program).declarations, 0)
  SI CONIURA ast_node_list_len((*rit).type_params) != 1
    REDDE 41
  FIN SI
  EVOCA SPECULUM AstNode param AD CONIURA ast_node_list_get((*rit).type_params, 0)
  SI CONIURA compare((*param).name, "T") != 0
    REDDE 42
  FIN SI
  SI CONIURA compare((*(*rit).return_type).type_name, "T") != 0
    REDDE 43
  FIN SI
  CONIURA ast_program_free(program)
  REDDE 0
EXPLICIT RITUALE
EXPLICIT grimoire
