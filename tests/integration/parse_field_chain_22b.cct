INCIPIT grimoire "parse_field_chain_22b"

ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/parser/parse_expr.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM AstNode expr AD CONIURA parser_parse_expression_source("obj.a.b", "expr.cct")

  SI (*expr).kind != AST_FIELD_ACCESS VEL CONIURA compare((*expr).name, "b") != 0
    REDDE 41
  FIN SI
  SI (*(*expr).left).kind != AST_FIELD_ACCESS VEL CONIURA compare((*(*expr).left).name, "a") != 0
    REDDE 42
  FIN SI
  SI CONIURA compare((*(*(*expr).left).left).name, "obj") != 0
    REDDE 43
  FIN SI

  CONIURA ast_node_free(expr)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
