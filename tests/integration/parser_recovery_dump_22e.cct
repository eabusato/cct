INCIPIT grimoire "parser_recovery_dump_22e"
ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/parser.cct"
RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"probe\"\nEVOCA REX x AD 1\nSIGILLUM Pair\n  left: REX\nFIN SIGILLUM\nEXPLICIT grimoire\n"
  EVOCA VERBUM dump AD CONIURA parser_dump_program_source(src, "m.cct")
  SI NON CONIURA contains(dump, "IMPORT (line 2, col 1)")
    REDDE 41
  FIN SI
  SI NON CONIURA contains(dump, "Filename: \"<error>\"")
    REDDE 42
  FIN SI
  SI NON CONIURA contains(dump, "SIGILLUM (line 3, col 1)")
    REDDE 43
  FIN SI
  SI NON CONIURA contains(dump, "Name: Pair")
    REDDE 44
  FIN SI
  REDDE 0
EXPLICIT RITUALE
EXPLICIT grimoire
