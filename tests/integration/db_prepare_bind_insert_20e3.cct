INCIPIT grimoire "db_prepare_bind_insert_20e3"

ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL db AD CONIURA db_open(":memory:")
  CONIURA db_exec(db, "CREATE TABLE items(id INTEGER, nome TEXT, preco REAL);")

  EVOCA SPECULUM NIHIL stmt AD CONIURA db_prepare(db, "INSERT INTO items(id, nome, preco) VALUES(?1, ?2, ?3);")
  CONIURA stmt_bind_int(stmt, 1, 1)
  CONIURA stmt_bind_text(stmt, 2, "alpha")
  CONIURA stmt_bind_real(stmt, 3, 1.5)
  SI NON CONIURA stmt_step(stmt)
    REDDE 1
  FIN SI

  CONIURA stmt_reset(stmt)
  CONIURA stmt_bind_int(stmt, 1, 2)
  CONIURA stmt_bind_text(stmt, 2, "beta")
  CONIURA stmt_bind_real(stmt, 3, 2.25)
  SI NON CONIURA stmt_step(stmt)
    REDDE 2
  FIN SI
  CONIURA stmt_finalize(stmt)

  EVOCA SPECULUM NIHIL rows AD CONIURA db_query(db, "SELECT id, nome, preco FROM items ORDER BY id;")
  SI NON CONIURA rows_next(rows)
    REDDE 3
  FIN SI
  SI CONIURA rows_get_int(rows, 0) != 1 VEL CONIURA compare(CONIURA rows_get_text(rows, 1), "alpha") != 0 VEL CONIURA rows_get_real(rows, 2) != 1.5
    REDDE 4
  FIN SI
  SI NON CONIURA rows_next(rows)
    REDDE 5
  FIN SI
  SI CONIURA rows_get_int(rows, 0) != 2 VEL CONIURA compare(CONIURA rows_get_text(rows, 1), "beta") != 0 VEL CONIURA rows_get_real(rows, 2) != 2.25
    REDDE 6
  FIN SI
  SI CONIURA rows_next(rows)
    REDDE 7
  FIN SI

  CONIURA rows_close(rows)
  CONIURA db_close(db)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
