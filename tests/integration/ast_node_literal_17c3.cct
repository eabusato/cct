INCIPIT grimoire "ast_node_literal_17c3"

ADVOCARE "cct/ast_node.cct"
ADVOCARE "cct/variant.cct"

RITUALE main() REDDE REX
  EVOCA AstLiteralInt lit
  VINCIRE lit.valor AD 42
  EVOCA Variant n AD CONIURA ast_make_literal_int(SPECULUM lit)

  SI CONIURA ast_is_literal_int(n) == VERUM
    EVOCA SPECULUM AstLiteralInt p AD CONIURA ast_as_literal_int(n)
    SI (*p).valor == 42
      REDDE 0
    FIN SI
  FIN SI

  REDDE 1
EXPLICIT RITUALE

EXPLICIT grimoire
