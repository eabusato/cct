INCIPIT grimoire "parser_dump_sigillum_genus_23b"
ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/parser.cct"
RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"p\"\nSIGILLUM Caixa GENUS(T)\n  value: Envelope GENUS(T)\nFIN SIGILLUM\nEXPLICIT grimoire\n"
  EVOCA VERBUM dump AD CONIURA parser_dump_program_source(src, "m.cct")
  SI NON CONIURA contains(dump, "SIGILLUM (line 2, col 1)")
    REDDE 41
  FIN SI
  SI NON CONIURA contains(dump, "GENUS Parameters: (1)")
    REDDE 42
  FIN SI
  SI NON CONIURA contains(dump, "- T")
    REDDE 43
  FIN SI
  SI NON CONIURA contains(dump, "- value: Envelope GENUS(T)")
    REDDE 44
  FIN SI
  REDDE 0
EXPLICIT RITUALE
EXPLICIT grimoire
