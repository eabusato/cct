INCIPIT grimoire "codegen_elige_else_27d"

ADVOCARE "../../src/bootstrap/parser/parser.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen_decl.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM source AD "INCIPIT grimoire \"g\"\nRITUALE main() REDDE REX\n  EVOCA REX x AD 5\n  ELIGE x\n  CASUS 1:\n    REDDE 1\n  ALIOQUIN:\n    REDDE 9\n  FIN ELIGE\nEXPLICIT RITUALE\nEXPLICIT grimoire\n"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(source, "elige_else.cct")
  EVOCA VERBUM out AD CONIURA codegen_generate_program(program, "elige_else.cct")
  EVOCA REX rc AD 0
  SI NON CONIURA contains(out, "default:")
    VINCIRE rc AD 1
  FIN SI
  DIMITTE out
  CONIURA ast_program_free(program)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
