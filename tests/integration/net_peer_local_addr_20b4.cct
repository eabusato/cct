INCIPIT grimoire "net_peer_local_addr_20b4"

ADVOCARE "cct/fs.cct"
ADVOCARE "cct/net.cct"
ADVOCARE "cct/process.cct"
ADVOCARE "cct/socket.cct"
ADVOCARE "cct/time.cct"
ADVOCARE "cct/verbum.cct"

RITUALE cleanup_file(VERBUM path) REDDE NIHIL
  SI CONIURA exists(path)
    CONIURA delete_file(path)
  FIN SI
  REDDE
EXPLICIT RITUALE

RITUALE wait_for_file(VERBUM path, REX timeout_ms) REDDE VERUM
  EVOCA REX elapsed AD 0
  DUM elapsed < timeout_ms
    SI CONIURA exists(path)
      REDDE VERUM
    FIN SI
    CONIURA sleep_ms(20)
    VINCIRE elapsed AD elapsed + 20
  FIN DUM
  REDDE CONIURA exists(path)
EXPLICIT RITUALE

RITUALE addr_looks_valid(VERBUM addr) REDDE VERUM
  SI CONIURA len(addr) == 0
    REDDE FALSUM
  FIN SI
  SI CONIURA find(addr, ":") != -1
    REDDE VERUM
  FIN SI
  SI CONIURA starts_with(addr, "unix")
    REDDE VERUM
  FIN SI
  REDDE FALSUM
EXPLICIT RITUALE

RITUALE main() REDDE REX
  EVOCA VERBUM ready AD "tests/.tmp/net_peer_local_addr_20b4.ready"
  EVOCA VERBUM done AD "tests/.tmp/net_peer_local_addr_20b4.done"
  EVOCA VERBUM log AD "tests/.tmp/net_peer_local_addr_20b4.server.log"

  CONIURA cleanup_file(ready)
  CONIURA cleanup_file(done)
  CONIURA cleanup_file(log)

  SI CONIURA run("tests/integration/net_peer_local_addr_20b4_server >tests/.tmp/net_peer_local_addr_20b4.server.log 2>&1 &") != 0
    REDDE 1
  FIN SI

  SI NON CONIURA wait_for_file(ready, 2000)
    REDDE 2
  FIN SI

  SI CONIURA compare(CONIURA read_all(ready), "skip") == 0
    REDDE 0
  FIN SI

  EVOCA SPECULUM NIHIL client AD CONIURA tcp_connect("127.0.0.1", 22316)
  EVOCA VERBUM peer AD CONIURA sock_peer_addr(client)
  EVOCA VERBUM local AD CONIURA sock_local_addr(client)

  SI NON CONIURA addr_looks_valid(peer)
    REDDE 3
  FIN SI
  SI NON CONIURA addr_looks_valid(local)
    REDDE 4
  FIN SI
  SI CONIURA compare(CONIURA sock_last_error(), "") != 0
    REDDE 5
  FIN SI

  EVOCA VERBUM ack AD CONIURA net_read_line(client)
  SI CONIURA compare(ack, "ok") != 0
    REDDE 6
  FIN SI

  CONIURA net_close(client)

  SI NON CONIURA wait_for_file(done, 2000)
    REDDE 7
  FIN SI
  SI CONIURA compare(CONIURA read_all(done), "ok") != 0
    REDDE 8
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
