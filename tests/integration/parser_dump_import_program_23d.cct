INCIPIT grimoire "parser_dump_import_program_23d"
ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/parser.cct"
RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"p\"\nADVOCARE \"./a.cct\"\nADVOCARE \"./b.cct\"\nRITUALE main() REDDE NIHIL\n  REDDE\nEXPLICIT RITUALE\nEXPLICIT grimoire\n"
  EVOCA VERBUM dump AD CONIURA parser_dump_program_source(src, "entry.cct")
  SI NON CONIURA contains(dump, "Filename: \"./a.cct\"")
    REDDE 41
  FIN SI
  SI NON CONIURA contains(dump, "Filename: \"./b.cct\"")
    REDDE 42
  FIN SI
  REDDE 0
EXPLICIT RITUALE
EXPLICIT grimoire
