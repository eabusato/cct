INCIPIT grimoire "fs_watch_kind_map_34e"

ADVOCARE "cct/fs_watch.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  SI CONIURA compare(CONIURA fs_watch_kind_to_string(WATCH_CREATE), "create") != 0
    REDDE 1
  FIN SI
  SI CONIURA compare(CONIURA fs_watch_kind_to_string(WATCH_NONE), "none") != 0
    REDDE 2
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
