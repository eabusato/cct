INCIPIT grimoire "selfhost_csv_parse_30c"
ADVOCARE "cct/csv.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL row AD CONIURA csv_parse_row("alpha,beta,gamma")
  EVOCA SPECULUM VERBUM first AD CONIURA fluxus_get(row, 0)
  EVOCA SPECULUM VERBUM third AD CONIURA fluxus_get(row, 2)
  SI CONIURA fluxus_len(row) == 3 ET CONIURA compare(*first, "alpha") == 0 ET CONIURA compare(*third, "gamma") == 0
    REDDE 35
  FIN SI
  REDDE 1
EXPLICIT RITUALE

EXPLICIT grimoire
