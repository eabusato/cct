INCIPIT grimoire "lexer_error_33b"

ADVOCARE "cct/lexer_util.cct"
ADVOCARE "cct/result.cct"

RITUALE main() REDDE REX
  EVOCA Scanner s AD CONIURA scanner_new("x")
  EVOCA SPECULUM NIHIL res AD CONIURA scanner_expect_char(SPECULUM s, 121)
  SI NON CONIURA result_is_err GENUS(REX, ScanError)(res)
    REDDE 1
  FIN SI

  EVOCA ScanError err AD CONIURA result_unwrap_err GENUS(REX, ScanError)(res)
  SI err.line != 1 VEL err.column != 1
    REDDE 1
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
