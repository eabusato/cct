INCIPIT grimoire "codegen_ordo_payload_local_27c"

ADVOCARE "../../src/bootstrap/codegen/codegen_decl.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM AstProgram program AD CONIURA ast_program_new()
  EVOCA SPECULUM AstNode ord AD CONIURA ast_make_ordo("Option", 1, 1)
  EVOCA SPECULUM AstNode some_item AD CONIURA ast_make_enum_item_no_value("Some", 1, 1)
  CONIURA ast_append_field(some_item, CONIURA ast_make_field("value", CONIURA ast_make_type("REX", 1, 1), 1, 1))
  CONIURA ast_append_item(ord, some_item)
  CONIURA ast_program_append_decl(program, ord)

  EVOCA SPECULUM AstNode body AD CONIURA ast_make_block(2, 1)
  EVOCA SPECULUM AstNode ctor AD CONIURA ast_make_call(CONIURA ast_make_identifier("Some", 2, 1), 2, 1)
  CONIURA ast_append_argument(ctor, CONIURA ast_make_literal_int("1", 2, 6))
  CONIURA ast_append_statement(body, CONIURA ast_make_evoca("opt", CONIURA ast_make_type("Option", 2, 1), ctor, 2, 1))
  CONIURA ast_append_statement(body, CONIURA ast_make_redde(CONIURA ast_make_literal_int("0", 3, 1), 3, 1))
  CONIURA ast_program_append_decl(program, CONIURA ast_make_rituale("main", CONIURA ast_make_type("REX", 2, 1), body, 2, 1))

  EVOCA VERBUM out AD CONIURA codegen_generate_program(program, "ordo_payload_local.cct")
  EVOCA REX rc AD 0
  SI NON CONIURA contains(out, "Option opt") ET NON CONIURA contains(out, "cct_boot_ord_Option opt")
    VINCIRE rc AD 1
  FIN SI
  SI NON CONIURA contains(out, ".__payload.Some = { 1 }")
    VINCIRE rc AD 2
  FIN SI
  DIMITTE out
  CONIURA ast_program_free(program)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
