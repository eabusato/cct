INCIPIT grimoire "codegen_ordo_payload_mixed_27c"

ADVOCARE "../../src/bootstrap/codegen/codegen_decl.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM AstProgram program AD CONIURA ast_program_new()
  EVOCA SPECULUM AstNode ord AD CONIURA ast_make_ordo("Result", 1, 1)
  EVOCA SPECULUM AstNode ok_item AD CONIURA ast_make_enum_item_no_value("Ok", 1, 1)
  EVOCA SPECULUM AstNode err_item AD CONIURA ast_make_enum_item_no_value("Err", 2, 1)
  CONIURA ast_append_field(ok_item, CONIURA ast_make_field("code", CONIURA ast_make_type("REX", 1, 1), 1, 1))
  CONIURA ast_append_item(ord, ok_item)
  CONIURA ast_append_item(ord, err_item)
  CONIURA ast_program_append_decl(program, ord)
  CONIURA ast_program_append_decl(program, CONIURA ast_make_rituale("main", CONIURA ast_make_type("REX", 3, 1), CONIURA ast_make_block(3, 1), 3, 1))
  EVOCA VERBUM out AD CONIURA codegen_generate_program(program, "ordo_payload_mixed.cct")
  EVOCA REX rc AD 0
  SI NON CONIURA contains(out, "cct_boot_tag_Result__Ok")
    VINCIRE rc AD 1
  FIN SI
  SI NON CONIURA contains(out, "cct_boot_tag_Result__Err")
    VINCIRE rc AD 2
  FIN SI
  SI NON CONIURA contains(out, "} Ok;")
    VINCIRE rc AD 3
  FIN SI
  DIMITTE out
  CONIURA ast_program_free(program)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
