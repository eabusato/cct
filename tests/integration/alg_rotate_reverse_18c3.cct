INCIPIT grimoire "alg_rotate_reverse_18c3"

ADVOCARE "cct/alg.cct"

RITUALE main() REDDE REX
  EVOCA SERIES REX[5] a
  VINCIRE a[0] AD 1
  VINCIRE a[1] AD 2
  VINCIRE a[2] AD 3
  VINCIRE a[3] AD 4
  VINCIRE a[4] AD 5

  CONIURA alg_rotate(SPECULUM a[0], 5, 2)
  SI a[0] != 3
    REDDE 1
  FIN SI
  SI a[1] != 4
    REDDE 2
  FIN SI
  SI a[2] != 5
    REDDE 3
  FIN SI
  SI a[3] != 1
    REDDE 4
  FIN SI
  SI a[4] != 2
    REDDE 5
  FIN SI

  CONIURA alg_reverse(SPECULUM a[0], 5)
  SI a[0] != 2
    REDDE 6
  FIN SI
  SI a[1] != 1
    REDDE 7
  FIN SI
  SI a[2] != 5
    REDDE 8
  FIN SI
  SI a[3] != 4
    REDDE 9
  FIN SI
  SI a[4] != 3
    REDDE 10
  FIN SI

  EVOCA SERIES REX[4] b
  VINCIRE b[0] AD 1
  VINCIRE b[1] AD 2
  VINCIRE b[2] AD 3
  VINCIRE b[3] AD 4

  CONIURA alg_rotate(SPECULUM b[0], 4, -1)
  SI b[0] != 4
    REDDE 11
  FIN SI
  SI b[1] != 1
    REDDE 12
  FIN SI
  SI b[2] != 2
    REDDE 13
  FIN SI
  SI b[3] != 3
    REDDE 14
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
