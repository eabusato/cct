INCIPIT grimoire "showcase_parse_math_random_11g"

ADVOCARE "cct/parse.cct"
ADVOCARE "cct/math.cct"
ADVOCARE "cct/random.cct"
ADVOCARE "cct/cmp.cct"

RITUALE main() REDDE REX
  CONIURA seed(1234)

  EVOCA REX n AD CONIURA parse_int("7")
  EVOCA UMBRA r AD CONIURA parse_real("2.5")
  EVOCA VERUM b AD CONIURA parse_bool("true")

  EVOCA REX a AD CONIURA abs(0 - n)
  EVOCA REX c AD CONIURA clamp(15, 0, 10)
  EVOCA REX ri AD CONIURA random_int(1, 3)
  EVOCA FLAMMA rf AD CONIURA random_real()

  SI b == VERUM
    SI CONIURA cmp_int(a, 7) == 0
      SI CONIURA cmp_real(r, 2.5) == 0
        SI c == 10
          SI ri >= 1
            SI ri <= 3
              SI rf >= 0.0
                SI rf < 1.0
                  REDDE 0
                FIN SI
              FIN SI
            FIN SI
          FIN SI
        FIN SI
      FIN SI
    FIN SI
  FIN SI

  REDDE 1
EXPLICIT RITUALE

EXPLICIT grimoire
