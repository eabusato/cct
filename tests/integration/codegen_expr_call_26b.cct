INCIPIT grimoire "codegen_expr_call_26b"

ADVOCARE "../../src/bootstrap/codegen/codegen_context.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen_expr.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM AstNode callee AD CONIURA ast_make_identifier("sum", 1, 1)
  EVOCA SPECULUM AstNode call AD CONIURA ast_make_call(callee, 1, 1)
  CONIURA ast_append_argument(call, CONIURA ast_make_literal_int("1", 1, 5))
  CONIURA ast_append_argument(call, CONIURA ast_make_literal_int("2", 1, 8))

  EVOCA SPECULUM CodegenContext ctx AD CONIURA codegen_context_new("call.cct")
  CONIURA codegen_emit_expr(ctx, call)
  EVOCA VERBUM out AD CONIURA codegen_output(ctx)
  EVOCA REX rc AD 0
  SI CONIURA compare(out, "cct_boot_rit_sum_0(1, 2)") != 0
    VINCIRE rc AD 1
  FIN SI
  SI CONIURA codegen_registered_rituale_count(ctx) != 1
    VINCIRE rc AD 2
  FIN SI
  DIMITTE out
  CONIURA ast_node_free(call)
  CONIURA codegen_context_free(ctx)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
