INCIPIT grimoire "parse_rituale_genus_constraint_23b"
ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/parser/parser.cct"
RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"p\" RITUALE ident GENUS(T, U PACTUM Forma)(T value, U other) REDDE U REDDE other EXPLICIT RITUALE EXPLICIT grimoire"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(src, "m.cct")
  EVOCA SPECULUM AstNode rit AD CONIURA ast_node_list_get((*program).declarations, 0)
  SI CONIURA ast_node_list_len((*rit).type_params) != 2
    REDDE 41
  FIN SI
  EVOCA SPECULUM AstNode second AD CONIURA ast_node_list_get((*rit).type_params, 1)
  SI NON (*second).has_type_expr
    REDDE 42
  FIN SI
  SI CONIURA compare((*second).name, "U") != 0
    REDDE 43
  FIN SI
  SI CONIURA compare((*(*second).type_expr).type_name, "Forma") != 0
    REDDE 44
  FIN SI
  CONIURA ast_program_free(program)
  REDDE 0
EXPLICIT RITUALE
EXPLICIT grimoire
