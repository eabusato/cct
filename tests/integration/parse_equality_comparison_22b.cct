INCIPIT grimoire "parse_equality_comparison_22b"

ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/lexer/token_type.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/parser/parse_expr.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM AstNode expr AD CONIURA parser_parse_expression_source("a < b == c", "expr.cct")

  SI (*expr).kind != AST_BINARY_OP VEL (*expr).operator_kind != TK_EQ_EQ
    REDDE 41
  FIN SI
  SI (*(*expr).left).kind != AST_BINARY_OP VEL (*(*expr).left).operator_kind != TK_LESS
    REDDE 42
  FIN SI
  SI CONIURA compare((*(*(*expr).left).left).name, "a") != 0 VEL CONIURA compare((*(*(*expr).left).right).name, "b") != 0
    REDDE 43
  FIN SI
  SI CONIURA compare((*(*expr).right).name, "c") != 0
    REDDE 44
  FIN SI

  CONIURA ast_node_free(expr)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
