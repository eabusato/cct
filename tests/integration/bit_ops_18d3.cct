INCIPIT grimoire "bit_ops_18d3"

ADVOCARE "cct/bit.cct"

RITUALE main() REDDE REX
  EVOCA REX n AD 0
  VINCIRE n AD CONIURA bit_set(n, 3)

  SI n != 8
    REDDE 1
  FIN SI

  SI NON CONIURA bit_get(n, 3)
    REDDE 2
  FIN SI

  SI CONIURA bit_get(n, 2)
    REDDE 3
  FIN SI

  VINCIRE n AD CONIURA bit_toggle(n, 3)
  SI n != 0
    REDDE 4
  FIN SI

  VINCIRE n AD CONIURA bit_set(n, 1)
  VINCIRE n AD CONIURA bit_set(n, 2)
  VINCIRE n AD CONIURA bit_clear(n, 1)
  SI n != 4
    REDDE 5
  FIN SI

  SI NON CONIURA parity(7)
    REDDE 6
  FIN SI

  SI CONIURA parity(6)
    REDDE 7
  FIN SI

  SI CONIURA bit_extract(45, 1, 3) != 6
    REDDE 8
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
