INCIPIT grimoire "image_crop_32i"

ADVOCARE "cct/image_ops.cct"

RITUALE main() REDDE REX
  EVOCA Image img AD CONIURA image_load("tests/integration/phase32i_assets/sample_32i.png")
  EVOCA Image cropped AD CONIURA image_crop(img, 10, 8, 20, 10)
  SI NON CONIURA image_is_valid(cropped)
    CONIURA image_free(img)
    REDDE 1
  FIN SI
  SI cropped.width != 20 VEL cropped.height != 10
    CONIURA image_free(cropped)
    CONIURA image_free(img)
    REDDE 2
  FIN SI
  CONIURA image_free(cropped)
  CONIURA image_free(img)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
