INCIPIT grimoire "codegen_ordo_local_decl_27b"

ADVOCARE "../../src/bootstrap/codegen/codegen_decl.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM AstProgram program AD CONIURA ast_program_new()
  EVOCA SPECULUM AstNode ord AD CONIURA ast_make_ordo("Cor", 1, 1)
  CONIURA ast_append_item(ord, CONIURA ast_make_enum_item_no_value("RUBER", 1, 1))
  CONIURA ast_program_append_decl(program, ord)

  EVOCA SPECULUM AstNode body AD CONIURA ast_make_block(2, 1)
  CONIURA ast_append_statement(body, CONIURA ast_make_evoca("estado", CONIURA ast_make_type("Cor", 2, 1), CONIURA ast_make_identifier("RUBER", 2, 1), 2, 1))
  CONIURA ast_append_statement(body, CONIURA ast_make_redde(CONIURA ast_make_literal_int("0", 3, 1), 3, 1))
  CONIURA ast_program_append_decl(program, CONIURA ast_make_rituale("main", CONIURA ast_make_type("REX", 2, 1), body, 2, 1))

  EVOCA VERBUM out AD CONIURA codegen_generate_program(program, "ordo_local.cct")
  EVOCA REX rc AD 0
  SI NON CONIURA contains(out, "cct_boot_ord_Cor estado = cct_boot_ord_Cor__RUBER;")
    VINCIRE rc AD 1
  FIN SI

  DIMITTE out
  CONIURA ast_program_free(program)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
