INCIPIT grimoire "alg_sum_min_max_18c3"

ADVOCARE "cct/alg.cct"

RITUALE main() REDDE REX
  EVOCA SERIES REX[4] ints
  VINCIRE ints[0] AD 1
  VINCIRE ints[1] AD 2
  VINCIRE ints[2] AD 3
  VINCIRE ints[3] AD 4

  EVOCA SERIES REX[4] mul
  VINCIRE mul[0] AD 2
  VINCIRE mul[1] AD 2
  VINCIRE mul[2] AD 2
  VINCIRE mul[3] AD 2

  EVOCA SERIES UMBRA[3] reals
  VINCIRE reals[0] AD 1.5
  VINCIRE reals[1] AD 2.0
  VINCIRE reals[2] AD -0.5

  EVOCA SERIES UMBRA[2] ra
  EVOCA SERIES UMBRA[2] rb
  VINCIRE ra[0] AD 1.0
  VINCIRE ra[1] AD 2.0
  VINCIRE rb[0] AD 0.5
  VINCIRE rb[1] AD 1.5

  SI CONIURA alg_sum(SPECULUM ints[0], 4) != 10
    REDDE 1
  FIN SI
  SI CONIURA alg_min(SPECULUM ints[0], 4) != 1
    REDDE 2
  FIN SI
  SI CONIURA alg_max(SPECULUM ints[0], 4) != 4
    REDDE 3
  FIN SI

  SI CONIURA alg_sum_real(SPECULUM reals[0], 3) != 3.0
    REDDE 4
  FIN SI
  SI CONIURA alg_min_real(SPECULUM reals[0], 3) != -0.5
    REDDE 5
  FIN SI
  SI CONIURA alg_max_real(SPECULUM reals[0], 3) != 2.0
    REDDE 6
  FIN SI

  SI CONIURA alg_dot_product(SPECULUM ints[0], SPECULUM mul[0], 4) != 20
    REDDE 7
  FIN SI

  SI CONIURA alg_dot_product_real(SPECULUM ra[0], SPECULUM rb[0], 2) != 3.5
    REDDE 8
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
