INCIPIT grimoire "failure_rethrow_chain"

RITUALE deep() REDDE REX
  IACE "deep-8b"
  REDDE 1
EXPLICIT RITUALE

RITUALE mid() REDDE REX
  TEMPTA
    REDDE CONIURA deep()
  CAPE FRACTUM erro
    IACE erro
  FIN TEMPTA
  REDDE 2
EXPLICIT RITUALE

RITUALE main() REDDE REX
  TEMPTA
    REDDE CONIURA mid()
  CAPE FRACTUM erro
    REDDE 33
  FIN TEMPTA
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
