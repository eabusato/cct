INCIPIT grimoire "semantic_generic_constraint_missing_25a"

ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/parser.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_context.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_register.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"p\" RITUALE usar GENUS(T PACTUM Forma)(T valor) REDDE NIHIL REDDE EXPLICIT RITUALE EXPLICIT grimoire"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(src, "constraint_missing.cct")
  EVOCA SPECULUM SemanticContext ctx AD CONIURA semantic_context_new("constraint_missing.cct")
  CONIURA semantic_register_program(ctx, program)

  SI (*ctx).had_error != VERUM
    REDDE 41
  FIN SI
  SI (*ctx).error_count != 1
    REDDE 42
  FIN SI
  SI CONIURA compare((*ctx).last_error_message, "unknown pactum constraint 'Forma'") != 0
    REDDE 43
  FIN SI

  CONIURA semantic_context_free(ctx)
  CONIURA ast_program_free(program)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
