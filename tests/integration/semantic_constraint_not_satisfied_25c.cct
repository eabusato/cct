INCIPIT grimoire "semantic_constraint_not_satisfied_25c"

ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/parser.cct"
ADVOCARE "../../src/bootstrap/parser/parse_expr.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_context.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_expr.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_register.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"p\" PACTUM Forma RITUALE medir() REDDE REX FIN PACTUM RITUALE usar GENUS(T PACTUM Forma)(T valor) REDDE NIHIL REDDE EXPLICIT RITUALE EXPLICIT grimoire"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(src, "constraint_fail_25c.cct")
  EVOCA SPECULUM SemanticContext ctx AD CONIURA semantic_context_new("constraint_fail_25c.cct")
  CONIURA semantic_register_program(ctx, program)

  EVOCA SPECULUM AstNode expr AD CONIURA parser_parse_expression_source("usar GENUS(REX)(1)", "expr.cct")
  EVOCA REX type_id AD CONIURA semantic_analyze_expr(ctx, expr)
  SI type_id != (*ctx).type_error
    REDDE 41
  FIN SI
  SI CONIURA compare((*ctx).last_error_message, "type argument 'REX' does not satisfy constraint 'T PACTUM Forma'") != 0
    REDDE 42
  FIN SI

  CONIURA ast_node_free(expr)
  CONIURA semantic_context_free(ctx)
  CONIURA ast_program_free(program)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
