INCIPIT grimoire "socket_timeout_20b1"

ADVOCARE "cct/fs.cct"
ADVOCARE "cct/process.cct"
ADVOCARE "cct/socket.cct"
ADVOCARE "cct/time.cct"
ADVOCARE "cct/verbum.cct"

RITUALE cleanup_file(VERBUM path) REDDE NIHIL
  SI CONIURA exists(path)
    CONIURA delete_file(path)
  FIN SI
  REDDE
EXPLICIT RITUALE

RITUALE wait_for_file(VERBUM path, REX timeout_ms) REDDE VERUM
  EVOCA REX elapsed AD 0
  DUM elapsed < timeout_ms
    SI CONIURA exists(path)
      REDDE VERUM
    FIN SI
    CONIURA sleep_ms(20)
    VINCIRE elapsed AD elapsed + 20
  FIN DUM
  REDDE CONIURA exists(path)
EXPLICIT RITUALE

RITUALE main() REDDE REX
  EVOCA VERBUM ready AD "tests/.tmp/socket_timeout_20b1.ready"
  EVOCA VERBUM done AD "tests/.tmp/socket_timeout_20b1.done"
  EVOCA VERBUM log AD "tests/.tmp/socket_timeout_20b1.server.log"

  CONIURA cleanup_file(ready)
  CONIURA cleanup_file(done)
  CONIURA cleanup_file(log)

  SI CONIURA run("tests/integration/socket_timeout_20b1_server >tests/.tmp/socket_timeout_20b1.server.log 2>&1 &") != 0
    REDDE 1
  FIN SI

  SI NON CONIURA wait_for_file(ready, 2000)
    REDDE 2
  FIN SI

  SI CONIURA compare(CONIURA read_all(ready), "skip") == 0
    REDDE 0
  FIN SI

  EVOCA SPECULUM NIHIL client AD CONIURA socket_tcp()
  CONIURA sock_connect(client, "127.0.0.1", 22302)
  CONIURA sock_set_timeout_ms(client, 50)

  EVOCA REX started AD CONIURA now_ms()
  EVOCA VERBUM got AD CONIURA sock_recv(client, 32)
  EVOCA REX elapsed AD CONIURA now_ms() - started

  SI CONIURA compare(got, "") != 0
    REDDE 3
  FIN SI

  SI elapsed < 20 VEL elapsed > 500
    REDDE 4
  FIN SI

  CONIURA sock_close(client)

  SI NON CONIURA wait_for_file(done, 2000)
    REDDE 5
  FIN SI

  SI CONIURA compare(CONIURA read_all(done), "ok") != 0
    REDDE 6
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
