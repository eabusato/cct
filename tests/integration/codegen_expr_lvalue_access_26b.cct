INCIPIT grimoire "codegen_expr_lvalue_access_26b"

ADVOCARE "../../src/bootstrap/codegen/codegen_context.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen_expr.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM AstNode obj AD CONIURA ast_make_identifier("state", 1, 1)
  EVOCA SPECULUM AstNode fld AD CONIURA ast_make_field_access(obj, "items", 1, 7)
  EVOCA SPECULUM AstNode idx AD CONIURA ast_make_index_access(fld, CONIURA ast_make_literal_int("0", 1, 13), 1, 12)
  EVOCA SPECULUM CodegenContext ctx AD CONIURA codegen_context_new("lvalue.cct")
  CONIURA codegen_emit_lvalue(ctx, idx)
  EVOCA VERBUM out AD CONIURA codegen_output(ctx)
  EVOCA REX rc AD 0
  SI CONIURA compare(out, "state.items[0]") != 0
    VINCIRE rc AD 1
  FIN SI
  DIMITTE out
  CONIURA ast_node_free(idx)
  CONIURA codegen_context_free(ctx)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
