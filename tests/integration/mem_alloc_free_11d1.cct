INCIPIT grimoire "mem_alloc_free_11d1"

ADVOCARE "cct/mem.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM REX ptr
  VINCIRE ptr AD CONIURA alloc(4 * MENSURA(REX))
  VINCIRE ptr[0] AD 7
  VINCIRE ptr[1] AD 35
  EVOCA REX out AD ptr[1]
  CONIURA free(ptr)
  REDDE out
EXPLICIT RITUALE

EXPLICIT grimoire
