INCIPIT grimoire "semantic_expr_nested_field_assignment_24d"

ADVOCARE "../../src/bootstrap/parser/parser.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_context.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_kind.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_register.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_symbol.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_expr.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"p\" SIGILLUM Inner valor: REX FIN SIGILLUM SIGILLUM Outer inner: Inner FIN SIGILLUM EXPLICIT grimoire"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(src, "nested_field_assignment.cct")
  EVOCA SPECULUM SemanticContext ctx AD CONIURA semantic_context_new("nested_field_assignment.cct")
  CONIURA semantic_register_program(ctx, program)

  EVOCA REX outer_sym_id AD CONIURA semantic_lookup_global(ctx, "Outer")
  EVOCA SPECULUM SemanticSymbol outer_sym AD CONIURA semantic_symbol_at(ctx, outer_sym_id)
  SI CONIURA semantic_define(ctx, SEM_SYMBOL_VARIABLE, "obj", (*outer_sym).payload_type_id, 1, 1) == CONIURA semantic_invalid_id()
    REDDE 41
  FIN SI

  EVOCA SPECULUM AstNode base AD CONIURA ast_make_identifier("obj", 1, 1)
  EVOCA SPECULUM AstNode inner_field AD CONIURA ast_make_field_access(base, "inner", 1, 4)
  EVOCA SPECULUM AstNode value_field AD CONIURA ast_make_field_access(inner_field, "valor", 1, 10)
  EVOCA SPECULUM AstNode assign AD CONIURA ast_make_vincire(value_field, CONIURA ast_make_literal_int("1", 1, 18), 1, 16)

  EVOCA REX type_id AD CONIURA semantic_analyze_expr(ctx, assign)
  SI type_id != (*ctx).type_rex
    REDDE 42
  FIN SI
  SI CONIURA semantic_had_error(ctx)
    REDDE 43
  FIN SI

  CONIURA semantic_context_free(ctx)
  CONIURA ast_program_free(program)
  CONIURA ast_node_free(assign)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
