INCIPIT grimoire "obj_storage_delete_40c"

ADVOCARE "cct/env.cct"
ADVOCARE "cct/object_storage.cct"
ADVOCARE "cct/result.cct"

RITUALE obj_client_from_env() REDDE SPECULUM NIHIL
  EVOCA ObjectStorageOptions opts AD CONIURA object_storage_default_options(
    CONIURA getenv("APP_OBJ_STORAGE_ENDPOINT"),
    CONIURA getenv("APP_OBJ_STORAGE_BUCKET"),
    CONIURA getenv("APP_OBJ_STORAGE_ACCESS_KEY"),
    CONIURA getenv("APP_OBJ_STORAGE_SECRET_KEY")
  )
  VINCIRE opts.region AD CONIURA getenv("APP_OBJ_STORAGE_REGION")
  REDDE CONIURA object_storage_open(opts)
EXPLICIT RITUALE

RITUALE main() REDDE REX
  SI NON CONIURA has_env("APP_OBJ_STORAGE_ENDPOINT")
    REDDE 0
  FIN SI

  EVOCA SPECULUM NIHIL opened AD CONIURA obj_client_from_env()
  SI NON CONIURA result_is_ok GENUS(ObjectStorageClient, VERBUM)(opened)
    REDDE 170
  FIN SI
  EVOCA ObjectStorageClient client AD CONIURA result_unwrap GENUS(ObjectStorageClient, VERBUM)(opened)
  SI NON CONIURA result_is_ok GENUS(ObjectRef, VERBUM)(CONIURA object_storage_put_text(client, "phase40c/delete.txt", "gone", "text/plain"))
    REDDE 171
  FIN SI
  SI NON CONIURA result_is_ok GENUS(REX, VERBUM)(CONIURA object_storage_delete(client, "phase40c/delete.txt"))
    REDDE 172
  FIN SI
  EVOCA SPECULUM NIHIL exists_res AD CONIURA object_storage_exists(client, "phase40c/delete.txt")
  SI NON CONIURA result_is_ok GENUS(VERUM, VERBUM)(exists_res)
    REDDE 173
  FIN SI
  SI CONIURA result_unwrap GENUS(VERUM, VERBUM)(exists_res)
    REDDE 174
  FIN SI
  CONIURA object_storage_close(SPECULUM client)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
