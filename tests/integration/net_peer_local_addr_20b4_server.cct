INCIPIT grimoire "net_peer_local_addr_20b4_server"

ADVOCARE "cct/fs.cct"
ADVOCARE "cct/net.cct"
ADVOCARE "cct/socket.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM ready AD "tests/.tmp/net_peer_local_addr_20b4.ready"
  EVOCA VERBUM done AD "tests/.tmp/net_peer_local_addr_20b4.done"
  TEMPTA
    EVOCA SPECULUM NIHIL listener AD CONIURA tcp_listen("", 22316)
    CONIURA write_all(ready, "ready")

    EVOCA SPECULUM NIHIL client AD CONIURA tcp_accept(listener)
    EVOCA VERBUM peer AD CONIURA sock_peer_addr(client)
    EVOCA VERBUM local AD CONIURA sock_local_addr(client)

    SI CONIURA len(peer) == 0 VEL CONIURA len(local) == 0
      REDDE 10
    FIN SI

    SI CONIURA compare(CONIURA sock_last_error(), "") != 0
      REDDE 11
    FIN SI

    CONIURA net_write_line(client, "ok")
    CONIURA net_close(client)
    CONIURA net_close(listener)
    CONIURA write_all(done, "ok")
    REDDE 0
  CAPE FRACTUM erro
    EVOCA VERBUM msg AD OBSECRO fractum_to_verbum(erro)
    SI CONIURA compare(msg, "sock_bind falhou") == 0 VEL CONIURA compare(msg, "socket tcp create falhou") == 0
      CONIURA write_all(ready, "skip")
      CONIURA write_all(done, "skip")
      REDDE 0
    FIN SI
    REDDE 90
  FIN TEMPTA
  REDDE 91
EXPLICIT RITUALE

EXPLICIT grimoire
