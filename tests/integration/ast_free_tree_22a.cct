INCIPIT grimoire "ast_free_tree_22a"

ADVOCARE "../../src/bootstrap/parser/ast.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM AstProgram program AD CONIURA ast_program_new()
  EVOCA SPECULUM AstNode body AD CONIURA ast_make_block(2, 1)
  EVOCA SPECULUM AstNode call AD CONIURA ast_make_call(CONIURA ast_make_identifier("soma", 3, 3), 3, 3)
  CONIURA ast_append_argument(call, CONIURA ast_make_literal_int("1", 3, 8))
  CONIURA ast_append_argument(call, CONIURA ast_make_literal_int("2", 3, 11))
  CONIURA ast_append_statement(body, CONIURA ast_make_expr_stmt(call, 3, 3))
  CONIURA ast_append_statement(body, CONIURA ast_make_redde(CONIURA ast_make_identifier("resultado", 4, 9), 4, 3))
  CONIURA ast_program_append_decl(program, CONIURA ast_make_rituale("main", CONIURA ast_make_type("REX", 1, 20), body, 1, 1))
  CONIURA ast_program_append_decl(program, CONIURA ast_make_import("cct/io.cct", 1, 1))

  SI CONIURA ast_node_list_len((*program).declarations) != 2
    REDDE 41
  FIN SI

  CONIURA ast_program_free(program)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
