INCIPIT grimoire "config_env_overlay_20d4"

ADVOCARE "cct/config.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM src AD "debug=false"
  VINCIRE src AD CONIURA concat(src, "\n")
  VINCIRE src AD CONIURA concat(src, "[db]")
  VINCIRE src AD CONIURA concat(src, "\n")
  VINCIRE src AD CONIURA concat(src, "host=localhost")

  EVOCA SPECULUM NIHIL cfg AD CONIURA config_parse_ini(src)
  CONIURA config_apply_env_prefix(cfg, "CCT")
  SI NON CONIURA config_get_bool(cfg, "", "debug")
    REDDE 1
  FIN SI
  SI CONIURA compare(CONIURA config_get(cfg, "db", "host"), "remote.db") != 0
    REDDE 2
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
