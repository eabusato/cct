INCIPIT grimoire "codegen_expr_logical_26b"

ADVOCARE "../../src/bootstrap/codegen/codegen_context.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen_expr.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/lexer/token_type.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM AstNode a AD CONIURA ast_make_identifier("ok", 1, 1)
  EVOCA SPECULUM AstNode b AD CONIURA ast_make_literal_bool(VERUM, 1, 6)
  EVOCA SPECULUM AstNode expr AD CONIURA ast_make_binary(TK_ET, a, b, 1, 4)
  EVOCA SPECULUM CodegenContext ctx AD CONIURA codegen_context_new("logic.cct")
  CONIURA codegen_emit_expr(ctx, expr)
  EVOCA VERBUM out AD CONIURA codegen_output(ctx)
  EVOCA REX rc AD 0
  SI CONIURA compare(out, "(ok && 1)") != 0
    VINCIRE rc AD 1
  FIN SI
  DIMITTE out
  CONIURA ast_node_free(expr)
  CONIURA codegen_context_free(ctx)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
