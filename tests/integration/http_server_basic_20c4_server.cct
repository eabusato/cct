INCIPIT grimoire "http_server_basic_20c4_server"

ADVOCARE "cct/fs.cct"
ADVOCARE "cct/http.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM ready AD "tests/.tmp/http_server_basic_20c4.ready"
  EVOCA VERBUM done AD "tests/.tmp/http_server_basic_20c4.done"
  TEMPTA
    EVOCA SPECULUM NIHIL srv AD CONIURA http_server_listen("", 22334)
    CONIURA write_all(ready, "ready")

    EVOCA HttpRequest req AD CONIURA http_server_accept(srv)
    SI CONIURA compare(CONIURA http_request_method(req), "GET") != 0
      REDDE 10
    FIN SI
    SI CONIURA compare(CONIURA http_request_path(req), "/server-basic") != 0
      REDDE 11
    FIN SI

    EVOCA HttpResponse res AD CONIURA http_response_new(200, "server-ok")
    CONIURA http_headers_set_or_push(CONIURA http_response_headers_handle(res), "X-Server", "cct")
    CONIURA http_server_reply(srv, res)
    CONIURA write_all(done, "ok")
    REDDE 0
  CAPE FRACTUM erro
    EVOCA VERBUM msg AD OBSECRO fractum_to_verbum(erro)
    SI CONIURA compare(msg, "sock_bind falhou") == 0 VEL CONIURA compare(msg, "socket tcp create falhou") == 0
      CONIURA write_all(ready, "skip")
      CONIURA write_all(done, "skip")
      REDDE 0
    FIN SI
    REDDE 90
  FIN TEMPTA
  REDDE 91
EXPLICIT RITUALE

EXPLICIT grimoire
