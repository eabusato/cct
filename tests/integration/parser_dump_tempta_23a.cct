INCIPIT grimoire "parser_dump_tempta_23a"
ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/parser.cct"
RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"probe\"\nRITUALE main() REDDE NIHIL\n  TEMPTA\n    IACE \"boom\"\n  CAPE FRACTUM erro\n    REDDE\n  SEMPER\n    REDDE\n  FIN TEMPTA\nEXPLICIT RITUALE\nEXPLICIT grimoire\n"
  EVOCA VERBUM dump AD CONIURA parser_dump_program_source(src, "m.cct")
  SI NON CONIURA contains(dump, "TEMPTA (line 3, col 3)")
    REDDE 41
  FIN SI
  SI NON CONIURA contains(dump, "Cape Type:")
    REDDE 42
  FIN SI
  SI NON CONIURA contains(dump, "Type: FRACTUM")
    REDDE 43
  FIN SI
  SI NON CONIURA contains(dump, "Cape Name: erro")
    REDDE 44
  FIN SI
  SI NON CONIURA contains(dump, "Semper:")
    REDDE 45
  FIN SI
  REDDE 0
EXPLICIT RITUALE
EXPLICIT grimoire
