INCIPIT grimoire "parse_elige_bindings_23a"
ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/parser/parser.cct"
RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"x\" RITUALE main() REDDE NIHIL ELIGE r CASUS Ok(v): REDDE CASUS Err(msg): REDDE FIN ELIGE EXPLICIT RITUALE EXPLICIT grimoire"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(src, "m.cct")
  EVOCA SPECULUM AstNode rit AD CONIURA ast_node_list_get((*program).declarations, 0)
  EVOCA SPECULUM AstNode elige_stmt AD CONIURA ast_node_list_get((*(*rit).body).statements, 0)
  EVOCA SPECULUM AstNode case1 AD CONIURA ast_node_list_get((*elige_stmt).cases, 0)
  EVOCA SPECULUM AstNode case2 AD CONIURA ast_node_list_get((*elige_stmt).cases, 1)
  EVOCA SPECULUM AstNode bind1 AD CONIURA ast_node_list_get((*case1).bindings, 0)
  EVOCA SPECULUM AstNode bind2 AD CONIURA ast_node_list_get((*case2).bindings, 0)
  SI CONIURA ast_node_list_len((*case1).bindings) != 1 VEL CONIURA ast_node_list_len((*case2).bindings) != 1
    REDDE 41
  FIN SI
  SI CONIURA compare((*bind1).name, "v") != 0 VEL CONIURA compare((*bind2).name, "msg") != 0
    REDDE 42
  FIN SI
  CONIURA ast_program_free(program)
  REDDE 0
EXPLICIT RITUALE
EXPLICIT grimoire
