INCIPIT grimoire "compress_empty_text_32f"

ADVOCARE "cct/compress.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM zipped AD CONIURA gzip_compress("")
  SI CONIURA len(CONIURA compress_last_error()) > 0
    REDDE 1
  FIN SI
  SI CONIURA len(zipped) == 0
    REDDE 2
  FIN SI

  EVOCA VERBUM plain AD CONIURA gzip_decompress(zipped)
  SI CONIURA len(CONIURA compress_last_error()) > 0
    REDDE 3
  FIN SI
  SI CONIURA len(plain) != 0
    REDDE 4
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
