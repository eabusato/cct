INCIPIT grimoire "semantic_generic_lookup_out_of_scope_25a"

ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/parser.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_context.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_register.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_resolver.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM src AD "INCIPIT grimoire \"p\" RITUALE fabrica GENUS(T)(T valor) REDDE T REDDE valor EXPLICIT RITUALE EXPLICIT grimoire"
  EVOCA SPECULUM AstProgram program AD CONIURA parser_parse_program_source(src, "lookup_oos.cct")
  EVOCA SPECULUM SemanticContext ctx AD CONIURA semantic_context_new("lookup_oos.cct")
  CONIURA semantic_register_program(ctx, program)

  SI CONIURA semantic_lookup(ctx, "T") != CONIURA semantic_invalid_id()
    REDDE 41
  FIN SI

  EVOCA SPECULUM AstNode type_node AD CONIURA ast_make_type("T", 1, 1)
  EVOCA REX resolved_type_id AD CONIURA semantic_resolve_type_node(ctx, type_node)
  SI resolved_type_id != (*ctx).type_error
    REDDE 42
  FIN SI
  SI (*ctx).had_error != VERUM
    REDDE 43
  FIN SI
  SI CONIURA compare((*ctx).last_error_message, "unknown type 'T'") != 0
    REDDE 44
  FIN SI

  CONIURA ast_node_free(type_node)
  CONIURA semantic_context_free(ctx)
  CONIURA ast_program_free(program)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
