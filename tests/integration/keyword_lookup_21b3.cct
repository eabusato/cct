INCIPIT grimoire "keyword_lookup_21b3"

ADVOCARE "../../src/bootstrap/lexer/token_type.cct"
ADVOCARE "../../src/bootstrap/lexer/keywords.cct"

RITUALE expect_kind(VERBUM lexeme, TokenKind expected, REX code) REDDE REX
  SI CONIURA keyword_lookup(lexeme) != expected
    REDDE code
  FIN SI
  REDDE 0
EXPLICIT RITUALE

