INCIPIT grimoire "semantic_expr_binary_valid_24d"

ADVOCARE "../../src/bootstrap/lexer/token_type.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_context.cct"
ADVOCARE "../../src/bootstrap/semantic/semantic_expr.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM SemanticContext ctx AD CONIURA semantic_context_new("binary_valid.cct")
  EVOCA SPECULUM AstNode left AD CONIURA ast_make_literal_int("7", 1, 1)
  EVOCA SPECULUM AstNode right AD CONIURA ast_make_literal_real("3.5", 1, 5)
  EVOCA SPECULUM AstNode expr AD CONIURA ast_make_binary(TK_PLUS, left, right, 1, 3)
  EVOCA REX type_id AD CONIURA semantic_analyze_expr(ctx, expr)

  SI type_id != (*ctx).type_umbra
    REDDE 41
  FIN SI
  SI CONIURA semantic_had_error(ctx)
    REDDE 42
  FIN SI

  CONIURA semantic_context_free(ctx)
  CONIURA ast_node_free(expr)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
