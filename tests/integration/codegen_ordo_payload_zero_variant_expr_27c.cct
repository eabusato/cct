INCIPIT grimoire "codegen_ordo_payload_zero_variant_expr_27c"

ADVOCARE "../../src/bootstrap/codegen/codegen_context.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen_expr.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM CodegenContext ctx AD CONIURA codegen_context_new("ordo_zero.cct")
  CONIURA codegen_register_ordo(ctx, "Option", "cct_boot_ord_Option")
  CONIURA codegen_mark_ordo_has_payload(ctx, "Option")
  CONIURA codegen_ordo_append_item_with_arity(ctx, "Option", "None", "cct_boot_tag_Option__None", 0)
  EVOCA SPECULUM AstNode expr AD CONIURA ast_make_identifier("None", 1, 1)
  CONIURA codegen_emit_expr(ctx, expr)
  EVOCA VERBUM out AD CONIURA codegen_output(ctx)
  EVOCA REX rc AD 0
  SI NON CONIURA contains(out, "cct_boot_ord_Option")
    VINCIRE rc AD 1
  FIN SI
  SI NON CONIURA contains(out, ".__tag = cct_boot_tag_Option__None")
    VINCIRE rc AD 2
  FIN SI
  DIMITTE out
  CONIURA ast_node_free(expr)
  CONIURA codegen_context_free(ctx)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
