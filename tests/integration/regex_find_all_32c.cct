INCIPIT grimoire "regex_find_all_32c"

ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/regex.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL compiled AD CONIURA regex_compile("[0-9]+")
  SI CONIURA result_is_err GENUS(Regex, VERBUM)(compiled)
    REDDE 1
  FIN SI

  EVOCA Regex rx AD CONIURA result_unwrap GENUS(Regex, VERBUM)(compiled)
  EVOCA SPECULUM NIHIL items AD CONIURA regex_find_all(rx, "ids: 10, 22, 305")
  EVOCA REX n AD CONIURA fluxus_len(items)
  EVOCA VERBUM joined AD CONIURA regex_find_all_joined(rx, "ids: 10, 22, 305", "|")
  SI n != 3
    CONIURA regex_free(rx)
    CONIURA fluxus_free(items)
    REDDE 2
  FIN SI

  CONIURA regex_free(rx)
  CONIURA fluxus_free(items)

  SI CONIURA compare(joined, "10|22|305") != 0
    REDDE 3
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
