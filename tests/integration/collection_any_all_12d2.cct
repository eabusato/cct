INCIPIT grimoire "collection_any_all_12d2"

ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/collection_ops.cct"

RITUALE eh_positivo(REX x) REDDE VERUM
  REDDE x > 0
EXPLICIT RITUALE

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL nums AD CONIURA fluxus_init(MENSURA(REX))
  EVOCA REX a AD 1
  EVOCA REX b AD 2
  EVOCA REX c AD 3
  CONIURA fluxus_push(nums, SPECULUM a)
  CONIURA fluxus_push(nums, SPECULUM b)
  CONIURA fluxus_push(nums, SPECULUM c)

  EVOCA REX code AD 0
  SI CONIURA fluxus_all GENUS(REX)(nums, eh_positivo)
    VINCIRE code AD code + 10
  FIN SI
  SI CONIURA fluxus_any GENUS(REX)(nums, eh_positivo)
    VINCIRE code AD code + 1
  FIN SI

  CONIURA fluxus_free(nums)
  REDDE code
EXPLICIT RITUALE

EXPLICIT grimoire
