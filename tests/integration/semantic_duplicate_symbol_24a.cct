INCIPIT grimoire "semantic_duplicate_symbol_24a"

ADVOCARE "../../src/bootstrap/semantic/semantic_context.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM SemanticContext ctx AD CONIURA semantic_context_new("dup.cct")
  EVOCA REX first AD CONIURA semantic_define(ctx, SEM_SYMBOL_VARIABLE, "x", (*ctx).type_rex, 1, 1)
  EVOCA REX second AD CONIURA semantic_define(ctx, SEM_SYMBOL_PARAMETER, "x", (*ctx).type_dux, 2, 2)

  SI first == CONIURA semantic_invalid_id()
    REDDE 41
  FIN SI
  SI second != CONIURA semantic_invalid_id()
    REDDE 42
  FIN SI
  SI (*ctx).had_error != VERUM
    REDDE 43
  FIN SI
  SI (*ctx).error_count != 1
    REDDE 44
  FIN SI
  SI CONIURA semantic_lookup_local(ctx, "x") != first
    REDDE 45
  FIN SI

  CONIURA semantic_context_free(ctx)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
