INCIPIT grimoire "db_transaction_commit_20e4"

ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL db AD CONIURA db_open(":memory:")
  CONIURA db_exec(db, "CREATE TABLE items(id INTEGER, nome TEXT);")

  CONIURA db_begin(db)
  CONIURA db_exec(db, "INSERT INTO items(id, nome) VALUES(1, 'alpha');")
  CONIURA db_exec(db, "INSERT INTO items(id, nome) VALUES(2, 'beta');")
  CONIURA db_commit(db)

  SI CONIURA db_scalar_int(db, "SELECT COUNT(*) FROM items;") != 2
    REDDE 1
  FIN SI
  SI CONIURA compare(CONIURA db_scalar_text(db, "SELECT nome FROM items WHERE id = 2;"), "beta") != 0
    REDDE 2
  FIN SI

  CONIURA db_close(db)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
