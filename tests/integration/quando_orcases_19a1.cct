INCIPIT grimoire "quando_orcases_19a1"

RITUALE main() REDDE NIHIL
  EVOCA REX status AD 201

  QUANDO status
    CASO 200:
    CASO 201:
      OBSECRO scribe("ok\n")
    CASO 500:
      OBSECRO scribe("erro\n")
    SENAO:
      OBSECRO scribe("desconhecido\n")
  FIN QUANDO

  REDDE
EXPLICIT RITUALE

EXPLICIT grimoire
