INCIPIT grimoire "form_percent_invalid_33f"

ADVOCARE "cct/form_codec.cct"
ADVOCARE "cct/result.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL invalid_a AD CONIURA percent_decode("%")
  EVOCA SPECULUM NIHIL invalid_b AD CONIURA percent_decode("%G1")

  SI NON CONIURA result_is_err GENUS(VERBUM, VERBUM)(invalid_a)
    REDDE 1
  FIN SI
  SI NON CONIURA result_is_err GENUS(VERBUM, VERBUM)(invalid_b)
    REDDE 1
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
