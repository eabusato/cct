INCIPIT grimoire "parse_evoca_with_init_22c"
ADVOCARE "cct/verbum.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "../../src/bootstrap/parser/parse_stmt.cct"
RITUALE main() REDDE REX
  EVOCA SPECULUM AstNode stmt AD CONIURA parser_parse_statement_source("EVOCA REX x AD 3", "stmt.cct")
  SI (*stmt).kind != AST_EVOCA VEL (*stmt).has_right != VERUM
    REDDE 41
  FIN SI
  SI CONIURA compare((*(*stmt).right).value_text, "3") != 0
    REDDE 42
  FIN SI
  CONIURA ast_node_free(stmt)
  REDDE 0
EXPLICIT RITUALE
EXPLICIT grimoire
