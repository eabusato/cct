INCIPIT grimoire "codegen_type_reuse_consistency_26e"

ADVOCARE "../../src/bootstrap/codegen/codegen_context.cct"
ADVOCARE "../../src/bootstrap/codegen/codegen_type.cct"
ADVOCARE "../../src/bootstrap/parser/ast.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM CodegenContext ctx AD CONIURA codegen_context_new("reuse.cct")
  EVOCA SPECULUM AstNode left AD CONIURA ast_make_type("MILES", 1, 1)
  EVOCA SPECULUM AstNode right AD CONIURA ast_make_type("MILES", 1, 1)
  EVOCA VERBUM a AD CONIURA codegen_type_text(ctx, left)
  EVOCA VERBUM b AD CONIURA codegen_type_text(ctx, right)
  EVOCA REX rc AD 0
  SI CONIURA compare(a, "char") != 0
    VINCIRE rc AD 1
  FIN SI
  SI CONIURA compare(b, "char") != 0
    VINCIRE rc AD 2
  FIN SI
  CONIURA ast_node_free(left)
  CONIURA ast_node_free(right)
  CONIURA codegen_context_free(ctx)
  REDDE rc
EXPLICIT RITUALE

EXPLICIT grimoire
