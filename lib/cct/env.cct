INCIPIT grimoire "env"

RITUALE getenv(VERBUM name) REDDE VERBUM
  REDDE OBSECRO env_get(name)
EXPLICIT RITUALE

RITUALE has_env(VERBUM name) REDDE VERUM
  REDDE OBSECRO env_has(name)
EXPLICIT RITUALE

RITUALE cwd() REDDE VERBUM
  REDDE OBSECRO env_cwd()
EXPLICIT RITUALE

EXPLICIT grimoire
