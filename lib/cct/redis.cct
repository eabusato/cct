EXPLICIT RITUALE

RITUALE redis_poll_message(Redis redis, REX timeout_ms) REDDE SPECULUM NIHIL
  SI NON redis.open
    REDDE CONIURA Err GENUS(RedisMaybeMessage, VERBUM)("Redis fechado")
  FIN SI
  EVOCA RedisRawReply raw_reply
  EVOCA VERBUM err AD CONIURA redis_recv_raw_fill(redis, timeout_ms, SPECULUM raw_reply)
  SI CONIURA len(err) > 0
    REDDE CONIURA Err GENUS(RedisMaybeMessage, VERBUM)(err)
  FIN SI
  EVOCA VERBUM raw AD raw_reply.payload
  SI CONIURA len(raw) == 0
    REDDE CONIURA Ok GENUS(RedisMaybeMessage, VERBUM)(CONIURA redis_maybe_message_none())
  FIN SI
  EVOCA RedisValue value AD CONIURA redis_resp_parse(raw)
  SI value.kind != REDIS_ARRAY
    REDDE CONIURA Ok GENUS(RedisMaybeMessage, VERBUM)(CONIURA redis_maybe_message_none())
  FIN SI
  EVOCA VERBUM kind AD CONIURA redis_value_to_text(CONIURA redis_array_get(value, 0))
  EVOCA RedisMessage message
  VINCIRE message.channel AD ""
  VINCIRE message.pattern AD ""
  VINCIRE message.payload AD ""
  SI CONIURA compare(kind, "message") == 0 ET CONIURA redis_array_len(value) >= 3
    VINCIRE message.channel AD CONIURA redis_value_to_text(CONIURA redis_array_get(value, 1))
    VINCIRE message.payload AD CONIURA redis_value_to_text(CONIURA redis_array_get(value, 2))
    REDDE CONIURA Ok GENUS(RedisMaybeMessage, VERBUM)(CONIURA redis_maybe_message_some(message))
  FIN SI
  SI CONIURA compare(kind, "pmessage") == 0 ET CONIURA redis_array_len(value) >= 4
    VINCIRE message.pattern AD CONIURA redis_value_to_text(CONIURA redis_array_get(value, 1))
    VINCIRE message.channel AD CONIURA redis_value_to_text(CONIURA redis_array_get(value, 2))
    VINCIRE message.payload AD CONIURA redis_value_to_text(CONIURA redis_array_get(value, 3))
    REDDE CONIURA Ok GENUS(RedisMaybeMessage, VERBUM)(CONIURA redis_maybe_message_some(message))
  FIN SI
  REDDE CONIURA Ok GENUS(RedisMaybeMessage, VERBUM)(CONIURA redis_maybe_message_none())
EXPLICIT RITUALE

RITUALE redis_text_list_len(RedisTextList list) REDDE REX
  REDDE list.count
EXPLICIT RITUALE

RITUALE redis_text_list_get(RedisTextList list, REX index) REDDE VERBUM
  EVOCA RedisValue array_value AD CONIURA redis_value_array(list.encoded, list.count)
  REDDE CONIURA redis_value_to_text(CONIURA redis_array_get(array_value, index))
EXPLICIT RITUALE

RITUALE redis_pair_list_len(RedisPairList list) REDDE REX
  REDDE list.count
EXPLICIT RITUALE

RITUALE redis_pair_list_get(RedisPairList list, REX index) REDDE RedisPair
  EVOCA RedisValue array_value AD CONIURA redis_value_array(list.encoded, list.count * 2)
  EVOCA RedisPair pair
  VINCIRE pair.key AD CONIURA redis_value_to_text(CONIURA redis_array_get(array_value, index * 2))
  VINCIRE pair.value AD CONIURA redis_value_to_text(CONIURA redis_array_get(array_value, index * 2 + 1))
  REDDE pair
EXPLICIT RITUALE

EXPLICIT grimoire
