RITUALE redis_smembers(Redis redis, VERBUM key) REDDE SPECULUM NIHIL
  EVOCA RedisRawReply raw_reply
  EVOCA VERBUM err AD CONIURA redis_send_wire_fill(redis, CONIURA redis_argv_2("SMEMBERS", key), SPECULUM raw_reply)
  SI CONIURA len(err) > 0
    REDDE CONIURA Err GENUS(RedisTextList, VERBUM)(err)
  FIN SI
  EVOCA RedisValue value AD CONIURA redis_resp_parse(raw_reply.payload)
  EVOCA RedisTextList out AD CONIURA redis_text_list_empty()
  SI value.kind == REDIS_ARRAY
    VINCIRE out.encoded AD value.string_value
    VINCIRE out.count AD value.int_value
  FIN SI
  REDDE CONIURA Ok GENUS(RedisTextList, VERBUM)(out)
