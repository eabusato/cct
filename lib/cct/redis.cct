RITUALE redis_publish(Redis redis, VERBUM channel, VERBUM payload) REDDE SPECULUM NIHIL
  EVOCA RedisRawReply raw_reply
  EVOCA VERBUM err AD CONIURA redis_send_wire_fill(redis, CONIURA redis_argv_3("PUBLISH", channel, payload), SPECULUM raw_reply)
  SI CONIURA len(err) > 0
    REDDE CONIURA Err GENUS(REX, VERBUM)(err)
  FIN SI
  EVOCA RedisValue value AD CONIURA redis_resp_parse(raw_reply.payload)
  REDDE CONIURA Ok GENUS(REX, VERBUM)(value.int_value)
EXPLICIT RITUALE

RITUALE redis_subscribe(Redis redis, VERBUM channel) REDDE SPECULUM NIHIL
  REDDE CONIURA redis_simple_ok_wire(redis, CONIURA redis_argv_2("SUBSCRIBE", channel))
EXPLICIT RITUALE

RITUALE redis_psubscribe(Redis redis, VERBUM pattern) REDDE SPECULUM NIHIL
  REDDE CONIURA redis_simple_ok_wire(redis, CONIURA redis_argv_2("PSUBSCRIBE", pattern))
EXPLICIT RITUALE

RITUALE redis_unsubscribe(Redis redis, VERBUM channel) REDDE SPECULUM NIHIL
