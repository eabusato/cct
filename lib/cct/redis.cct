  EVOCA RedisRawReply raw_reply
  EVOCA VERBUM err AD CONIURA redis_send_wire_fill(redis, CONIURA redis_argv_3("SADD", key, value), SPECULUM raw_reply)
  SI CONIURA len(err) > 0
    REDDE CONIURA Err GENUS(VERUM, VERBUM)(err)
  FIN SI
  EVOCA RedisValue reply_value AD CONIURA redis_resp_parse(raw_reply.payload)
  REDDE CONIURA Ok GENUS(VERUM, VERBUM)(reply_value.int_value > 0)
