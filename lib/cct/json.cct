RITUALE json_parse(VERBUM s) REDDE Json
  EVOCA SPECULUM NIHIL c AD CONIURA cursor_init(s)
  TEMPTA
    CONIURA json_skip_ws(c)
    EVOCA Json out AD CONIURA json_parse_value(s, c)
    CONIURA json_skip_ws(c)
    SI NON CONIURA cursor_eof(c)
      IACE "json: invalid literal"
    FIN SI
    CONIURA cursor_free(c)
    REDDE out
  CAPE FRACTUM erro
    CONIURA cursor_free(c)
    IACE erro
  FIN TEMPTA
  REDDE JsonNull
EXPLICIT RITUALE

RITUALE json_try_parse(VERBUM s) REDDE SPECULUM NIHIL
  TEMPTA
    EVOCA Json out AD CONIURA json_parse(s)
    REDDE CONIURA Ok GENUS(Json, JsonError)(out)
  CAPE FRACTUM erro
    EVOCA JsonError e AD JsonErrorMsg(OBSECRO fractum_to_verbum(erro))
    REDDE CONIURA Err GENUS(Json, JsonError)(e)
  FIN TEMPTA
  EVOCA JsonError fallback AD JsonErrorMsg("json: invalid literal")
  REDDE CONIURA Err GENUS(Json, JsonError)(fallback)
EXPLICIT RITUALE

RITUALE json_parse_file(VERBUM path) REDDE Json
  EVOCA VERBUM s AD CONIURA read_all(path)
  REDDE CONIURA json_parse(s)
EXPLICIT RITUALE

RITUALE json_try_parse_file(VERBUM path) REDDE SPECULUM NIHIL
  TEMPTA
    EVOCA Json out AD CONIURA json_parse_file(path)
    REDDE CONIURA Ok GENUS(Json, JsonError)(out)
  CAPE FRACTUM erro
    EVOCA JsonError e AD JsonErrorMsg(OBSECRO fractum_to_verbum(erro))
    REDDE CONIURA Err GENUS(Json, JsonError)(e)
  FIN TEMPTA
  EVOCA JsonError fallback AD JsonErrorMsg("json: invalid literal")
  REDDE CONIURA Err GENUS(Json, JsonError)(fallback)
EXPLICIT RITUALE

EXPLICIT grimoire
