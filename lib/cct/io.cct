INCIPIT grimoire "io"

RITUALE print(VERBUM s) REDDE NIHIL
  OBSECRO io_print(s)
  REDDE
EXPLICIT RITUALE

RITUALE println(VERBUM s) REDDE NIHIL
  OBSECRO io_println(s)
  REDDE
EXPLICIT RITUALE

RITUALE print_int(REX n) REDDE NIHIL
  OBSECRO io_print_int(n)
  REDDE
EXPLICIT RITUALE

RITUALE read_line() REDDE VERBUM
  REDDE OBSECRO io_read_line()
EXPLICIT RITUALE

EXPLICIT grimoire
